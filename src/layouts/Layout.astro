---
import Analytics from '../components/Analytics.astro';
import SEO from '../components/SEO.astro';
import '../styles/global.css';
import { getCollection } from 'astro:content';

// Build search index from all blog posts
const allBlogPosts = await getCollection('blog');
const searchIndex = allBlogPosts.map(post => {
  const slugParts = post.id.split('/');
  const cleanSlug = slugParts.length > 1 ? slugParts.slice(1).join('/').replace(/\.md$/, '') : slugParts[0].replace(/\.md$/, '');
  const prefix = { zh: '', en: '/en', ja: '/ja', hi: '/hi' }[post.data.lang] || '';
  return {
    url: `${prefix}/blog/${cleanSlug}`,
    title: post.data.title,
    description: post.data.description,
    tags: post.data.tags,
    lang: post.data.lang,
  };
});

export interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const { title, description, lang = 'zh-CN' } = Astro.props;

const siteUrl = 'https://kailash2026.com';
const currentPath = Astro.url.pathname;

// Extract current route from path (strip language prefix)
let routePath = currentPath;
for (const prefix of ['/en', '/ja', '/hi']) {
  if (currentPath === prefix) {
    routePath = '/';
    break;
  }
  if (currentPath.startsWith(prefix + '/')) {
    routePath = currentPath.slice(prefix.length);
    break;
  }
}

// Build alternate URLs for hreflang tags
const zhAlt = siteUrl + (routePath === '/' ? '' : routePath);
const enAlt = siteUrl + '/en' + (routePath === '/' ? '' : routePath);
const jaAlt = siteUrl + '/ja' + (routePath === '/' ? '' : routePath);
const hiAlt = siteUrl + '/hi' + (routePath === '/' ? '' : routePath);

const navItems = [
  { label: 'གཙོ་ངོས།', labelZh: '首页', labelEn: 'Home', href: '/' },
  { label: '🔥 རྟ་ལོ།', labelZh: '🔥 马年专题', labelEn: '🔥 Horse Year', href: '/horse-year-2026' },
  { label: 'ལྷ་རིའི་རིག་གནས།', labelZh: '神山文化', labelEn: 'Culture', href: '/culture' },
  { label: 'མཇལ་བསྐོར་གནས་ཚུལ།', labelZh: '朝圣攻略', labelEn: 'Guide', href: '/guide' },
  { label: 'ལམ་ཐིག', labelZh: '转山路线', labelEn: 'Routes', href: '/routes' },
  { label: 'མངའ་རིས་རིག་གནས།', labelZh: '阿里人文', labelEn: 'Ngari Culture', href: '/ali' },
  { label: 'ཤེས་བྱའི་མཛོད།', labelZh: '知识宝典', labelEn: 'Codex', href: '/codex' },
  { label: 'སྒྲོལ་ལྗོངས།', labelZh: '朝圣故事', labelEn: 'Stories', href: '/stories' },
  { label: 'བརྙན་མཛོད།', labelZh: '图库', labelEn: 'Gallery', href: '/gallery' },
  { label: 'ཟུང་བྲལ།', labelZh: '常见问题', labelEn: 'FAQ', href: '/faq' },
  { label: 'ང་ཚོ།', labelZh: '关于我们', labelEn: 'About', href: '/about' },
  { label: 'འབྲེལ་བ།', labelZh: '联系我们', labelEn: 'Contact', href: '/contact' },
  { label: '🤖', labelZh: '🤖 生活助手', labelEn: '🤖 Assistant', href: '/assistant' },
];
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <SEO title={title} description={description} />
  <Analytics />
  <meta name="msvalidate.01" content="A201D66C22CCDC609070662B96215D47" />
  <link rel="alternate" hreflang="zh-CN" href={zhAlt} />
  <link rel="alternate" hreflang="en" href={enAlt} />
  <link rel="alternate" hreflang="hi" href={hiAlt} />
  <link rel="alternate" hreflang="ja" href={jaAlt} />
  <link rel="alternate" hreflang="x-default" href={zhAlt} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@400;600;700&display=swap" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet"></noscript>
  <link rel="preload" as="image" href="/images/kailash-hero.webp" fetchpriority="high" />
  <meta http-equiv="Cache-Control" content="public, max-age=31536000, immutable" />
  <style>body{font-family:system-ui,-apple-system,sans-serif}body.fonts-loaded{font-family:Inter,system-ui,sans-serif}</style>
</head>
<body class="bg-kailash-light text-kailash-dark antialiased">
  <header class="fixed top-0 w-full bg-kailash-dark/95 backdrop-blur-sm z-50">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        <a href="/" class="text-kailash-gold font-display text-2xl font-bold">Kailash 2026</a>

        {/* Desktop Nav */}
        <div class="hidden lg:flex items-center space-x-6">
          {navItems.slice(0, 5).map(item => (
            <a href={item.href} class="text-white hover:text-kailash-gold transition text-sm group relative">
              <span>{item.labelZh}</span>
              <span class="hidden group-hover:inline text-xs text-kailash-gold ml-1">{item.label}</span>
            </a>
          ))}

          {/* Language Switcher */}
          <div class="flex items-center gap-1 ml-4 border-l border-white/20 pl-4">
            <button
              class="lang-btn px-2 py-1 rounded text-sm text-kailash-gold font-medium"
              data-lang="zh"
              onclick="switchLanguage('zh')"
            >
              中文
            </button>
            <span class="text-white/30">|</span>
            <button
              class="lang-btn px-2 py-1 rounded text-sm text-white/60 hover:text-white transition"
              data-lang="en"
              onclick="switchLanguage('en')"
            >
              EN
            </button>
            <span class="text-white/30">|</span>
            <button
              class="lang-btn px-2 py-1 rounded text-sm text-white/60 hover:text-white transition"
              data-lang="hi"
              onclick="switchLanguage('hi')"
            >
              हिंदी
            </button>
            <span class="text-white/30">|</span>
            <button
              class="lang-btn px-2 py-1 rounded text-sm text-white/60 hover:text-white transition"
              data-lang="ja"
              onclick="switchLanguage('ja')"
            >
              日本語
            </button>
          </div>

        {/* Search Box */}
        <div class="relative ml-4">
          <input
            type="text"
            id="nav-search-input"
            placeholder="搜索..."
            class="bg-white/10 text-white placeholder-white/50 px-4 py-2 rounded-lg text-sm w-48 focus:outline-none focus:ring-2 focus:ring-kailash-gold/50 focus:bg-white/20 transition"
          />
          <button
            id="nav-search-btn"
            class="absolute right-2 top-1/2 -translate-y-1/2 text-white/60 hover:text-kailash-gold transition"
            aria-label="搜索"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
          </button>
        </div>
        </div>

        {/* Mobile Menu Button */}
        <button id="mobile-menu-btn" class="lg:hidden text-white p-2" aria-label="打开菜单" aria-expanded="false">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>

      {/* Mobile Nav */}
      <div id="mobile-menu" class="hidden lg:hidden pb-4">
        <div class="flex flex-col space-y-3">
          {navItems.map(item => (
            <a href={item.href} class="text-white hover:text-kailash-gold transition py-2">
              {item.labelZh}
            </a>
          ))}
          <a href="/guide" class="bg-kailash-gold text-kailash-dark px-4 py-3 rounded-lg font-medium text-center">
            Explore / 探索
          </a>

          {/* Mobile Search */}
          <div class="relative mt-3">
            <input
              type="text"
              id="mobile-search-input"
              placeholder="搜索..."
              class="bg-white/10 text-white placeholder-white/50 px-4 py-3 rounded-lg text-sm w-full focus:outline-none focus:ring-2 focus:ring-kailash-gold/50 focus:bg-white/20 transition"
            />
            <button
              id="mobile-search-btn"
              class="absolute right-3 top-1/2 -translate-y-1/2 text-white/60 hover:text-kailash-gold transition"
              aria-label="搜索"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </nav>
  </header>

  <main class="pt-16">
    <slot />
  </main>

  <footer class="bg-kailash-dark text-white py-12 mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-4 gap-8">
        <div>
          <h3 class="font-display text-xl text-kailash-gold mb-4">Kailash 2026</h3>
          <p class="text-gray-400 text-sm">专注冈仁波齐朝圣之旅，为您提供专业的文化解读与行程服务。</p>
        </div>

        <div>
          <h4 class="font-medium mb-4">探索</h4>
          <ul class="space-y-2 text-gray-400 text-sm">
            <li><a href="/culture" class="hover:text-kailash-gold">神山文化</a></li>
            <li><a href="/guide" class="hover:text-kailash-gold">朝圣攻略</a></li>
            <li><a href="/routes" class="hover:text-kailash-gold">转山路线</a></li>
            <li><a href="/codex" class="hover:text-kailash-gold">知识宝典</a></li>
            <li><a href="/stories" class="hover:text-kailash-gold">朝圣故事</a></li>
            <li><a href="/gallery" class="hover:text-kailash-gold">图库</a></li>
          </ul>
        </div>

        <div>
          <h4 class="font-medium mb-4">服务</h4>
          <ul class="space-y-2 text-gray-400 text-sm">
            <li><a href="/faq" class="hover:text-kailash-gold">常见问题</a></li>
            <li><a href="/about" class="hover:text-kailash-gold">关于我们</a></li>
            <li><a href="/contact" class="hover:text-kailash-gold">联系我们</a></li>
          </ul>
        </div>

        <div>
          <h4 class="font-medium mb-4">联系我们</h4>
          <p class="text-gray-400 text-sm">kailash2026Lucas@outlook.com</p>
          <p class="text-gray-400 text-sm mt-2">微信: Kailash2026</p>
        </div>
      </div>
      <div class="border-t border-gray-700 mt-8 pt-8 text-center text-gray-400 text-sm">
        © 2026 Kailash. 保留所有权利。
      </div>
    </div>
  </footer>

  <script define:vars={{ index: JSON.stringify(searchIndex) }}>
    const blogSearchIndex = JSON.parse(index);
  </script>
  <script>

    // Mobile menu toggle
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');

    menuBtn?.addEventListener('click', () => {
      mobileMenu?.classList.toggle('hidden');
    });

    // Search functionality
    function performSearch(query) {
      if (!query || query.trim().length === 0) return;

      const searchTerm = query.trim().toLowerCase();

      // Define searchable pages with keywords
      const searchablePages = [
        { url: '/culture', title: '神山文化', titleEn: 'Culture', keywords: ['文化', '宗教', '历史', '藏传佛教', '印度教', '苯教', '耆那教', 'culture', 'religion', 'buddhism', 'hinduism', 'bon', 'jainism'] },
        { url: '/guide', title: '朝圣攻略', titleEn: 'Guide', keywords: ['攻略', '指南', '准备', '行程', '装备', '注意事项', '高原反应', 'guide', 'preparation', 'equipment', 'altitude'] },
        { url: '/routes', title: '转山路线', titleEn: 'Routes', keywords: ['路线', '转山', '徒步', '里程', '海拔', '卓玛拉', 'kora', 'route', 'trek', '52km'] },
        { url: '/stories', title: '朝圣故事', titleEn: 'Stories', keywords: ['故事', '朝圣', '经历', '感悟', '传说', '米拉日巴', 'pilgrim', 'story'] },
        { url: '/gallery', title: '图库', titleEn: 'Gallery', keywords: ['图片', '照片', '风景', '冈仁波齐', '玛旁雍错', '雪山', 'photo', 'gallery'] },
        { url: '/faq', title: '常见问题', titleEn: 'FAQ', keywords: ['问题', 'FAQ', '签证', '交通', '住宿', '费用', 'visa', 'transport', 'cost', 'permit'] },
        { url: '/about', title: '关于我们', titleEn: 'About', keywords: ['关于', '介绍', '团队', '使命', '愿景', 'about'] },
        { url: '/contact', title: '联系我们', titleEn: 'Contact', keywords: ['联系', '邮箱', '反馈', 'contact', 'email'] },
        { url: '/codex', title: '知识宝典', titleEn: 'Codex', keywords: ['百科', '知识', 'codex', 'encyclopedia', '文献', '经典'] },
        { url: '/blog', title: '朝圣博客', titleEn: 'Blog', keywords: ['博客', '文章', 'blog', 'article', '指南'] },
      ];

      // Search static pages
      const pageResults = searchablePages.filter(page => {
        const inTitle = page.title.toLowerCase().includes(searchTerm);
        const inTitleEn = (page.titleEn || '').toLowerCase().includes(searchTerm);
        const inKeywords = page.keywords.some(k => k.includes(searchTerm));
        return inTitle || inTitleEn || inKeywords;
      });

      // Search blog posts
      const blogResults = blogSearchIndex.filter(post => {
        const inTitle = post.title.toLowerCase().includes(searchTerm);
        const inDesc = post.description.toLowerCase().includes(searchTerm);
        const inTags = post.tags.some(t => t.toLowerCase().includes(searchTerm));
        return inTitle || inDesc || inTags;
      }).slice(0, 5);

      const allResults = [...pageResults.map(p => ({ ...p, type: 'page' })), ...blogResults.map(p => ({ ...p, type: 'blog' }))];

      if (allResults.length === 1) {
        window.location.href = allResults[0].url;
      } else if (allResults.length > 1) {
        // Show results as a simple modal
        const existing = document.getElementById('search-results-modal');
        if (existing) existing.remove();
        const modal = document.createElement('div');
        modal.id = 'search-results-modal';
        modal.style.cssText = 'position:fixed;top:4rem;left:50%;transform:translateX(-50%);width:90%;max-width:32rem;max-height:70vh;overflow-y:auto;background:white;border-radius:1rem;box-shadow:0 20px 60px rgba(0,0,0,0.3);z-index:9999;padding:1.5rem;';
        const bg = document.createElement('div');
        bg.style.cssText = 'position:fixed;inset:0;z-index:9998;';
        bg.onclick = () => { modal.remove(); bg.remove(); };
        modal.innerHTML = '<h3 class="font-bold text-kailash-dark mb-1">搜索结果 (' + allResults.length + ')</h3><p class="text-xs text-gray-400 mb-4">搜索: ' + searchTerm + '</p>' +
          allResults.map(r => '<a href="' + r.url + '" class="block p-3 rounded-lg hover:bg-kailash-cream transition mb-1"><span class="font-medium text-kailash-dark">' + r.title + '</span><span class="text-xs text-gray-400 ml-2">' + (r.type === 'blog' ? '📝' : '📄') + '</span>' + (r.description ? '<p class="text-sm text-gray-500 mt-1 line-clamp-1">' + r.description + '</p>' : '') + '</a>').join('');
        document.body.appendChild(bg);
        document.body.appendChild(modal);
      } else {
        alert('未找到相关内容，请尝试其他关键词');
      }
    }

    // Desktop search
    const desktopSearchInput = document.getElementById('nav-search-input');
    const desktopSearchBtn = document.getElementById('nav-search-btn');

    desktopSearchBtn?.addEventListener('click', () => {
      performSearch(desktopSearchInput?.value);
    });

    desktopSearchInput?.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        performSearch(desktopSearchInput.value);
      }
    });

    // Mobile search
    const mobileSearchInput = document.getElementById('mobile-search-input');
    const mobileSearchBtn = document.getElementById('mobile-search-btn');

    mobileSearchBtn?.addEventListener('click', () => {
      performSearch(mobileSearchInput?.value);
    });

    mobileSearchInput?.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        performSearch(mobileSearchInput.value);
      }
    });
  </script>
  <!-- PWA Service Worker -->
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      });
    }
  </script>
  <!-- Global Language Switch Script -->
  <script is:inline>
    (function() {
      function switchLanguage(lang) {
        const currentPath = window.location.pathname;
        const isOnLangPage = currentPath.startsWith('/' + lang + '/');

        // For ja/hi on pages without inline content: redirect to standalone page
        if ((lang === 'ja' || lang === 'hi') && !isOnLangPage) {
          var hasInline = document.querySelectorAll('[data-lang-content="' + lang + '"]').length > 0;
          if (!hasInline) {
            localStorage.setItem('preferred-lang', lang);
            window.location.href = '/' + lang + currentPath;
            return;
          }
        }

        // From ja/hi standalone pages back to root for zh/en
        if ((lang === 'zh' || lang === 'en') && (currentPath.startsWith('/ja/') || currentPath.startsWith('/hi/'))) {
          localStorage.setItem('preferred-lang', lang);
          window.location.href = currentPath.replace(/^\/(ja|hi)\//, '/');
          return;
        }

        document.documentElement.setAttribute('data-lang', lang);
        localStorage.setItem('preferred-lang', lang);

        // Update button styles
        document.querySelectorAll('.lang-btn').forEach(btn => {
          if (btn.getAttribute('data-lang') === lang) {
            btn.classList.remove('text-white/60', 'hover:text-white');
            btn.classList.add('text-kailash-gold', 'font-medium');
          } else {
            btn.classList.remove('text-kailash-gold', 'font-medium');
            btn.classList.add('text-white/60', 'hover:text-white');
          }
        });

        // Toggle content visibility
        document.querySelectorAll('[data-lang-content]').forEach(el => {
          if (el.getAttribute('data-lang-content') === lang) {
            el.style.display = '';
          } else {
            el.style.display = 'none';
          }
        });
      }

      // Initialize on page load
      const savedLang = localStorage.getItem('preferred-lang') || 'zh';
      switchLanguage(savedLang);

      // Expose to global scope for onclick handlers
      window.switchLanguage = switchLanguage;
    })();
  </script>
</body>
</html>

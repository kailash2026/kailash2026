      { day: 7, title: "返回拉萨", titleEn: "Return to Lhasa", desc: "从阿里昆莎机场飞回拉萨，行程结束。建议在拉萨再多住1天休息恢复。", descEn: "Fly back to Lhasa from Ali Kunsha Airport. Trip complete. Recommend one extra rest day in Lhasa." }
    ]
  },
  {
    name: "尼泊尔入境朝圣线",
    nameEn: "Nepal Entry Pilgrimage Route",
    summary: "从加德满都经吉隆口岸入藏，是一条风景壮美但条件艰苦的路线。适合有高原经验、时间充裕的朝圣者。全程约14-16天。",
    summaryEn: "Enter Tibet from Kathmandu via Gyirong Port. A spectacular but demanding route. Suitable for altitude-experienced pilgrims with ample time. ~14-16 days total.",
    days: [
      { day: 1, title: "加德满都休整（1400m）", titleEn: "Kathmandu rest (1400m)", desc: "在加德满都办理中国签证（如需），联系旅行社办理进藏函。参观博达哈大佛塔和斯瓦扬布纳寺（猴庙），为朝圣之旅祈福。", descEn: "Process China visa in Kathmandu if needed; arrange Tibet Travel Permit through an agency. Visit Boudhanath Stupa and Swayambhunath (Monkey Temple) for pilgrimage blessings." },
      { day: 2, title: "加德满都→吉隆镇（2700m）", titleEn: "Kathmandu→Gyirong Town (2700m)", desc: "乘车前往中尼边境吉隆口岸（约6-8小时），入境中国后乘车至吉隆镇。海拔从1400m升至2700m，第一级适应。", descEn: "Drive to Gyirong border port (6-8 hours). Cross into China, drive to Gyirong Town. Altitude rises from 1400m to 2700m — first stage of adaptation." },
      { day: 3, title: "吉隆镇→定日（4300m）", titleEn: "Gyirong→Tingri (4300m)", desc: "穿越喜马拉雅山脉北坡，途经佩枯错和希夏邦马峰。车程约5-6小时，风景从亚热带峡谷变为高寒荒漠。", descEn: "Cross the northern Himalayan slopes, pass Pekutso Lake and Shishapangma. ~5-6 hours driving. Landscape transforms from subtropical gorges to alpine desert." },
      { day: 4, title: "定日→珠峰大本营→定日", titleEn: "Tingri→EBC→Tingri", desc: "前往珠峰大本营（5200m）参观后返回定日住宿。避免在5200m过夜，这是高原适应的黄金法则。", descEn: "Visit Everest Base Camp (5200m), return to Tingri to sleep. Avoid overnighting at 5200m — a golden rule of altitude adaptation." },
      { day: 5, title: "定日→萨嘎（4500m）", titleEn: "Tingri→Saga (4500m)", desc: "沿G219向西，车程约6小时。萨嘎是前往阿里的最后一个较大补给城镇，建议在此补充物资。", descEn: "Westward on G219, ~6 hours. Saga is the last large supply town before Ngari. Restock provisions here." },
      { day: 6, title: "萨嘎→塔尔钦", titleEn: "Saga→Darchen", desc: "最后一段车程。途经帕羊、霍尔乡，在玛旁雍错湖畔停留致敬神湖，傍晚抵达塔尔钦。", descEn: "Final drive. Pass Paryang and Hor, stop to pay respects at Lake Manasarovar, arrive Darchen by evening." },
      { day: 7, title: "转山准备日", titleEn: "Kora preparation day", desc: "在塔尔钦休整一天，办理转山登记，雇佣背夫或马匹，做最后的身体和心理准备。可绕塔尔钦小镇散步，感受神山脚下的特殊能量。", descEn: "Rest day in Darchen. Register for the kora, hire porters or horses, make final physical and mental preparations. Walk around Darchen to feel the special energy at the mountain's foot." }
    ]
  }
];
---

<Layout title="朝圣攻略 - 冈仁波齐转山指南 | Kailash 2026" description="最详尽的冈仁波齐转山攻略：最佳时间、装备清单、高原反应预防、边防证办理。52公里转山路线全程指南。">
  <!-- Hero: Photo on top, content below -->
  <section class="relative bg-kailash-dark">
    <!-- Full-width photo - moderate height -->
    <div class="relative w-full h-[45vh] lg:h-[55vh]">
      <div class="absolute inset-0 bg-[url('/images/kailash-aerial.webp')] bg-cover bg-top"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-kailash-dark/30 to-kailash-dark"></div>
    </div>

    <!-- Content below photo -->
    <div class="relative -mt-12 z-10 px-4 sm:px-6 lg:px-8 pb-8">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="font-display text-4xl md:text-5xl font-bold text-white mb-3" data-lang-content="zh">
          朝圣攻略
        </h1>
        <h1 class="font-display text-4xl md:text-5xl font-bold text-white mb-3" data-lang-content="en" style="display: none;">
          Pilgrimage Guide
        </h1>
        <p class="text-lg md:text-xl text-white/60 max-w-2xl mx-auto" data-lang-content="zh">
          从准备到出发，一份详尽的冈仁波齐转山指南
        </p>
        <p class="text-lg md:text-xl text-white/60 max-w-2xl mx-auto" data-lang-content="en" style="display: none;">
          A comprehensive guide to Mount Kailash Kora, from preparation to departure
        </p>
      </div>
    </div>
  </section>

  <!-- Four Meanings of Kora -->
<section class="py-20 bg-kailash-dark text-white">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="font-display text-4xl font-bold mb-4" data-lang-content="zh">转山的四重意义</h2>
      <h2 class="font-display text-4xl font-bold mb-4" data-lang-content="en" style="display: none;">Four Meanings of Kora</h2>
      <p class="text-gray-400" data-lang-content="zh">每一步都是修行，每一圈都是新生</p>
      <p class="text-gray-400" data-lang-content="en" style="display: none;">Every step is practice, every circle is rebirth</p>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      <!-- 1. Physical Pilgrimage -->
      <div class="bg-white/5 rounded-xl p-8 hover:bg-white/10 transition">
        <div class="flex items-center gap-4 mb-4">
          <span class="text-4xl">🚶</span>
          <h3 class="font-display text-2xl font-bold" data-lang-content="zh">身体的朝圣</h3>
          <h3 class="font-display text-2xl font-bold" data-lang-content="en" style="display: none;">Physical Pilgrimage</h3>
        </div>
        <p class="text-gray-300 leading-relaxed" data-lang-content="zh">
          52公里的山路，是对身体的极限挑战。从海拔4560米的塔尔钦出发，翻越5648米的卓玛拉垭口，每一步都在与高反、寒冷、疲惫对抗。这不是简单的徒步，而是用身体丈量信仰的距离。当双腿酸痛、呼吸急促时，你才真切感受到：原来信仰需要如此真实的付出。
        </p>
        <p class="text-gray-300 leading-relaxed" data-lang-content="en" style="display: none;">
          52 kilometers of mountain trails—a physical challenge. Starting from Darchen at 4,560m, crossing Drolma La at 5,648m. Every step battles altitude sickness, cold, and exhaustion. This is not mere trekking; it is measuring faith with your body.
        </p>
      </div>

      <!-- 2. Spiritual Pilgrimage -->
      <div class="bg-white/5 rounded-xl p-8 hover:bg-white/10 transition">
        <div class="flex items-center gap-4 mb-4">
          <span class="text-4xl">🙏</span>
          <h3 class="font-display text-2xl font-bold" data-lang-content="zh">心灵的朝圣</h3>
          <h3 class="font-display text-2xl font-bold" data-lang-content="en" style="display: none;">Spiritual Pilgrimage</h3>
        </div>
        <p class="text-gray-300 leading-relaxed" data-lang-content="zh">
          远离城市的喧嚣，放下工作邮件，暂时告别社交媒体的纷扰。三天两夜，只有你、神山和内心的声音。在止热寺仰望冈仁波齐北壁的星空，在卓玛拉垭口感受经幡在风中诵念真言——这些时刻，你会遇见最真实的自己。转山不是逃避，而是一次深度的自我对话。沿途虽有手机信号，但不妨主动选择"数字断联"，让心灵真正沉淀。
        </p>
        <p class="text-gray-300 leading-relaxed" data-lang-content="en" style="display: none;">
          Away from urban noise—put aside work emails and social media. Three days and two nights, just you, the sacred mountain, and your inner voice. Gazing at starlit Kailash from Drirapuk, feeling prayer flags chant mantras in the wind at Drolma La—these moments reveal your truest self. Kora is not escape; it is deep self-dialogue. Though mobile signal is now available along the route, consider choosing a "digital detox" to let your mind truly settle.
        </p>
      </div>

      <!-- 3. Cultural Pilgrimage -->
      <div class="bg-white/5 rounded-xl p-8 hover:bg-white/10 transition">
        <div class="flex items-center gap-4 mb-4">
          <span class="text-4xl">📿</span>
          <h3 class="font-display text-2xl font-bold" data-lang-content="zh">文化的朝圣</h3>
          <h3 class="font-display text-2xl font-bold" data-lang-content="en" style="display: none;">Cultural Pilgrimage</h3>
        </div>
        <p class="text-gray-300 leading-relaxed" data-lang-content="zh">
          冈仁波齐是藏传佛教、印度教、耆那教、苯教四大宗教的共同圣地。你会遇到磕长头的藏族信徒、吟诵梵文的印度苦行僧、静默行走的西方修行者。没有宗教的界限，只有共同的敬畏。在这里，你会理解什么是"和而不同"，什么是人类对神圣的永恒追寻。
        </p>
        <p class="text-gray-300 leading-relaxed" data-lang-content="en" style="display: none;">
          Kailash is sacred to four religions: Tibetan Buddhism, Hinduism, Jainism, and Bon. You will meet Tibetan prostrating pilgrims, Hindu chanting ascetics, and silent Western practitioners. No religious boundaries—only shared reverence. Here you understand "harmony in diversity" and humanity's eternal quest for the sacred.
        </p>
      </div>

      <!-- 4. Natural Pilgrimage -->
      <div class="bg-white/5 rounded-xl p-8 hover:bg-white/10 transition">
        <div class="flex items-center gap-4 mb-4">
          <span class="text-4xl">🏔️</span>
          <h3 class="font-display text-2xl font-bold" data-lang-content="zh">自然的朝圣</h3>
          <h3 class="font-display text-2xl font-bold" data-lang-content="en" style="display: none;">Natural Pilgrimage</h3>
        </div>
        <p class="text-gray-300 leading-relaxed" data-lang-content="zh">
          冈仁波齐是地球上最壮观的地质奇观之一。金字塔形的峰顶、对称的四壁、终年不化的积雪——这是大自然亿万年雕琢的神迹。转山途中，你会经过冰川、湖泊、峡谷、草原，见证藏羚羊、野驴、高原鼠兔的自由生息。在这里，人类只是过客，自然才是永恒的主人。
        </p>
        <p class="text-gray-300 leading-relaxed" data-lang-content="en" style="display: none;">
          Kailash is one of Earth's most spectacular geological wonders. Its pyramid peak, symmetrical walls, and eternal snow are nature's divine sculpture over millions of years. Along the kora: glaciers, lakes, canyons, grasslands, and free-roaming Tibetan antelopes and wild donkeys. Here, humans are merely visitors; nature is the eternal master.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Best Time -->
  <section class="py-20 bg-kailash-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="font-display text-4xl font-bold text-kailash-dark mb-6" data-lang-content="zh">最佳时间</h2>
          <h2 class="font-display text-4xl font-bold text-kailash-dark mb-6" data-lang-content="en" style="display: none;">Best Time to Go</h2>
          <div class="space-y-6">
            <div class="bg-white rounded-xl p-6 shadow-md">
              <div class="flex items-center gap-3 mb-2">
                <span class="text-2xl">🌸</span>
                <h3 class="font-semibold text-lg" data-lang-content="zh">开放季节</h3>
                <h3 class="font-semibold text-lg" data-lang-content="en" style="display: none;">Open Season</h3>
              </div>
              <p class="text-kailash-gold font-bold text-xl" data-lang-content="zh">{bestTime.season}</p>
              <p class="text-kailash-gold font-bold text-xl" data-lang-content="en" style="display: none;">{bestTime.seasonEn}</p>
              <p class="text-gray-600 mt-2" data-lang-content="zh">每年冬季（11月-次年3月）大雪封山，转山道关闭。2026年为马年，如天气条件允许可能提前至3月下旬开放，但4月中旬更为稳妥。</p>
              <p class="text-gray-600 mt-2" data-lang-content="en" style="display: none;">Winter closure Nov–Mar due to heavy snow. For the 2026 Horse Year, the trail may open as early as late March if weather permits, but mid-April is more reliable.</p>
            </div>
            <div class="bg-white rounded-xl p-6 shadow-md">
              <div class="flex items-center gap-3 mb-2">
                <span class="text-2xl">⭐</span>
                <h3 class="font-semibold text-lg" data-lang-content="zh">最佳月份</h3>
                <h3 class="font-semibold text-lg" data-lang-content="en" style="display: none;">Peak Months</h3>
              </div>
              <p class="text-kailash-gold font-bold text-xl" data-lang-content="zh">{bestTime.peak}</p>
              <p class="text-kailash-gold font-bold text-xl" data-lang-content="en" style="display: none;">{bestTime.peakEn}</p>
              <p class="text-gray-600 mt-2" data-lang-content="zh">天气稳定，能见度高，转山体验最佳。5月日照充足，9-10月秋高气爽，是最理想的转山窗口。</p>
              <p class="text-gray-600 mt-2" data-lang-content="en" style="display: none;">Stable weather, great visibility—ideal for trekking. May offers abundant sunshine; Sep-Oct brings crisp autumn air, the two best windows for kora.</p>
            </div>
            <div class="bg-amber-50 border border-amber-200 rounded-xl p-6">
              <div class="flex items-center gap-3 mb-2">
                <span class="text-2xl">⚠️</span>
                <h3 class="font-semibold text-lg" data-lang-content="zh">注意事项</h3>
                <h3 class="font-semibold text-lg" data-lang-content="en" style="display: none;">Notes</h3>
              </div>
              <p class="text-gray-700" data-lang-content="zh">{bestTime.notes}</p>
              <p class="text-gray-700" data-lang-content="en" style="display: none;">{bestTime.notesEn}</p>
            </div>
          </div>
        </div>
        <div class="bg-white rounded-2xl p-8 shadow-lg">
          <h3 class="font-display text-xl font-bold mb-6" data-lang-content="zh">月度天气详情</h3>
          <h3 class="font-display text-xl font-bold mb-6" data-lang-content="en" style="display: none;">Monthly Weather Details</h3>
          <div class="space-y-4">
            {monthlyDetail.map(m => (
              <div class="border-b border-gray-100 pb-4 last:border-0 last:pb-0">
                <div class="flex justify-between items-center mb-2">
                  <span class="font-semibold text-kailash-dark" data-lang-content="zh">{m.month}</span>
                  <span class="font-semibold text-kailash-dark" data-lang-content="en" style="display: none;">{m.monthEn}</span>
                  <span class="text-kailash-gold font-medium">{m.temp}</span>
                </div>
                <p class="text-sm text-gray-500 mb-1" data-lang-content="zh">天气：{m.weather}</p>
                <p class="text-sm text-gray-500 mb-1" data-lang-content="en" style="display: none;">Weather: {m.weatherEn}</p>
                <div class="grid grid-cols-2 gap-2 mt-2">
                  <div class="bg-green-50 rounded-lg px-3 py-2">
                    <span class="text-xs text-green-600 font-medium" data-lang-content="zh">✅ {m.pro}</span>
                    <span class="text-xs text-green-600 font-medium" data-lang-content="en" style="display: none;">✅ {m.proEn}</span>
                  </div>
                  <div class="bg-red-50 rounded-lg px-3 py-2">
                    <span class="text-xs text-red-600 font-medium" data-lang-content="zh">⚠️ {m.con}</span>
                    <span class="text-xs text-red-600 font-medium" data-lang-content="en" style="display: none;">⚠️ {m.conEn}</span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Equipment -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4" data-lang-content="zh">装备清单</h2>
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4" data-lang-content="en" style="display: none;">Equipment Checklist</h2>
        <p class="text-lg text-gray-600" data-lang-content="zh">充分准备，才能应对高原的严酷环境</p>
        <p class="text-lg text-gray-600" data-lang-content="en" style="display: none;">Be fully prepared for the harsh high-altitude environment</p>
      </div>

      <div class="grid lg:grid-cols-3 gap-8 mb-12">
        <!-- Required -->
        <div class="bg-red-50 rounded-2xl p-8">
          <div class="flex items-center gap-3 mb-6">
            <span class="bg-red-500 text-white w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold" data-lang-content="zh">必</span>
            <span class="bg-red-500 text-white w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold" data-lang-content="en" style="display: none;">R</span>
            <h3 class="font-display text-xl font-bold" data-lang-content="zh">必备装备</h3>
            <h3 class="font-display text-xl font-bold" data-lang-content="en" style="display: none;">Required</h3>
          </div>
          <ul class="space-y-4">
            {equipment.required.map(item => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-red-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <div>
                  <p class="font-medium" data-lang-content="zh">{item.item}</p>
                  <p class="font-medium" data-lang-content="en" style="display: none;">{item.itemEn}</p>
                  <p class="text-sm text-gray-600" data-lang-content="zh">{item.desc}</p>
                  <p class="text-sm text-gray-600" data-lang-content="en" style="display: none;">{item.descEn}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>

        <!-- Recommended -->
        <div class="bg-blue-50 rounded-2xl p-8">
          <div class="flex items-center gap-3 mb-6">
            <span class="bg-blue-500 text-white w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold" data-lang-content="zh">荐</span>
            <span class="bg-blue-500 text-white w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold" data-lang-content="en" style="display: none;">R</span>
            <h3 class="font-display text-xl font-bold" data-lang-content="zh">推荐装备</h3>
            <h3 class="font-display text-xl font-bold" data-lang-content="en" style="display: none;">Recommended</h3>
          </div>
          <ul class="space-y-4">
            {equipment.recommended.map(item => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-blue-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <div>
                  <p class="font-medium" data-lang-content="zh">{item.item}</p>
                  <p class="font-medium" data-lang-content="en" style="display: none;">{item.itemEn}</p>
                  <p class="text-sm text-gray-600" data-lang-content="zh">{item.desc}</p>
                  <p class="text-sm text-gray-600" data-lang-content="en" style="display: none;">{item.descEn}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>

        <!-- Provided -->
        <div class="bg-green-50 rounded-2xl p-8">
          <div class="flex items-center gap-3 mb-6">
            <span class="bg-green-500 text-white w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold" data-lang-content="zh">团</span>
            <span class="bg-green-500 text-white w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold" data-lang-content="en" style="display: none;">T</span>
            <h3 class="font-display text-xl font-bold" data-lang-content="zh">团队提供</h3>
            <h3 class="font-display text-xl font-bold" data-lang-content="en" style="display: none;">Team Provided</h3>
          </div>

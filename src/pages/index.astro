---
import Layout from '../layouts/Layout.astro';
import SearchBox from '../components/SearchBox.astro';
import Newsletter from '../components/Newsletter.astro';
import { getCollection } from 'astro:content';

const latestPosts = (await getCollection('blog', ({ data }) => data.lang === 'zh'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<Layout title="冈仁波齐2026 - 全球朝圣者平台 | 神山冈仁波齐" description="冈仁波齐2026：连接全球朝圣者的平台。藏传佛教、印度教、苯教、耆那教共同的圣地。转山路线、朝圣攻略、神山文化。">
  
  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-[url('/images/kailash-hero-mobile.webp')] bg-cover bg-center md:bg-[url('/images/kailash-hero.webp')]"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-kailash-dark/60 via-kailash-dark/40 to-kailash-dark"></div>
    
    <div class="relative z-10 text-center px-4 max-w-5xl mx-auto">
      <!-- 中文 -->
      <div data-lang-content="zh">
        <p class="text-kailash-gold text-sm md:text-base tracking-[0.3em] uppercase mb-4 font-light">🐎 2026 藏历马年 · 十二年一遇</p>
        <h1 class="font-display text-5xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">冈仁波齐<span class="block text-kailash-gold mt-2">2026</span></h1>
        <p class="text-xl md:text-2xl text-white/80 mb-4 max-w-3xl mx-auto font-light leading-relaxed">四大宗教共同的圣地 — 专业朝圣团、深度攻略、权威指南</p>
        <p class="text-lg text-white/60 mb-8">藏传佛教 · 印度教 · 苯教 · 耆那教</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/packages" class="bg-kailash-gold text-kailash-dark px-10 py-5 rounded-xl font-bold text-lg hover:bg-kailash-accent transition shadow-lg shadow-kailash-gold/25">🐎 2026 朝圣团</a>
          <a href="/guide" class="border-2 border-white/30 text-white px-8 py-4 rounded-lg font-semibold hover:bg-white/10 transition">朝圣攻略</a>
        </div>
      </div>

      <!-- English -->
      <div data-lang-content="en" style="display: none;">
        <p class="text-kailash-gold text-sm md:text-base tracking-[0.3em] uppercase mb-4 font-light">🐎 2026 Horse Year · Once Every 12 Years</p>
        <h1 class="font-display text-5xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">Mount Kailash<span class="block text-kailash-gold mt-2">2026</span></h1>
        <p class="text-xl md:text-2xl text-white/80 mb-4 max-w-3xl mx-auto font-light leading-relaxed">Sacred to Four Religions — Guided Tours, Expert Guides, Premium Resources</p>
        <p class="text-lg text-white/60 mb-8">Tibetan Buddhism · Hinduism · Bön · Jainism</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/packages" class="bg-kailash-gold text-kailash-dark px-10 py-5 rounded-xl font-bold text-lg hover:bg-kailash-accent transition shadow-lg shadow-kailash-gold/25">🐎 2026 Pilgrimage Tours</a>
          <a href="/guide" class="border-2 border-white/30 text-white px-8 py-4 rounded-lg font-semibold hover:bg-white/10 transition">Pilgrim Guide</a>
        </div>
      </div>
      
      
      
      
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="bg-kailash-dark py-8 border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- 中文 -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center" data-lang-content="zh">
        <div><p class="text-3xl md:text-4xl font-bold text-kailash-gold">6656m</p><p class="text-white/60 text-sm mt-1">冈仁波齐海拔</p></div>
        <div><p class="text-3xl md:text-4xl font-bold text-kailash-gold">52km</p><p class="text-white/60 text-sm mt-1">转山全程</p></div>
        <div><p class="text-3xl md:text-4xl font-bold text-kailash-gold">5630m</p><p class="text-white/60 text-sm mt-1">最高垭口</p></div>
        <div><p class="text-3xl md:text-4xl font-bold text-kailash-gold">4</p><p class="text-white/60 text-sm mt-1">宗教圣地</p></div>
      </div>
      <!-- English -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center" data-lang-content="en" style="display: none;">
        <div><p class="text-3xl md:text-4xl font-bold text-kailash-gold">6,656m</p><p class="text-white/60 text-sm mt-1">Peak Elevation</p></div>
        <div><p class="text-3xl md:text-4xl font-bold text-kailash-gold">52km</p><p class="text-white/60 text-sm mt-1">Kora Distance</p></div>
        <div><p class="text-3xl md:text-4xl font-bold text-kailash-gold">5,630m</p><p class="text-white/60 text-sm mt-1">Highest Pass</p></div>
        <div><p class="text-3xl md:text-4xl font-bold text-kailash-gold">4</p><p class="text-white/60 text-sm mt-1">Sacred Traditions</p></div>
      </div>
      
    </div>
  </section>

  <!-- 2026 Horse Year Tour CTA -->
  <section class="py-16 bg-white border-b border-gray-100">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-gradient-to-r from-kailash-dark to-kailash-stone rounded-3xl p-8 md:p-12 shadow-xl">
        <div class="flex flex-col lg:flex-row items-center gap-8">
          <div class="flex-1 text-center lg:text-left">
            <span class="inline-block bg-kailash-gold/20 text-kailash-gold text-sm font-bold px-4 py-1.5 rounded-full mb-4">
              <span data-lang-content="zh">🐎 2026 藏历马年 · 十二年一遇</span>
              <span data-lang-content="en" style="display: none;">🐎 2026 Horse Year · Once Every 12 Years</span>
            </span>
            <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">
              <span data-lang-content="zh">冈仁波齐转山朝圣团</span>
              <span data-lang-content="en" style="display: none;">Kailash Kora Pilgrimage Tours</span>
            </h2>
            <p class="text-white/70 text-lg mb-2 leading-relaxed">
              <span data-lang-content="zh">8-12天深度体验 · 专业向导带队 · 三档套餐 ¥8,800 起</span>
              <span data-lang-content="en" style="display: none;">8-12 Day Immersion · Expert Guides · From $1,299</span>
            </p>
            <p class="text-white/50 text-sm">
              <span data-lang-content="zh">马年转山一圈 = 13圈功德。每月发团，名额有限。</span>
              <span data-lang-content="en" style="display: none;">One Horse Year kora = 13 circuits of merit. Monthly departures, limited spots.</span>
            </p>
          </div>
          <div class="flex-shrink-0 flex flex-col sm:flex-row gap-4">
            <a href="/packages" class="bg-kailash-gold text-kailash-dark px-8 py-4 rounded-xl font-bold text-lg hover:bg-kailash-accent transition shadow-lg shadow-kailash-gold/25 whitespace-nowrap text-center">
              <span data-lang-content="zh">查看详情 & 预订</span>
              <span data-lang-content="en" style="display: none;">View & Book</span>
            </a>
            <a href="/guide" class="border-2 border-white/30 text-white px-8 py-4 rounded-xl font-semibold text-lg hover:bg-white/10 transition whitespace-nowrap text-center">
              <span data-lang-content="zh">先看攻略</span>
              <span data-lang-content="en" style="display: none;">Read Guide</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-20 bg-kailash-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- 中文 -->
      <div class="text-center mb-16" data-lang-content="zh">
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4">为什么选择冈仁波齐</h2>
        <p class="text-lg text-gray-600">世界中心，信仰之巅</p>
      </div>
      <!-- English -->
      <div class="text-center mb-16" data-lang-content="en" style="display: none;">
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4">Why Kailash?</h2>
        <p class="text-lg text-gray-600">Center of the World, Pinnacle of Faith</p>
      </div>
      
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Feature 1: Four Religions -->
        <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-xl transition">
          <div class="text-4xl mb-4">🕉️</div>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="zh">四大宗教圣地</h3>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="en" style="display: none;">Four Sacred Traditions</h3>
          <p class="text-gray-600" data-lang-content="zh">藏传佛教、印度教、苯教、耆那教共同尊奉的世界中心，全球唯一被四大宗教同时视为圣地的山峰</p>
          <p class="text-gray-600" data-lang-content="en" style="display: none;">Tibetan Buddhism, Hinduism, Bön, and Jainism all revere this as the center of the world. The only mountain sacred to all four religions simultaneously.</p>
        </div>
        
        <!-- Feature 2: 6656m -->
        <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-xl transition">
          <div class="text-4xl mb-4">🏔️</div>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="zh">6656米神山</h3>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="en" style="display: none;">6,656m Sacred Peak</h3>
          <p class="text-gray-600" data-lang-content="zh">从未被攀登的圣洁之峰，金字塔形山体独一无二，南坡万字符印记神秘庄严</p>
          <p class="text-gray-600" data-lang-content="en" style="display: none;">An unclimbed sacred summit with a unique pyramid shape. The mysterious swastika mark on its southern face radiates solemn divinity.</p>
        </div>
        
        <!-- Feature 3: 52km -->
        <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-xl transition">
          <div class="text-4xl mb-4">🚶</div>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="zh">52公里转山</h3>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="en" style="display: none;">52km Kora Circuit</h3>
          <p class="text-gray-600" data-lang-content="zh">三天两夜高原徒步，翻越5630米卓玛拉垭口，每转一圈相当于念诵六字真言六亿遍</p>
          <p class="text-gray-600" data-lang-content="en" style="display: none;">A three-day high-altitude trek crossing the 5,630m Drolma La pass. One circuit equals 600 million recitations of the six-syllable mantra.</p>
        </div>
        
        <!-- Feature 4: Lake -->
        <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-xl transition">
          <div class="text-4xl mb-4">💧</div>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="zh">圣湖玛旁雍错</h3>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="en" style="display: none;">Lake Manasarovar</h3>
          <p class="text-gray-600" data-lang-content="zh">世界上海拔最高的淡水湖之一，四大河流的发源地，被称为「西天瑶池」</p>
          <p class="text-gray-600" data-lang-content="en" style="display: none;">One of the world's highest freshwater lakes, source of four great rivers. Known as the "Western Heaven Jade Pool."</p>
        </div>
        
        <!-- Feature 5: Global -->
        <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-xl transition">
          <div class="text-4xl mb-4">🌏</div>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="zh">全球朝圣者</h3>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="en" style="display: none;">Global Pilgrims</h3>
          <p class="text-gray-600" data-lang-content="zh">每年数十万朝圣者来自印度、尼泊尔、中国及世界各地，不同信仰者在此平等朝拜</p>
          <p class="text-gray-600" data-lang-content="en" style="display: none;">Hundreds of thousands of pilgrims gather annually from India, Nepal, China, and across the globe. Different faiths worship here as equals.</p>
        </div>
        
        <!-- Feature 6: 2026 -->
        <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-xl transition">
          <div class="text-4xl mb-4">📅</div>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="zh">2026朝圣之旅</h3>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="en" style="display: none;">2026 Pilgrimage</h3>
          <p class="text-gray-600" data-lang-content="zh">精心的行程规划与专业团队支持，为您的神圣朝圣之旅保驾护航</p>
          <p class="text-gray-600" data-lang-content="en" style="display: none;">Carefully planned itinerary with professional team support for your sacred pilgrimage journey.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Route Preview -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- 中文 -->
      <div class="text-center mb-16" data-lang-content="zh">
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4">52公里转山路线</h2>
        <p class="text-lg text-gray-600">三天两夜的高原徒步，从塔尔钦出发，翻越5630米的卓玛拉垭口，最终回到起点</p>
      </div>
      <!-- English -->
      <div class="text-center mb-16" data-lang-content="en" style="display: none;">
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4">52km Kora Route</h2>
        <p class="text-lg text-gray-600">A three-day high-altitude trek starting from Darchen, crossing the 5,630m Drolma La pass</p>
      </div>
      
      
      <div class="grid md:grid-cols-3 gap-8">
        <!-- Day 1 -->
        <div class="bg-kailash-light rounded-2xl p-8">
          <div class="text-kailash-gold text-4xl font-bold mb-4">1</div>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="zh">第一天：塔尔钦 → 止热寺（20km）</h3>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="en" style="display: none;">Day 1: Darchen → Drirapuk (20km)</h3>
          <p class="text-gray-600" data-lang-content="zh">平缓起步，适应海拔，沿途可见神山北壁</p>
          <p class="text-gray-600" data-lang-content="en" style="display: none;">Gentle start, acclimatizing to altitude, viewing the north face</p>
        </div>
        
        <!-- Day 2 -->
        <div class="bg-kailash-light rounded-2xl p-8">
          <div class="text-kailash-gold text-4xl font-bold mb-4">2</div>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="zh">第二天：止热寺 → 尊珠寺（18km）</h3>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="en" style="display: none;">Day 2: Drirapuk → Zongchu (18km)</h3>
          <p class="text-gray-600" data-lang-content="zh">翻越卓玛拉垭口，最具挑战的一天</p>
          <p class="text-gray-600" data-lang-content="en" style="display: none;">Crossing Drolma La pass, the most challenging day</p>
        </div>
        
        <!-- Day 3 -->
        <div class="bg-kailash-light rounded-2xl p-8">
          <div class="text-kailash-gold text-4xl font-bold mb-4">3</div>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="zh">第三天：尊珠寺 → 塔尔钦（14km）</h3>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="en" style="display: none;">Day 3: Zongchu → Darchen (14km)</h3>
          <p class="text-gray-600" data-lang-content="zh">轻松返程，完成神圣的转山之旅</p>
          <p class="text-gray-600" data-lang-content="en" style="display: none;">Easy return, completing the sacred kora</p>
        </div>
      </div>
      
      <div class="text-center mt-12">
        <a href="/routes" class="inline-flex items-center bg-kailash-gold text-kailash-dark px-8 py-3 rounded-lg font-semibold hover:bg-kailash-accent transition">
          <span data-lang-content="zh">查看详细路线</span>
          <span data-lang-content="en" style="display: none;">View Detailed Route</span>
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-20 bg-kailash-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-2" data-lang-content="zh">朝圣者心声</h2>
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-2" data-lang-content="en" style="display: none;">Pilgrim Voices</h2>
        <p class="text-lg text-gray-600" data-lang-content="zh">来自世界各地的转山者分享他们的真实体验</p>
        <p class="text-lg text-gray-600" data-lang-content="en" style="display: none;">Real experiences from pilgrims around the world</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Testimonial 1 -->
        <div class="bg-white rounded-2xl p-8 shadow-md">
          <div class="text-kailash-gold mb-4">★★★★★</div>
          <p class="text-gray-700 mb-6 italic" data-lang-content="zh">"当翻越卓玛拉垭口的那一刻，我终于明白什么是信仰的力量。5630米，这是我人生到达的最高点，也是心灵的最高点。"</p>
          <p class="text-gray-700 mb-6 italic" data-lang-content="en" style="display: none;">"The moment I crossed Drolma La pass, I finally understood the power of faith. At 5,630 meters, this is the highest point of my life, and also the highest point of my soul."</p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-kailash-gold/20 rounded-full flex items-center justify-center font-bold">张</div>
            <div>
              <p class="font-medium" data-lang-content="zh">张先生</p>
              <p class="font-medium" data-lang-content="en" style="display: none;">Mr. Zhang</p>
              <p class="text-sm text-gray-500">北京 · 2025年9月</p>
            </div>
          </div>
        </div>

        <!-- Testimonial 2 -->
        <div class="bg-white rounded-2xl p-8 shadow-md">
          <div class="text-kailash-gold mb-4">★★★★★</div>
          <p class="text-gray-700 mb-6 italic" data-lang-content="zh">"带着70岁的母亲完成转山，她在止热寺前双手合十的样子，是我这辈子见过最美的画面。朝圣无关年龄，只关乎心愿。"</p>
          <p class="text-gray-700 mb-6 italic" data-lang-content="en" style="display: none;">"I completed the kora with my 70-year-old mother. Watching her pray at Drirapuk Monastery was the most beautiful sight I've ever seen. Pilgrimage knows no age—it only requires a sincere heart."</p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-kailash-gold/20 rounded-full flex items-center justify-center font-bold">李</div>
            <div>
              <p class="font-medium" data-lang-content="zh">李女士</p>
              <p class="font-medium" data-lang-content="en" style="display: none;">Ms. Li</p>
              <p class="text-sm text-gray-500">成都 · 2025年6月</p>
            </div>
          </div>
        </div>

        <!-- Testimonial 3 -->
        <div class="bg-white rounded-2xl p-8 shadow-md">
          <div class="text-kailash-gold mb-4">★★★★★</div>
          <p class="text-gray-700 mb-6 italic">"Kailash is the abode of Lord Shiva. I waited 3 years for the permit. The 52km kora changed my perspective on life forever."</p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-kailash-gold/20 rounded-full flex items-center justify-center font-bold">R</div>
            <div>
              <p class="font-medium">Rajesh Kumar</p>
              <p class="text-sm text-gray-500">Delhi, India · 2024</p>
            </div>
          </div>
        </div>
      </div>

      <div class="text-center mt-12">
        <a href="/stories" class="inline-flex items-center text-kailash-gold font-semibold hover:text-kailash-dark transition">
          <span data-lang-content="zh">查看更多朝圣故事</span>
          <span data-lang-content="en" style="display: none;">Read More Stories</span>
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Search Section -->
  <section class="py-20 bg-kailash-gold">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-3xl font-bold text-kailash-dark mb-4">
        <span data-lang-content="zh">搜索冈仁波齐</span>
        <span data-lang-content="en" style="display: none;">Search Kailash</span>

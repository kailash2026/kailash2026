---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import RoutePreview from '../components/RoutePreview.astro';
import BookingCTA from '../components/BookingCTA.astro';
---

<Layout title="Kailash 2026 - Global Pilgrimage Platform | Mount Kailash Sacred Mountain for All Pilgrims" description="Kailash 2026: The global pilgrimage platform connecting pilgrims worldwide. Mount Kailash - sacred to Hinduism, Tibetan Buddhism, Bön, and Jainism. Join pilgrims from India, Nepal, China, and around the world on this transformative journey.">
  <Hero />
  <!-- Stats Bar -->
  <section class="bg-kailash-dark py-8 border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center" data-lang-content="zh">
        <div>
          <p class="text-3xl md:text-4xl font-bold text-kailash-gold">6656m</p>
          <p class="text-white/60 text-sm mt-1">神山海拔</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold text-kailash-gold">52km</p>
          <p class="text-white/60 text-sm mt-1">转山全程</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold text-kailash-gold">5630m</p>
          <p class="text-white/60 text-sm mt-1">最高垭口</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold text-kailash-gold">4</p>
          <p class="text-white/60 text-sm mt-1">宗教圣地</p>
        </div>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center" data-lang-content="en" style="display: none;">
        <div>
          <p class="text-3xl md:text-4xl font-bold text-kailash-gold">6,656m</p>
          <p class="text-white/60 text-sm mt-1">Peak Elevation</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold text-kailash-gold">52km</p>
          <p class="text-white/60 text-sm mt-1">Kora Distance</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold text-kailash-gold">5,630m</p>
          <p class="text-white/60 text-sm mt-1">Highest Pass</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold text-kailash-gold">4</p>
          <p class="text-white/60 text-sm mt-1">Sacred Traditions</p>
        </div>
      </div>
    </div>
  </section>
  
  <Features />
  <RoutePreview />
  <!-- Testimonials Section -->
  <section class="py-20 bg-kailash-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-2" data-lang-content="zh">朝圣者心声</h2>
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-2" data-lang-content="en" style="display: none;">Pilgrim Voices</h2>
        <p class="text-lg text-gray-600" data-lang-content="zh">来自世界各地的转山者分享他们的真实体验</p>
        <p class="text-lg text-gray-600" data-lang-content="en" style="display: none;">Real experiences from pilgrims around the world</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Testimonial 1 -->
        <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-xl transition-shadow">
          <div class="flex items-center gap-1 mb-4">
            <span class="text-kailash-gold">★★★★★</span>
          </div>
          <p class="text-gray-700 mb-6 leading-relaxed italic">
            "当翻越卓玛拉垭口的那一刻，我终于明白什么是信仰的力量。5630米，这是我人生到达的最高点，也是心灵的最高点。"
          </p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-kailash-gold/20 rounded-full flex items-center justify-center text-kailash-dark font-bold">张</div>
            <div>
              <p class="font-medium text-kailash-dark">张先生</p>
              <p class="text-sm text-gray-500">北京 · 2025年9月</p>
            </div>
          </div>
        </div>

        <!-- Testimonial 2 -->
        <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-xl transition-shadow">
          <div class="flex items-center gap-1 mb-4">
            <span class="text-kailash-gold">★★★★★</span>
          </div>
          <p class="text-gray-700 mb-6 leading-relaxed italic">
            "带着70岁的母亲完成转山，她在止热寺前双手合十的样子，是我这辈子见过最美的画面。朝圣无关年龄，只关乎心愿。"
          </p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-kailash-gold/20 rounded-full flex items-center justify-center text-kailash-dark font-bold">李</div>
            <div>
              <p class="font-medium text-kailash-dark">李女士</p>
              <p class="text-sm text-gray-500">成都 · 2025年6月</p>
            </div>
          </div>
        </div>

        <!-- Testimonial 3 -->
        <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-xl transition-shadow">
          <div class="flex items-center gap-1 mb-4">
            <span class="text-kailash-gold">★★★★★</span>
          </div>
          <p class="text-gray-700 mb-6 leading-relaxed italic">
            "Kailash is the abode of Lord Shiva. I waited 3 years for the permit. The 52km kora changed my perspective on life forever."
          </p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-kailash-gold/20 rounded-full flex items-center justify-center text-kailash-dark font-bold">R</div>
            <div>
              <p class="font-medium text-kailash-dark">Rajesh Kumar</p>
              <p class="text-sm text-gray-500">Delhi, India · 2024</p>
            </div>
          </div>
        </div>
      </div>

      <div class="text-center mt-12">
        <a href="/stories" class="inline-flex items-center text-kailash-gold font-semibold hover:text-kailash-dark transition">
          <span data-lang-content="zh">查看更多朝圣故事</span>
          <span data-lang-content="en" style="display: none;">Read More Stories</span>
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Gallery Preview -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-2" data-lang-content="zh">神山影像</h2>
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-2" data-lang-content="en" style="display: none;">Sacred Mountain Gallery</h2>
        <p class="text-lg text-gray-600" data-lang-content="zh">用影像记录神圣的土地</p>
        <p class="text-lg text-gray-600" data-lang-content="en" style="display: none;">Capturing the sacred land through images</p>
      </div>

      <div class="grid md:grid-cols-3 gap-4">
        <div class="relative aspect-[4/3] rounded-xl overflow-hidden group">
          <img src="/images/kailash-golden.jpg" alt="日照金山" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity">
            <p class="absolute bottom-4 left-4 text-white font-medium">日照金山</p>
          </div>
        </div>
        <div class="relative aspect-[4/3] rounded-xl overflow-hidden group md:row-span-2">
          <img src="/images/kailash-aerial.jpg" alt="航拍神山" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity">
            <p class="absolute bottom-4 left-4 text-white font-medium">航拍神山</p>
          </div>
        </div>
        <div class="relative aspect-[4/3] rounded-xl overflow-hidden group">
          <img src="/images/kailash-lake.jpg" alt="玛旁雍错" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity">
            <p class="absolute bottom-4 left-4 text-white font-medium">圣湖玛旁雍错</p>
          </div>
        </div>
        <div class="relative aspect-[4/3] rounded-xl overflow-hidden group">
          <img src="/images/kailash-sunrise.jpg" alt="日出金顶" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity">
            <p class="absolute bottom-4 left-4 text-white font-medium">日出金顶</p>
          </div>
        </div>
        <div class="relative aspect-[4/3] rounded-xl overflow-hidden group">
          <img src="/images/kailash-yaks.jpg" alt="草原牦牛" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity">
            <p class="absolute bottom-4 left-4 text-white font-medium">草原牦牛</p>
          </div>
        </div>
      </div>

      <div class="text-center mt-12">
        <a href="/gallery" class="inline-flex items-center bg-kailash-gold text-kailash-dark px-8 py-3 rounded-lg font-semibold hover:bg-kailash-accent transition">
          <span data-lang-content="zh">浏览完整图库</span>
          <span data-lang-content="en" style="display: none;">View Full Gallery</span>
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Quick Links / Trust Badges -->
  <section class="py-16 bg-kailash-light border-t border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div class="flex flex-col items-center">
          <div class="w-12 h-12 bg-kailash-gold/20 rounded-full flex items-center justify-center mb-3">
            <svg class="w-6 h-6 text-kailash-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <p class="font-medium text-kailash-dark" data-lang-content="zh">专业向导团队</p>
          <p class="font-medium text-kailash-dark" data-lang-content="en" style="display: none;">Professional Guides</p>
          <p class="text-sm text-gray-500" data-lang-content="zh">10年+高原经验</p>
          <p class="text-sm text-gray-500" data-lang-content="en" style="display: none;">10+ years high-altitude experience</p>
        </div>
        <div class="flex flex-col items-center">
          <div class="w-12 h-12 bg-kailash-gold/20 rounded-full flex items-center justify-center mb-3">
            <svg class="w-6 h-6 text-kailash-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
          </div>
          <p class="font-medium text-kailash-dark" data-lang-content="zh">医疗保障完善</p>
          <p class="font-medium text-kailash-dark" data-lang-content="en" style="display: none;">Medical Support</p>
          <p class="text-sm text-gray-500" data-lang-content="zh">氧气+药品+救援</p>
          <p class="text-sm text-gray-500" data-lang-content="en" style="display: none;">Oxygen + Meds + Rescue</p>
        </div>
        <div class="flex flex-col items-center">
          <div class="w-12 h-12 bg-kailash-gold/20 rounded-full flex items-center justify-center mb-3">
            <svg class="w-6 h-6 text-kailash-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <p class="font-medium text-kailash-dark" data-lang-content="zh">跨宗教中立</p>
          <p class="font-medium text-kailash-dark" data-lang-content="en" style="display: none;">Interfaith Neutral</p>
          <p class="text-sm text-gray-500" data-lang-content="zh">尊重所有信仰传统</p>
          <p class="text-sm text-gray-500" data-lang-content="en" style="display: none;">Respecting all traditions</p>
        </div>
        <div class="flex flex-col items-center">
          <div class="w-12 h-12 bg-kailash-gold/20 rounded-full flex items-center justify-center mb-3">
            <svg class="w-6 h-6 text-kailash-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <p class="font-medium text-kailash-dark" data-lang-content="zh">24小时响应</p>
          <p class="font-medium text-kailash-dark" data-lang-content="en" style="display: none;">24/7 Support</p>
          <p class="text-sm text-gray-500" data-lang-content="zh">全程客服在线</p>
          <p class="text-sm text-gray-500" data-lang-content="en" style="display: none;">Always here to help</p>
        </div>
      </div>
    </div>
  </section>

  <BookingCTA />
</Layout>
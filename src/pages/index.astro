          <span data-lang-content="en" style="display: none;">In-depth guides on Kailash religion, routes, and pilgrimage stories</span>
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {latestPosts.map((post) => {
          const slugParts = post.id.split('/');
          const cleanSlug = slugParts.length > 1 ? slugParts.slice(1).join('/').replace(/\.md$/, '') : slugParts[0].replace(/\.md$/, '');
          return (
            <article class="bg-kailash-light rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition group">
              <a href={`/blog/${cleanSlug}`} class="block">
                <div class="aspect-[16/10] overflow-hidden">
                  <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition duration-500" loading="lazy" />
                </div>
              </a>
              <div class="p-6">
                <div class="flex flex-wrap gap-2 mb-3">
                  {post.data.tags.slice(0, 2).map((tag) => (
                    <span class="text-xs bg-kailash-cream text-kailash-dark/60 px-2 py-0.5 rounded-full">{tag}</span>
                  ))}
                </div>
                <a href={`/blog/${cleanSlug}`}>
                  <h3 class="font-display text-lg font-bold text-kailash-dark mb-2 group-hover:text-kailash-gold transition line-clamp-2">{post.data.title}</h3>
                </a>
                <p class="text-gray-600 text-sm line-clamp-2">{post.data.description}</p>
              </div>
            </article>
          );
        })}
      </div>
      <div class="text-center mt-10">
        <a href="/blog" class="inline-flex items-center text-kailash-gold font-semibold hover:text-kailash-dark transition">
          <span data-lang-content="zh">查看全部文章 →</span>
          <span data-lang-content="en" style="display: none;">View All Articles →</span>
        </a>
      </div>
    </div>
  </section>


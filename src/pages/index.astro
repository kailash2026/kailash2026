---
import Layout from '../layouts/Layout.astro';
import SearchBox from '../components/SearchBox.astro';
---

<Layout title="Kailash 2026 - Global Pilgrimage Platform | Mount Kailash Sacred Mountain" description="Kailash 2026: The global pilgrimage platform connecting pilgrims worldwide. Sacred to Hinduism, Tibetan Buddhism, Bön, and Jainism.">
  
  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-[url('/images/kailash-golden.jpg')] bg-cover bg-center"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-kailash-dark/60 via-kailash-dark/40 to-kailash-dark"></div>
    
    <div class="relative z-10 text-center px-4 max-w-5xl mx-auto">
      <!-- 中文 -->
      <div data-lang-content="zh">
        <p class="text-kailash-gold text-sm md:text-base tracking-[0.3em] uppercase mb-4 font-light">世界中心 · 神圣朝圣之旅</p>
        <h1 class="font-display text-5xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">冈仁波齐<span class="block text-kailash-gold mt-2">2026</span></h1>
        <p class="text-xl md:text-2xl text-white/80 mb-4 max-w-3xl mx-auto font-light leading-relaxed">四大宗教共同的圣地，连接印度、西藏与世界的精神桥梁</p>
        <p class="text-lg text-white/60 mb-8">藏传佛教 · 印度教 · 苯教 · 耆那教</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/guide" class="bg-kailash-gold text-kailash-dark px-8 py-4 rounded-lg font-semibold hover:bg-kailash-accent transition">开始探索</a>
          <a href="/culture" class="border-2 border-white/30 text-white px-8 py-4 rounded-lg font-semibold hover:bg-white/10 transition">了解文化</a>
        </div>
      </div>
      
      <!-- English -->
      <div data-lang-content="en" style="display: none;">
        <p class="text-kailash-gold text-sm md:text-base tracking-[0.3em] uppercase mb-4 font-light">Center of the World · Sacred Pilgrimage</p>
        <h1 class="font-display text-5xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">Mount Kailash<span class="block text-kailash-gold mt-2">2026</span></h1>
        <p class="text-xl md:text-2xl text-white/80 mb-4 max-w-3xl mx-auto font-light leading-relaxed">Sacred to Four Religions, Connecting India, Tibet & the World</p>
        <p class="text-lg text-white/60 mb-8">Tibetan Buddhism · Hinduism · Bön · Jainism</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/guide" class="bg-kailash-gold text-kailash-dark px-8 py-4 rounded-lg font-semibold hover:bg-kailash-accent transition">Start Exploring</a>
          <a href="/culture" class="border-2 border-white/30 text-white px-8 py-4 rounded-lg font-semibold hover:bg-white/10 transition">Explore Culture</a>
        </div>
      </div>
      
      <!-- 日本語 -->
      <div data-lang-content="ja" style="display: none;">
        <p class="text-kailash-gold text-sm md:text-base tracking-[0.3em] uppercase mb-4 font-light">世界の中心 · 神聖なる巡礼の旅</p>
        <h1 class="font-display text-5xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">カイラス山<span class="block text-kailash-gold mt-2">2026</span></h1>
        <p class="text-xl md:text-2xl text-white/80 mb-4 max-w-3xl mx-auto font-light leading-relaxed">四大宗教が共に崇める聖地、インド・チベット・世界をつなぐ精神の橋</p>
        <p class="text-lg text-white/60 mb-8">チベット仏教 · ヒンドゥー教 · ボン教 · ジャイナ教</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/guide" class="bg-kailash-gold text-kailash-dark px-8 py-4 rounded-lg font-semibold hover:bg-kailash-accent transition">探索を始める</a>
          <a href="/culture" class="border-2 border-white/30 text-white px-8 py-4 rounded-lg font-semibold hover:bg-white/10 transition">文化を知る</a>
        </div>
      </div>
      
      
      
      <!-- हिन्दी -->
      <div data-lang-content="hi" style="display: none;">
        <p class="text-kailash-gold text-sm md:text-base tracking-[0.3em] uppercase mb-4 font-light">विश्व का केंद्र · पवित्र तीर्थयात्रा</p>
        <h1 class="font-display text-5xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">कैलाश पर्वत<span class="block text-kailash-gold mt-2">2026</span></h1>
        <p class="text-xl md:text-2xl text-white/80 mb-4 max-w-3xl mx-auto font-light leading-relaxed">चार धर्मों का पवित्र स्थल, भारत, तिब्बत और विश्व को जोड़ने वाला आध्यात्मिक पुल</p>
        <p class="text-lg text-white/60 mb-8">तिब्बती बौद्ध धर्म · हिंदू धर्म · बॉन धर्म · जैन धर्म</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/guide" class="bg-kailash-gold text-kailash-dark px-8 py-4 rounded-lg font-semibold hover:bg-kailash-accent transition">खोज शुरू करें</a>
          <a href="/culture" class="border-2 border-white/30 text-white px-8 py-4 rounded-lg font-semibold hover:bg-white/10 transition">संस्कृति जानें</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="bg-kailash-dark py-8 border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- 中文 -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center" data-lang-content="zh">
        <div><p class="text-3xl md:text-4xl font-bold text-kailash-gold">6656m</p><p class="text-white/60 text-sm mt-1">冈仁波齐海拔</p></div>
        <div><p class="text-3xl md:text-4xl font-bold text-kailash-gold">52km</p><p class="text-white/60 text-sm mt-1">转山全程</p></div>
        <div><p class="text-3xl md:text-4xl font-bold text-kailash-gold">5630m</p><p class="text-white/60 text-sm mt-1">最高垭口</p></div>
        <div><p class="text-3xl md:text-4xl font-bold text-kailash-gold">4</p><p class="text-white/60 text-sm mt-1">宗教圣地</p></div>
      </div>
      <!-- English -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center" data-lang-content="en" style="display: none;">
        <div><p class="text-3xl md:text-4xl font-bold text-kailash-gold">6,656m</p><p class="text-white/60 text-sm mt-1">Peak Elevation</p></div>
        <div><p class="text-3xl md:text-4xl font-bold text-kailash-gold">52km</p><p class="text-white/60 text-sm mt-1">Kora Distance</p></div>
        <div><p class="text-3xl md:text-4xl font-bold text-kailash-gold">5,630m</p><p class="text-white/60 text-sm mt-1">Highest Pass</p></div>
        <div><p class="text-3xl md:text-4xl font-bold text-kailash-gold">4</p><p class="text-white/60 text-sm mt-1">Sacred Traditions</p></div>
      </div>
      <!-- 日本語 -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center" data-lang-content="ja" style="display: none;">
        <div><p class="text-3xl md:text-4xl font-bold text-kailash-gold">6656m</p><p class="text-white/60 text-sm mt-1">カイラス山の標高</p></div>
        <div><p class="text-3xl md:text-4xl font-bold text-kailash-gold">52km</p><p class="text-white/60 text-sm mt-1">コーラ全長</p></div>
        <div><p class="text-3xl md:text-4xl font-bold text-kailash-gold">5630m</p><p class="text-white/60 text-sm mt-1">最高地点ドマラ峠</p></div>
        <div><p class="text-3xl md:text-4xl font-bold text-kailash-gold">4</p><p class="text-white/60 text-sm mt-1">宗教の聖地</p></div>
      </div>
      
      <!-- हिन्दी -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center" data-lang-content="hi" style="display: none;">
        <div><p class="text-3xl md:text-4xl font-bold text-kailash-gold">6656m</p><p class="text-white/60 text-sm mt-1">कैलाश की ऊँचाई</p></div>
        <div><p class="text-3xl md:text-4xl font-bold text-kailash-gold">52km</p><p class="text-white/60 text-sm mt-1">परिक्रमा दूरी</p></div>
        <div><p class="text-3xl md:text-4xl font-bold text-kailash-gold">5630m</p><p class="text-white/60 text-sm mt-1">सबसे ऊँचा दर्रा</p></div>
        <div><p class="text-3xl md:text-4xl font-bold text-kailash-gold">4</p><p class="text-white/60 text-sm mt-1">धार्मिक स्थल</p></div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-20 bg-kailash-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- 中文 -->
      <div class="text-center mb-16" data-lang-content="zh">
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4">为什么选择冈仁波齐</h2>
        <p class="text-lg text-gray-600">世界中心，信仰之巅</p>
      </div>
      <!-- English -->
      <div class="text-center mb-16" data-lang-content="en" style="display: none;">
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4">Why Kailash?</h2>
        <p class="text-lg text-gray-600">Center of the World, Pinnacle of Faith</p>
      </div>
      <!-- 日本語 -->
      <div class="text-center mb-16" data-lang-content="ja" style="display: none;">
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4">なぜカイラスなのか</h2>
        <p class="text-lg text-gray-600">世界の中心、信仰の頂点</p>
      </div>
      
      <!-- हिन्दी -->
      <div class="text-center mb-16" data-lang-content="hi" style="display: none;">
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4">क्यों कैलाश?</h2>
        <p class="text-lg text-gray-600">विश्व का केंद्र, आस्था का शिखर</p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Feature 1: Four Religions -->
        <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-xl transition">
          <div class="text-4xl mb-4">🕉️</div>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="zh">四大宗教圣地</h3>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="en" style="display: none;">Four Sacred Traditions</h3>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="ja" style="display: none;">四大宗教の聖地</h3>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="hi" style="display: none;">चार पवित्र परंपराएँ</h3>
          <p class="text-gray-600" data-lang-content="zh">藏传佛教、印度教、苯教、耆那教共同尊奉的世界中心，全球唯一被四大宗教同时视为圣地的山峰</p>
          <p class="text-gray-600" data-lang-content="en" style="display: none;">Tibetan Buddhism, Hinduism, Bön, and Jainism all revere this as the center of the world. The only mountain sacred to all four religions simultaneously.</p>
          <p class="text-gray-600" data-lang-content="ja" style="display: none;">チベット仏教、ヒンドゥー教、ボン教、ジャイナ教が共に崇める世界の中心。全球で唯一、四大宗教が同時に聖地とする山。</p>
          <p class="text-gray-600" data-lang-content="hi" style="display: none;">तिब्बती बौद्ध धर्म, हिंदू धर्म, बॉन धर्म और जैन धर्म इसे विश्व का केंद्र मानते हैं। एकमात्र पर्वत जो चारों धर्मों को एक साथ पवित्र है।</p>
        </div>
        
        <!-- Feature 2: 6656m -->
        <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-xl transition">
          <div class="text-4xl mb-4">🏔️</div>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="zh">6656米神山</h3>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="en" style="display: none;">6,656m Sacred Peak</h3>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="ja" style="display: none;">6656メートルの聖山</h3>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="hi" style="display: none;">6,656मी पवित्र शिखर</h3>
          <p class="text-gray-600" data-lang-content="zh">从未被攀登的圣洁之峰，金字塔形山体独一无二，南坡万字符印记神秘庄严</p>
          <p class="text-gray-600" data-lang-content="en" style="display: none;">An unclimbed sacred summit with a unique pyramid shape. The mysterious swastika mark on its southern face radiates solemn divinity.</p>
          <p class="text-gray-600" data-lang-content="ja" style="display: none;">未踏の聖なる峰、ピラミッド型の山体は独一无二。南斜面の万字印は神秘に満ちた荘厳さを放つ。</p>
          <p class="text-gray-600" data-lang-content="hi" style="display: none;">एक अविजित पवित्र शिखर जिसका पिरामिड आकार अद्वितीय है। दक्षिणी ढलान पर स्वस्तिक चिह्न रहस्यमय और गंभीर दिव्यता बिखेरता है।</p>
        </div>
        
        <!-- Feature 3: 52km -->
        <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-xl transition">
          <div class="text-4xl mb-4">🚶</div>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="zh">52公里转山</h3>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="en" style="display: none;">52km Kora Circuit</h3>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="ja" style="display: none;">52キロのコーラ</h3>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="hi" style="display: none;">52km परिक्रमा मार्ग</h3>
          <p class="text-gray-600" data-lang-content="zh">三天两夜高原徒步，翻越5630米卓玛拉垭口，每转一圈相当于念诵六字真言六亿遍</p>
          <p class="text-gray-600" data-lang-content="en" style="display: none;">A three-day high-altitude trek crossing the 5,630m Drolma La pass. One circuit equals 600 million recitations of the six-syllable mantra.</p>
          <p class="text-gray-600" data-lang-content="ja" style="display: none;">三日二夜の高原ハイキング、5630メートルのドマラ峠を越えて。一周することで六字真言を六億遍唱えたのと同等の功徳。</p>
          <p class="text-gray-600" data-lang-content="hi" style="display: none;">तीन दिनों की उच्च ऊँचाई वाली यात्रा, 5630मी के दोलमा ला दर्रे को पार करना। एक परिक्रमा छह अरब मंत्रों के जाप के बराबर पुण्य देती है।</p>
        </div>
        
        <!-- Feature 4: Lake -->
        <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-xl transition">
          <div class="text-4xl mb-4">💧</div>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="zh">圣湖玛旁雍错</h3>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="en" style="display: none;">Lake Manasarovar</h3>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="ja" style="display: none;">聖湖マナサロワール</h3>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="hi" style="display: none;">मानसरोवर झील</h3>
          <p class="text-gray-600" data-lang-content="zh">世界上海拔最高的淡水湖之一，四大河流的发源地，被称为「西天瑶池」</p>
          <p class="text-gray-600" data-lang-content="en" style="display: none;">One of the world's highest freshwater lakes, source of four great rivers. Known as the "Western Heaven Jade Pool."</p>
          <p class="text-gray-600" data-lang-content="ja" style="display: none;">世界で最も高い淡水湖の一つ、四大河の発源地。「西天瑶池」と称される。</p>
          <p class="text-gray-600" data-lang-content="hi" style="display: none;">दुनिया की सबसे ऊँची मीठे पानी की झीलों में से एक, चार महान नदियों का उद्गम स्थल। इसे 'स्वर्ग का जेड तालाब' कहा जाता है।</p>
        </div>
        
        <!-- Feature 5: Global -->
        <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-xl transition">
          <div class="text-4xl mb-4">🌏</div>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="zh">全球朝圣者</h3>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="en" style="display: none;">Global Pilgrims</h3>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="ja" style="display: none;">世界の巡礼者</h3>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="hi" style="display: none;">वैश्विक तीर्थयात्री</h3>
          <p class="text-gray-600" data-lang-content="zh">每年数十万朝圣者来自印度、尼泊尔、中国及世界各地，不同信仰者在此平等朝拜</p>
          <p class="text-gray-600" data-lang-content="en" style="display: none;">Hundreds of thousands of pilgrims gather annually from India, Nepal, China, and across the globe. Different faiths worship here as equals.</p>
          <p class="text-gray-600" data-lang-content="ja" style="display: none;">年間数十万の巡礼者がインド、ネパール、中国、世界各地から集まる。異なる信仰者がここで平等に礼拝する。</p>
          <p class="text-gray-600" data-lang-content="hi" style="display: none;">हर साल लाखों तीर्थयात्री भारत, नेपाल, चीन और दुनिया भर से आते हैं। विभिन्न धर्मों के लोग यहाँ समान रूप से पूजा करते हैं।</p>
        </div>
        
        <!-- Feature 6: 2026 -->
        <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-xl transition">
          <div class="text-4xl mb-4">📅</div>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="zh">2026朝圣之旅</h3>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="en" style="display: none;">2026 Pilgrimage</h3>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="ja" style="display: none;">2026年巡礼の旅</h3>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3" data-lang-content="hi" style="display: none;">2026 तीर्थयात्रा</h3>
          <p class="text-gray-600" data-lang-content="zh">精心策划的行程，专业团队全程保障您的安全，早鸟预订享受专属优惠</p>
          <p class="text-gray-600" data-lang-content="en" style="display: none;">Carefully planned itineraries with professional teams ensuring your safety. Early bird bookings enjoy exclusive discounts.</p>
          <p class="text-gray-600" data-lang-content="ja" style="display: none;">丁寧に計画された行程、プロチームが安全をフルサポート。早期予約で特別割引を享受。</p>
          <p class="text-gray-600" data-lang-content="hi" style="display: none;">सावधानीपूर्वक योजनाबद्ध यात्राएँ, पेशेवर टीमें आपकी सुरक्षा सुनिश्चित करती हैं। जल्दी बुकिंग पर विशेष छूट।</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Route Preview -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- 中文 -->
      <div class="text-center mb-16" data-lang-content="zh">
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4">52公里转山路线</h2>
        <p class="text-lg text-gray-600">三天两夜的高原徒步，从塔尔钦出发，翻越5630米的卓玛拉垭口，最终回到起点</p>
      </div>
      <!-- English -->

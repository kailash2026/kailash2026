      <a href="mailto:kailash2026Lucas@outlook.com?subject=预览《冈仁波齐权威指南》" class="inline-block bg-kailash-dark text-kailash-gold px-8 py-3 rounded-lg font-semibold hover:bg-kailash-stone transition">

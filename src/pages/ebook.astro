---
import Layout from '../layouts/Layout.astro';

const features = [
  {
    icon: '📚',
    title: '13部权威著作摘要',
    titleEn: '13 Verified Book Summaries',
    desc: '覆盖藏传佛教、印度教、苯教、耆那教四大传统的核心文献，每篇摘要均标注原始出处与版本信息。',
    descEn: 'Core texts from Tibetan Buddhism, Hinduism, Bön, and Jainism, each summary citing original sources and edition details.',
  },
  {
    icon: '🗺️',
    title: '完整转山路线指南',
    titleEn: 'Complete Kora Route Guide',
    desc: '外圈52公里详细分段描述，含海拔变化、补给点、住宿推荐、卓玛拉山口通行建议。',
    descEn: 'Detailed 52km outer kora breakdown with elevation changes, supply points, accommodation tips, and Drolma La Pass advice.',
  },
  {
    icon: '🏔️',
    title: '高原反应防护指南',
    titleEn: 'Altitude Sickness Guide',
    desc: '基于医学文献与实地经验，涵盖预防措施、症状识别、紧急应对方案。',
    descEn: 'Based on medical literature and field experience, covering prevention, symptom recognition, and emergency response.',
  },
  {
    icon: '⚖️',
    title: '四大宗教对比分析',
    titleEn: '4-Religion Comparison',
    desc: '藏传佛教、印度教、苯教、耆那教对冈仁波齐的不同解读与朝圣传统，一目了然的对比表格。',
    descEn: 'Side-by-side comparison of how Tibetan Buddhism, Hinduism, Bön, and Jainism interpret Mount Kailash and their pilgrimage traditions.',
  },
  {
    icon: '📖',
    title: '朝圣实用手册',
    titleEn: 'Pilgrimage Practical Handbook',
    desc: '涵盖签证办理、最佳季节、装备清单、当地交通、住宿预算等所有行前必备信息。',
    descEn: 'Covers visas, best seasons, equipment checklist, local transport, accommodation budget—everything you need before departure.',
  },
  {
    icon: '🖼️',
    title: '高清地图与实拍照片',
    titleEn: 'HD Maps & Field Photos',
    desc: '独家手绘路线图与实地拍摄的高清照片，标注关键地标与朝圣节点。',
    descEn: 'Exclusive hand-drawn route maps and high-resolution field photos, with key landmarks and pilgrimage points marked.',
  },
];
---

<Layout title="冈仁波齐权威指南 - 电子书 | The Authoritative Guide to Mount Kailash - Ebook" description="《冈仁波齐权威指南》电子书：45页PDF，含13部权威著作摘要、转山路线指南、高原反应防护、四大宗教对比。售价 ¥29.9 / $4.99。">


<script>
  document.getElementById('ebook-purchase-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const email = form.querySelector('input[name="email"]')?.value?.trim();
    if (!email) return;

    const btn = document.getElementById('ebook-purchase-btn');
    const card = document.getElementById('purchase-card');
    const origText = btn?.textContent;
    if (btn) { btn.textContent = '发送中...'; btn.disabled = true; }

    try {
      const res = await fetch('/api/ebook-purchase', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, method: 'wechat/alipay' }),
      });

      if (res.ok) {
        if (card) {
          card.innerHTML = `
            <div class="text-center py-8">
              <p class="text-5xl mb-4">📬</p>
              <p class="text-xl font-bold text-kailash-dark mb-2">
                <span data-lang-content="zh">电子书已发送！</span>
                <span data-lang-content="en" style="display: none;">Ebook Sent!</span>
              </p>
              <p class="text-gray-500 mb-4">
                <span data-lang-content="zh">请检查 <strong>${email}</strong> 的收件箱（也看看垃圾邮件箱）</span>
                <span data-lang-content="en" style="display: none;">Check <strong>${email}</strong> inbox (and spam folder)</span>
              </p>
              <p class="text-xs text-gray-400">
                <span data-lang-content="zh">没收到？联系 kailash2026Lucas@outlook.com</span>
                <span data-lang-content="en" style="display: none;">Didn't receive it? Contact kailash2026Lucas@outlook.com</span>
              </p>
            </div>
          `;
        }
      } else {
        if (btn) { btn.textContent = origText; btn.disabled = false; }
        alert('发送失败，请联系 kailash2026Lucas@outlook.com');
      }
    } catch {
      if (btn) { btn.textContent = origText; btn.disabled = false; }
      alert('网络错误，请重试或直接联系 kailash2026Lucas@outlook.com');
    }
  });
</script>

</Layout>

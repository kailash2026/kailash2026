    services: "临时板房"
  },
  {
    id: 11,
    name: "仲哲普寺 / 祖楚寺",
    nameEn: "Zhongzhepu Temple",
    altitude: 4800,
    distance: "+4.5km",
    type: "camp",
    supplies: ["酥油茶", "藏面", "泡面", "零食"],
    lodging: "多人间（旺季开放）",
    services: "中型补给，简易住宿"
  },
  {
    id: 12,
    name: "宗堆茶馆",
    nameEn: "Zongdui Teahouse",
    altitude: 4700,
    distance: "+6.2km",

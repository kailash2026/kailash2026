  },
  {
    id: 13,
    name: "塔尔钦",
    nameEn: "Tarqin",
    altitude: 4600,
    distance: "+4km（终点）",
    type: "end",
    supplies: ["矿泉水", "可乐", "能量饮料", "方便面", "面包", "巧克力", "牛肉干", "压缩饼干", "氧气瓶", "冲锋衣", "帽子", "手套", "登山杖", "护膝", "防晒霜", "唇膏"],
    lodging: "客栈、酒店（多人间/标间）",
    services: "餐厅、商店、加油站、邮局、网吧、医务室、租车/马/背夫"
  }
];
---

<Layout title="转山路线 - 52公里朝圣之旅 | Kailash 2026" description="冈仁波齐52公里外转路线详解：三天两夜行程、海拔变化、途经寺庙与地标。从塔尔钦出发，翻越5630米卓玛拉垭口。">
  <!-- Hero: Photo on top, content below -->
  <section class="relative bg-kailash-dark">
    <!-- Full-width photo -->
    <div class="relative w-full h-[45vh] lg:h-[55vh]">
      <div class="absolute inset-0 bg-[url('/images/kailash-yaks.jpg')] bg-cover bg-center"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-kailash-dark"></div>
    </div>
    
    <!-- Content below photo -->
    <div class="relative -mt-20 z-10 px-4 sm:px-6 lg:px-8 pb-16">
      <div class="max-w-7xl mx-auto text-center">
        <h1 class="font-display text-5xl md:text-6xl font-bold text-white mb-4">
          <span data-lang-content="zh">转山路线</span>
          <span data-lang-content="en" style="display: none;">Kora Route</span>
        </h1>
        <p class="text-xl text-white/60 max-w-3xl mx-auto">
          <span data-lang-content="zh">52公里，三天两夜，从信仰出发，向心灵回归</span>
          <span data-lang-content="en" style="display: none;">52 km, three days and two nights—from faith, toward the soul</span>
        </p>
        <div class="flex justify-center gap-8 mt-8">
          <div class="text-center">
            <p class="text-3xl font-bold text-kailash-gold">52km</p>
            <p class="text-white/40 text-sm" data-lang-content="zh">总距离</p>
            <p class="text-white/40 text-sm" data-lang-content="en" style="display: none;">Total Distance</p>
          </div>
          <div class="text-center">
            <p class="text-3xl font-bold text-kailash-gold">5630m</p>
            <p class="text-white/40 text-sm" data-lang-content="zh">最高点</p>
            <p class="text-white/40 text-sm" data-lang-content="en" style="display: none;">Highest Point</p>
          </div>
          <div class="text-center">
            <p class="text-3xl font-bold text-kailash-gold">3天</p>
            <p class="text-white/40 text-sm" data-lang-content="zh">标准行程</p>
            <p class="text-white/40 text-sm" data-lang-content="en" style="display: none;">Standard Itinerary</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Route Overview -->
  <section class="py-20 bg-kailash-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4">
          <span data-lang-content="zh">路线概览</span>
          <span data-lang-content="en" style="display: none;">Route Overview</span>
        </h2>
        <p class="text-lg text-gray-600">
          <span data-lang-content="zh">海拔变化与关键节点</span>
          <span data-lang-content="en" style="display: none;">Altitude changes and key waypoints</span>
        </p>
      </div>

      <!-- Altitude Chart Placeholder -->
      <div class="bg-white rounded-2xl shadow-lg p-8 mb-12">
        <div class="aspect-[21/9] bg-gradient-to-r from-gray-100 to-gray-50 rounded-xl flex items-center justify-center">
          <div class="text-center text-gray-500">
            <svg class="w-16 h-16 mx-auto mb-4 text-kailash-gold/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"></path>
            </svg>
            <p data-lang-content="zh">海拔变化图表（4600m → 5648m → 4600m）</p>
            <p data-lang-content="en" style="display: none;">Altitude Profile (4600m → 5648m → 4600m)</p>
          </div>
        </div>
      </div>

      <!-- 分段补给明细 -->
      <div class="mt-16">
        <div class="text-center mb-12">
          <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4">
            <span data-lang-content="zh">分段补给明细</span>
            <span data-lang-content="en" style="display: none;">Supply Stations</span>
          </h2>
          <p class="text-lg text-gray-600">
            <span data-lang-content="zh">13个补给点，从起点到终点全程覆盖</span>
            <span data-lang-content="en" style="display: none;">13 supply stations covering the entire route</span>
          </p>
        </div>

        <div class="space-y-4">
          {supplyStations.map((station, index) => (
            <div class={`rounded-xl overflow-hidden ${
              station.type === 'start' || station.type === 'end' ? 'bg-green-50 border-2 border-green-200' :
              station.type === 'peak' ? 'bg-red-50 border-2 border-red-200' :
              station.type === 'camp' ? 'bg-blue-50 border-2 border-blue-200' :
              'bg-white shadow-md border border-gray-100'
            }`}>
              <div class={`p-5 ${
                station.type === 'start' || station.type === 'end' ? 'bg-green-100/50' :
                station.type === 'peak' ? 'bg-red-100/50' :
                station.type === 'camp' ? 'bg-blue-100/50' :
                'bg-gray-50/50'
              }`}>
                <div class="flex items-start gap-4">
                  <div class={`w-14 h-14 rounded-full flex items-center justify-center font-bold text-lg shrink-0 ${
                    station.type === 'start' || station.type === 'end' ? 'bg-green-500 text-white' :
                    station.type === 'peak' ? 'bg-red-500 text-white' :
                    station.type === 'camp' ? 'bg-blue-500 text-white' :
                    'bg-kailash-gold text-kailash-dark'
                  }`}>
                    {station.altitude}m
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-3 mb-1 flex-wrap">
                      <h3 class="font-display text-xl font-bold text-kailash-dark">{station.name}</h3>
                      <span class="text-sm text-gray-500">{station.nameEn}</span>
                      {station.type === 'camp' && <span class="bg-blue-100 text-blue-700 px-2 py-0.5 rounded text-xs font-semibold" data-lang-content="zh">🏠 住宿点</span>}
                      {station.type === 'peak' && <span class="bg-red-100 text-red-700 px-2 py-0.5 rounded text-xs font-semibold" data-lang-content="zh">⚠️ 最高点</span>}
                      {station.type === 'start' && <span class="bg-green-100 text-green-700 px-2 py-0.5 rounded text-xs font-semibold" data-lang-content="zh">🚀 起点</span>}
                      {station.type === 'end' && <span class="bg-green-100 text-green-700 px-2 py-0.5 rounded text-xs font-semibold" data-lang-content="zh">🏁 终点</span>}
                      {station.type === 'teahouse' && <span class="bg-kailash-gold/20 text-kailash-dark px-2 py-0.5 rounded text-xs font-semibold" data-lang-content="zh">🍵 茶馆</span>}
                    </div>
                    <p class="text-sm text-gray-500 font-medium">{station.distance}</p>
                  </div>
                  <div class="text-2xl text-gray-300 font-bold shrink-0">
                    {String(index + 1).padStart(2, '0')}
                  </div>
                </div>
              </div>
              
              <div class="px-5 pb-5">
                {station.supplies.length > 0 && (
                  <div class="mb-3">
                    <h4 class="text-sm font-semibold text-gray-700 mb-2 flex items-center gap-1">
                      <span class="text-kailash-gold">●</span> 可购买
                    </h4>
                    <div class="flex flex-wrap gap-2">
                      {station.supplies.map(item => (
                        <span class="bg-white border border-gray-200 px-2 py-1 rounded text-sm text-gray-600">{item}</span>
                      ))}
                    </div>
                  </div>
                )}
                
                <div class="grid md:grid-cols-2 gap-3">
                  <div>
                    <h4 class="text-sm font-semibold text-gray-700 mb-1 flex items-center gap-1">
                      <span class="text-kailash-gold">●</span> 住宿
                    </h4>
                    <p class="text-sm text-gray-600">{station.lodging}</p>
                  </div>
                  <div>
                    <h4 class="text-sm font-semibold text-gray-700 mb-1 flex items-center gap-1">
                      <span class="text-kailash-gold">●</span> 服务
                    </h4>
                    <p class="text-sm text-gray-600">{station.services}</p>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Day by Day -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4">
          <span data-lang-content="zh">每日详情</span>
          <span data-lang-content="en" style="display: none;">Day-by-Day Details</span>
        </h2>
        <p class="text-lg text-gray-600">
          <span data-lang-content="zh">三天转山路，一步一修行</span>
          <span data-lang-content="en" style="display: none;">Three days of pilgrimage, every step a practice</span>
        </p>
      </div>

      <div class="space-y-12">
        {routeDays.map((day, index) => (
          <div class="bg-kailash-light rounded-2xl overflow-hidden">
            <div class="bg-kailash-dark text-white p-6">
              <div class="flex items-center justify-between">
                <div>
                  <span class="text-kailash-gold font-semibold">{day.day}</span>
                  <h3 class="font-display text-2xl font-bold mt-1">{day.title}</h3>
                </div>
                <div class="text-right text-sm text-gray-400">
                  <p>{day.distance}</p>
                  <p>{day.altitude}</p>
                  <p>{day.duration}</p>
                </div>
              </div>
            </div>
            <div class="p-8">
              <p class="text-gray-700 mb-6 leading-relaxed">{day.description}</p>
              
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <h4 class="font-semibold mb-3 flex items-center gap-2">
                    <span class="text-kailash-gold">★</span>
                    <span data-lang-content="zh">途经亮点</span>
                    <span data-lang-content="en" style="display: none;">Highlights</span>
                  </h4>
                  <ul class="space-y-2">
                    {day.highlights.map(h => (
                      <li class="flex items-center gap-2 text-gray-600">
                        <span class="w-1.5 h-1.5 bg-kailash-gold rounded-full"></span>
                        {h}
                      </li>
                    ))}
                  </ul>
                </div>
                <div class="bg-amber-50 rounded-xl p-4">
                  <h4 class="font-semibold mb-2 text-amber-800">
                    <span data-lang-content="zh">💡 温馨提示</span>
                    <span data-lang-content="en" style="display: none;">💡 Tips</span>
                  </h4>
                  <p class="text-amber-700 text-sm">{day.tips}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Booking CTA -->
  <section class="py-20 bg-kailash-gold">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-3xl font-bold text-kailash-dark mb-4">
        <span data-lang-content="zh">准备好踏上朝圣之路了吗？</span>
        <span data-lang-content="en" style="display: none;">Ready to embark on the pilgrimage?</span>
      </h2>
      <p class="text-kailash-dark/80 mb-8">
        <span data-lang-content="zh">了解更多转山路线详情，规划您的冈仁波齐朝圣之旅</span>
        <span data-lang-content="en" style="display: none;">Learn more about the Kora route and plan your Mount Kailash pilgrimage</span>
      </p>
      <a href="/booking" class="inline-flex items-center bg-kailash-dark text-white px-8 py-4 rounded-lg font-semibold text-lg hover:bg-kailash-dark/90 transition">
        <span data-lang-content="zh">预订朝圣之旅</span>
        <span data-lang-content="en" style="display: none;">Book Your Pilgrimage</span>
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
      </a>
    </div>
  </section>
</Layout>

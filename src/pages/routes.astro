    name: "珠牡沐浴瀑布",
    nameEn: "Jomu Waterfall",
    altitude: 4900,
    distance: "+4.5km",
    type: "teahouse",
    supplies: ["酥油茶", "热水", "泡面"],
    lodging: "无住宿",
    services: "临时板房"
  },
  {

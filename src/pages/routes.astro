                    <h5 class="font-semibold mb-2 text-amber-800 text-sm">
                      <span data-lang-content="zh">💡 温馨提示</span>
                      <span data-lang-content="en" style="display: none;">💡 Tips</span>
                    </h5>
                    <p class="text-amber-700 text-sm">
                      <span data-lang-content="zh">{day.tips}</span>
                      <span data-lang-content="en" style="display: none;">{day.tipsEn}</span>
                    </p>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


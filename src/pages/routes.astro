    nameEn: "Tarqin",
    altitude: 4600,
    distance: "0km（起点）",
    type: "start",
    supplies: ["矿泉水", "可乐", "能量饮料", "方便面", "面包", "巧克力", "牛肉干", "压缩饼干", "氧气瓶", "冲锋衣", "帽子", "手套", "登山杖", "护膝", "防晒霜", "唇膏"],
    lodging: "客栈、酒店（多人间/标间）",
    services: "餐厅、商店、加油站、邮局、网吧、医务室、租车/马/背夫"
  },
  {

---
import Layout from '../layouts/Layout.astro';

const values = [
  {
    title: "跨宗教中立",
    titleEn: "Interfaith Neutrality",
    desc: "同时呈现藏传佛教、印度教、苯教、耆那教四大传统，不站队、不偏袒，尊重每一种真诚的信仰。",
    descEn: "Presenting Tibetan Buddhism, Hinduism, Bön, and Jainism without taking sides. Every sincere faith deserves respect.",
    icon: "⚖️"
  },
  {
    title: "学术诚实",
    titleEn: "Academic Honesty",
    desc: "区分宗教叙事与历史可证性，承认不确定，呈现争议，不编造年份和细节。",
    descEn: "Distinguishing religious narrative from historical verifiability. Acknowledging uncertainty and presenting disputes without fabricating dates or details.",
    icon: "📚"
  },
  {
    title: "一手经验",
    titleEn: "Firsthand Experience",
    desc: "内容基于实地走访与亲身转山经历，不是二手搬运，不是想象。",
    descEn: "Content grounded in field visits and personal Kora experience—not secondhand copy or imagination.",
    icon: "🥾"
  },
  {
    title: "开放共享",
    titleEn: "Open Sharing",
    desc: "文字内容采用 Creative Commons 授权，欢迎全球媒体、学者、创作者引用。",
    descEn: "Text content under Creative Commons license. Global media, scholars, and creators are welcome to cite and adapt.",
    icon: "🌐"
  }
];
---

<Layout title="关于我们 - 冈仁波齐全球文化平台 | About Kailash 2026" description="Kailash 2026 是全球首个跨宗教中立的冈仁波齐文化平台。我们呈现藏传佛教、印度教、苯教、耆那教四大传统，以学术严谨与通俗表达并行的方式，服务全球 pilgrims 与研究者。">

  <!-- Hero: Photo on top, content below -->
  <section class="relative bg-kailash-dark">
    <!-- Full-width photo -->
    <div class="relative w-full h-[45vh] lg:h-[55vh]">
      <div class="absolute inset-0 bg-[url('/images/kailash-sunrise.jpg')] bg-cover bg-center"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-kailash-dark"></div>
    </div>
    
    <!-- Content below photo -->
    <div class="relative -mt-20 z-10 px-4 sm:px-6 lg:px-8 pb-16">
      <div class="max-w-5xl mx-auto text-center">
        <p class="text-kailash-gold text-sm tracking-widest uppercase mb-4">About Us · 关于我们</p>
        <h1 class="font-display text-5xl md:text-6xl font-bold text-white mb-6">
          <span data-lang-content="zh">关于 Kailash 2026</span>
          <span data-lang-content="en" style="display: none;">About Kailash 2026</span>
        </h1>
        <p class="text-xl text-white/60 max-w-3xl mx-auto mb-4">
          <span data-lang-content="zh">全球首个跨宗教中立的冈仁波齐冈仁波齐文化平台</span>
          <span data-lang-content="en" style="display: none;">The world's first interfaith-neutral sacred mountain culture platform for Mount Kailash</span>
        </p>
        <p class="text-lg text-white/40 italic">
          <span data-lang-content="zh">The world's first interfaith-neutral sacred mountain culture platform for Mount Kailash</span>
          <span data-lang-content="en" style="display: none;">全球首个跨宗教中立的冈仁波齐冈仁波齐文化平台</span>
        </p>
      </div>
    </div>
  </section>

  <!-- Story -->
  <section class="py-20 bg-kailash-light">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-3xl font-bold text-kailash-dark mb-8 text-center">
        <span data-lang-content="zh">我们的故事</span>
        <span data-lang-content="en" style="display: none;">Our Story</span>
      </h2>
      <div class="prose prose-lg mx-auto text-gray-600">
        <p class="mb-6 text-lg leading-relaxed">
          <span data-lang-content="zh">Kailash 2026 诞生于一个简单的观察：关于冈仁波齐，全球没有一个网站真正同时回答四大宗教信徒的问题。印度教网站不讲苯教，佛教网站不提湿婆，旅行指南没有宗教深度，而学术文章又太艰深。</span>
          <span data-lang-content="en" style="display: none;">Kailash 2026 was born from a simple observation: there is no website in the world that truly answers the questions of devotees from all four religions at once. Hindu sites don't mention Bön, Buddhist sites don't mention Shiva, travel guides lack religious depth, and academic articles are too dense.</span>
        </p>
        <p class="mb-6 text-lg leading-relaxed">
          <span data-lang-content="zh">我们想做的是——一个让藏传佛教徒、印度教徒、苯教信徒、耆那教徒，以及什么都不信只是好奇的人，都能找到自己需要的信息的地方。中立、诚实、有深度。</span>
          <span data-lang-content="en" style="display: none;">What we want to create is a place where Tibetan Buddhists, Hindus, Bön practitioners, Jains, and even those who believe in nothing but are simply curious can all find the information they need. Neutral, honest, and deep.</span>
        </p>
        <p class="text-lg leading-relaxed">
          <span data-lang-content="zh">这不是一个旅行社网站。我们不卖团、不催单。我们传播冈仁波齐文化，建立信任，然后让 pilgrims 自己决定何时、以何种方式前往。</span>
          <span data-lang-content="en" style="display: none;">This is not a travel agency website. We don't sell tours or push bookings. We spread sacred mountain culture, build trust, and let pilgrims decide for themselves when and how to go.</span>
        </p>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display text-3xl font-bold text-kailash-dark mb-2">
          <span data-lang-content="zh">我们的原则</span>
          <span data-lang-content="en" style="display: none;">Our Principles</span>
        </h2>
        <p class="text-lg text-gray-500 italic">Our Principles</p>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        {values.map((value, index) => (
          <div class="bg-kailash-light rounded-2xl p-8">
            <div class="flex items-center gap-4 mb-4">
              <div class="text-4xl">{value.icon}</div>
              <div>
                <h3 class="font-display text-xl font-bold text-kailash-dark">{value.title}</h3>
                <p class="text-sm text-gray-500 italic">{value.titleEn}</p>
              </div>
            </div>
            <p class="text-gray-700 leading-relaxed">{value.desc}</p>
            <p class="text-gray-500 text-sm italic mt-2">{value.descEn}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Press Kit CTA -->
  <section class="py-20 bg-kailash-dark text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-3xl font-bold mb-4">
        <span data-lang-content="zh">媒体与创作者</span>
        <span data-lang-content="en" style="display: none;">Press & Creators</span>
      </h2>
      <p class="text-gray-300 mb-4">
        <span data-lang-content="zh">我们为记者、学者、博主提供免费的素材包、引用格式与采访支持。</span>
        <span data-lang-content="en" style="display: none;">We offer free press kits, citation formats, and interview support for journalists, scholars, and content creators.</span>
      </p>
      <p class="text-gray-400 italic mb-8">
        <span data-lang-content="zh">We offer free press kits, citation formats, and interview support for journalists, scholars, and content creators.</span>
        <span data-lang-content="en" style="display: none;">我们为记者、学者、博主提供免费的素材包、引用格式与采访支持。</span>
      </p>
      <a href="/press-kit" class="bg-kailash-gold text-kailash-dark px-8 py-3 rounded-lg font-semibold hover:bg-kailash-accent transition inline-block">
        <span data-lang-content="zh">访问媒体素材包</span>
        <span data-lang-content="en" style="display: none;">Visit Press Kit</span>
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-kailash-gold">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-3xl font-bold text-kailash-dark mb-4">
        <span data-lang-content="zh">加入我们的旅程</span>
        <span data-lang-content="en" style="display: none;">Join Our Journey</span>
      </h2>
      <p class="text-kailash-dark/80 text-lg mb-8 leading-relaxed">
        <span data-lang-content="zh">无论你是计划朝圣、研究冈仁波齐文化，还是单纯好奇——这里都有属于你的内容。</span>
        <span data-lang-content="en" style="display: none;">Whether you're planning a pilgrimage, researching sacred mountain culture, or simply curious—there's something here for you.</span>
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/culture" class="bg-kailash-dark text-white px-8 py-3 rounded-lg font-semibold hover:bg-kailash-dark/90 transition">
          <span data-lang-content="zh">探索冈仁波齐文化</span>
          <span data-lang-content="en" style="display: none;">Explore Culture</span>
        </a>
        <a href="/contact" class="bg-white text-kailash-dark px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition">
          <span data-lang-content="zh">联系我们</span>
          <span data-lang-content="en" style="display: none;">Contact Us</span>
        </a>
      </div>
    </div>
  </section>

</Layout>

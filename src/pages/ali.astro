---
import Layout from '../layouts/Layout.astro';

// 冈仁波齐·写实影像 — 用镜头记录神山与朝圣的真实面貌
// 不做艺术加工，不搞旅游渲染。就是客观记录。
const culturePhotos = [
  {
    id: "golden-peak",
    title: "日照金山",
    titleEn: "Golden Summit at Dawn",
    desc: "日出时分，第一缕阳光点燃冈仁波齐南壁。金字塔形山体在晨光中呈现金色——藏语称「斯巴阔洛」，意为金色神山。",
    descEn: "First light ignites Kailash's south face at dawn. The pyramidal peak glows gold — Tibetans call this 'Serpo Kora,' the golden sacred mountain.",
    image: "kailash-golden.webp",
    location: "塔尔钦南侧·日出角度"
  },
  {
    id: "north-face",
    title: "神山北壁",
    titleEn: "The North Face",
    desc: "转山第一天途中可见的北壁景观。巨大的万字符印记隐约可辨——藏传佛教和苯教均视此印记为神圣符号，方向相反，信仰如一。",
    descEn: "The north face visible on Day 1 of the kora. A faint swastika mark can be discerned on the rock — revered by both Tibetan Buddhists and Bön practitioners, opposite in direction, one in faith.",
    image: "kailash-aerial.webp",
    location: "止热寺附近·转山沿途"
  },
  {
    id: "drolma-la",
    title: "卓玛拉垭口",
    titleEn: "Drolma La Pass",
    desc: "海拔5630米的卓玛拉垭口是转山路线最高点。朝圣者在此抛撒经幡、留下衣物——象征放下过去的自己。经年累月，经幡铺满山隘。",
    descEn: "At 5,630 meters, Drolma La is the highest point of the kora. Pilgrims scatter lungta (prayer flags) and leave clothing — symbolizing the shedding of the old self. The pass is carpeted with years of prayer flags.",
    image: "kailash-sunrise.webp",
    location: "卓玛拉垭口·转山最高点"
  },
  {
    id: "manasarovar-lake",
    title: "玛旁雍错",
    titleEn: "Lake Manasarovar",
    desc: "冈仁波齐以南的玛旁雍错，世界海拔最高的淡水湖之一。印度教称其为「玛那莎之湖」——梵天意念所化。湖面海拔4588米，冬季冰封，夏季碧蓝如镜。",
    descEn: "South of Kailash lies Manasarovar, among the world's highest freshwater lakes. Hindus call it 'the lake born from Brahma's mind.' At 4,588m, it freezes in winter and gleams turquoise in summer.",
    image: "kailash-lake.webp",
    location: "普兰县·冈仁波齐以南"
  },
  {
    id: "pilgrim-prostration",
    title: "磕长头的朝圣者",
    titleEn: "Prostrating Pilgrims",
    desc: "转山路上，藏族朝圣者以全身伏地的方式前行——每一步都用身体丈量。转山一圈等于念诵六字真言六亿遍。这不是徒步，是修行。",
    descEn: "On the kora route, Tibetan pilgrims advance by full-body prostration — measuring every step with their entire being. One circuit equals 600 million mantra recitations. This is not trekking; this is practice.",
    image: "kailash-prairie.webp",
    location: "转山沿途"
  },
  {
    id: "drirapuk",
    title: "止热寺",
    titleEn: "Drirapuk Monastery",
    desc: "转山第一天宿营点。海拔5080米，正对冈仁波齐北壁。传说米拉日巴曾在此修行——寺院岩壁上至今留有他的手印和头印。",
    descEn: "Day 1 campsite of the kora. At 5,080m, it faces Kailash's north wall directly. Legend holds that Milarepa practiced here — his hand and head prints remain visible on the monastery rock face.",
    image: "kailash-yaks.webp",
    location: "止热寺·转山第一天"
  },
  {
    id: "prayer-flags",
    title: "经幡与风马",
    titleEn: "Lungta: Wind Horses",
    desc: "风马旗（藏语称「隆达」）在高原劲风中猎猎作响。五色——蓝白红绿黄——分别对应天、云、火、水、土。每一次风吹动经幡，等于念诵一遍经文。",
    descEn: "Lungta (wind-horse flags) snap in the plateau wind. Five colors — blue, white, red, green, yellow — correspond to sky, cloud, fire, water, earth. Each flutter equals one prayer recited.",
    image: "kailash-birds.webp",
    location: "转山沿途·各垭口"
  },
  {
    id: "mani-stones",
    title: "玛尼堆",
    titleEn: "Mani Stone Mounds",
    desc: "刻有六字真言的石板层层堆叠，是藏传佛教最朴素的信仰表达。朝圣者每路过一个玛尼堆，便顺时针绕行三圈，添上一块石子。",
    descEn: "Slate slabs carved with the six-syllable mantra, stacked layer upon layer — the humblest expression of Tibetan Buddhist faith. Pilgrims circumambulate each mound three times clockwise, adding a stone.",
    image: "kailash-trek-map.webp",
    location: "转山沿途"
  },
  {
    id: "darchen-town",
    title: "塔尔钦镇",
    titleEn: "Darchen: The Pilgrim's Gateway",
    desc: "转山的起点与终点。海拔4675米，世界最高的小镇之一。每年5-10月，来自印度、尼泊尔、中国及世界各地的朝圣者在此聚集，准备踏上52公里的神圣旅程。",
    descEn: "Start and end point of the kora. At 4,675m, among the world's highest towns. Each year from May to October, pilgrims from India, Nepal, China, and beyond gather here to begin the 52km sacred circuit.",
    image: "kailash-prairie.webp",
    location: "塔尔钦镇·转山起点"
  },
  {
    id: "kora-path",
    title: "转山路",
    titleEn: "The Kora Path",
    desc: "52公里的土路，无铺装、无车道。海拔在4675至5630米之间起伏。碎石、泥泞、经幡和玛尼堆——这就是通往信仰的道路最真实的模样。",
    descEn: "52 kilometers of dirt path. No pavement. No vehicle access. Altitude swings between 4,675 and 5,630 meters. Gravel, mud, prayer flags, and mani stones — this is what the path of faith actually looks like.",
    image: "kailash-aerial.webp",
    location: "转山路线全程"
  }
];
---

<Layout title="神山影像 - 冈仁波齐写实记录" description="用写实照片客观记录冈仁波齐：金山日出、转山路、玛旁雍错、朝圣者、经幡、玛尼堆——不渲染，只呈现神山的真实面貌。">
  <!-- Hero Section -->
  <section class="relative h-[70vh] min-h-[500px] flex items-end">
    <div class="absolute inset-0 bg-[url('/images/kailash-golden.webp')] bg-cover bg-center"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-kailash-dark via-kailash-dark/50 to-transparent"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 w-full">
      <p class="text-kailash-gold text-sm tracking-[0.3em] uppercase mb-2 font-light" data-lang-content="zh">写实影像 · 不渲染 · 不加工</p>
      <p class="text-kailash-gold text-sm tracking-[0.3em] uppercase mb-2 font-light" data-lang-content="en" style="display: none;">Documentary · Unembellished · Real</p>
      <h1 class="font-display text-5xl md:text-7xl font-bold text-white mb-4" data-lang-content="zh">神山影像</h1>
      <h1 class="font-display text-5xl md:text-7xl font-bold text-white mb-4" data-lang-content="en" style="display: none;">Kailash Through the Lens</h1>
      <p class="text-xl text-white/70 max-w-3xl" data-lang-content="zh">
        用镜头客观记录冈仁波齐的真实面貌——日出、转山路、朝圣者、圣湖。没有滤镜，只有事实。
      </p>
      <p class="text-xl text-white/70 max-w-3xl" data-lang-content="en" style="display: none;">
        An objective photographic record of Mount Kailash — dawn light, the kora path, pilgrims, the sacred lake. No filters. Just facts.
      </p>
    </div>
  </section>

  <!-- Introduction -->
  <section class="py-16 bg-kailash-dark text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-4 gap-8 text-center">
        <div class="p-6">
          <div class="text-4xl mb-3">🏔️</div>
          <div class="text-kailash-gold text-2xl font-bold">6656m</div>
          <p class="text-gray-400 text-sm mt-1" data-lang-content="zh">冈仁波齐海拔</p>
          <p class="text-gray-400 text-sm mt-1" data-lang-content="en" style="display: none;">Peak Elevation</p>
        </div>
        <div class="p-6">
          <div class="text-4xl mb-3">🚶</div>
          <div class="text-kailash-gold text-2xl font-bold">52km</div>
          <p class="text-gray-400 text-sm mt-1" data-lang-content="zh">转山全程</p>
          <p class="text-gray-400 text-sm mt-1" data-lang-content="en" style="display: none;">Kora Distance</p>
        </div>
        <div class="p-6">
          <div class="text-4xl mb-3">⛰️</div>
          <div class="text-kailash-gold text-2xl font-bold">5630m</div>
          <p class="text-gray-400 text-sm mt-1" data-lang-content="zh">卓玛拉垭口</p>
          <p class="text-gray-400 text-sm mt-1" data-lang-content="en" style="display: none;">Drolma La Pass</p>
        </div>
        <div class="p-6">
          <div class="text-4xl mb-3">📿</div>
          <div class="text-kailash-gold text-2xl font-bold">4</div>
          <p class="text-gray-400 text-sm mt-1" data-lang-content="zh">宗教共同圣地</p>
          <p class="text-gray-400 text-sm mt-1" data-lang-content="en" style="display: none;">Sacred Traditions</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Photo Wall - Full Width Masonry -->
  <section class="py-20 bg-kailash-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4" data-lang-content="zh">📸 神山影像</h2>
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4" data-lang-content="en" style="display: none;">📸 Kailash in Photographs</h2>
        <p class="text-gray-600 max-w-2xl mx-auto" data-lang-content="zh">
          写实照片，客观记录。不美化，不渲染——只呈现冈仁波齐和朝圣之路的真实面貌。
        </p>
        <p class="text-gray-600 max-w-2xl mx-auto" data-lang-content="en" style="display: none;">
          Documentary photography. No embellishment. No dramatization — just Kailash and the pilgrimage path as they really are.
        </p>
      </div>

      <!-- Alternating Photo Layout -->
      <div class="space-y-20">
        {culturePhotos.map((photo, index) => (
          <div class="group">
            <!-- Large Photo -->
            <div class={`relative overflow-hidden rounded-2xl ${index % 2 === 0 ? 'lg:ml-16' : 'lg:mr-16'}`}>
              <div class="aspect-[16/9] md:aspect-[21/9] bg-gray-200 relative">
                <img 
                  src={`/images/${photo.image}`}
                  alt={photo.title}
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                  loading={index < 3 ? 'eager' : 'lazy'}
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent"></div>
                
                <!-- Photo Info Overlay -->
                <div class="absolute bottom-0 left-0 right-0 p-8 md:p-12">
                  <span class="inline-block bg-kailash-gold/90 text-kailash-dark text-xs px-3 py-1 rounded-full mb-3 font-medium">
                    {photo.location}
                  </span>
                  <h3 class="text-white font-display text-3xl md:text-4xl font-bold mb-2" data-lang-content="zh">{photo.title}</h3>
                  <h3 class="text-white font-display text-3xl md:text-4xl font-bold mb-2" data-lang-content="en" style="display: none;">{photo.titleEn}</h3>
                  <p class="text-white/80 text-base md:text-lg max-w-2xl" data-lang-content="zh">{photo.desc}</p>
                  <p class="text-white/80 text-base md:text-lg max-w-2xl" data-lang-content="en" style="display: none;">{photo.descEn}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quote Section -->
  <section class="py-24 bg-kailash-dark text-white relative overflow-hidden">
    <div class="absolute inset-0 bg-[url('/images/kailash-aerial.webp')] bg-cover bg-center opacity-10"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <svg class="w-12 h-12 text-kailash-gold/50 mx-auto mb-6" fill="currentColor" viewBox="0 0 32 32">
        <path d="M10 8c-3.3 0-6 2.7-6 6v10h10V14H8c0-1.1.9-2 2-2V8zm16 0c-3.3 0-6 2.7-6 6v10h10V14h-6c0-1.1.9-2 2-2V8z"/>
      </svg>
      <blockquote class="font-display text-2xl md:text-3xl italic text-white/80 leading-relaxed" data-lang-content="zh">
        "照片不会说谎。<br>冈仁波齐就在那里——<br>不是滤镜里的神山，是海拔6656米的真实存在。"
      </blockquote>
      <blockquote class="font-display text-2xl md:text-3xl italic text-white/80 leading-relaxed" data-lang-content="en" style="display: none;">
        "Photographs don't lie.<br>Kailash is there — <br>not a filtered fantasy, but a real mountain at 6,656 meters."
      </blockquote>
    </div>
  </section>

  <!-- Topics Grid -->
  <section class="py-20 bg-kailash-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4" data-lang-content="zh">冈仁波齐·四大元素</h2>
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4" data-lang-content="en" style="display: none;">Kailash · Four Elements</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="aspect-square relative overflow-hidden rounded-xl group cursor-pointer bg-gradient-to-br from-amber-900 to-kailash-dark">
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="text-center p-4">
              <span class="text-5xl block mb-3">🕉️</span>
              <h3 class="text-white font-bold text-lg" data-lang-content="zh">印度教</h3>
              <h3 class="text-white font-bold text-lg" data-lang-content="en" style="display: none;">Hinduism</h3>
              <p class="text-white/60 text-sm mt-1" data-lang-content="zh">湿婆的宝座</p>
              <p class="text-white/60 text-sm mt-1" data-lang-content="en" style="display: none;">Shiva's Abode</p>
            </div>
          </div>
        </div>
        <div class="aspect-square relative overflow-hidden rounded-xl group cursor-pointer bg-gradient-to-br from-indigo-900 to-kailash-dark">
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="text-center p-4">
              <span class="text-5xl block mb-3">📿</span>
              <h3 class="text-white font-bold text-lg" data-lang-content="zh">藏传佛教</h3>
              <h3 class="text-white font-bold text-lg" data-lang-content="en" style="display: none;">Tibetan Buddhism</h3>
              <p class="text-white/60 text-sm mt-1" data-lang-content="zh">胜乐金刚坛城</p>
              <p class="text-white/60 text-sm mt-1" data-lang-content="en" style="display: none;">Chakrasamvara Mandala</p>
            </div>
          </div>
        </div>
        <div class="aspect-square relative overflow-hidden rounded-xl group cursor-pointer bg-gradient-to-br from-emerald-900 to-kailash-dark">
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="text-center p-4">
              <span class="text-5xl block mb-3">卍</span>
              <h3 class="text-white font-bold text-lg" data-lang-content="zh">苯教</h3>
              <h3 class="text-white font-bold text-lg" data-lang-content="en" style="display: none;">Bön</h3>
              <p class="text-white/60 text-sm mt-1" data-lang-content="zh">雍仲九层山</p>
              <p class="text-white/60 text-sm mt-1" data-lang-content="en" style="display: none;">Yungdrung Gutsek</p>
            </div>
          </div>
        </div>
        <div class="aspect-square relative overflow-hidden rounded-xl group cursor-pointer bg-gradient-to-br from-rose-900 to-kailash-dark">
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="text-center p-4">
              <span class="text-5xl block mb-3">☸️</span>
              <h3 class="text-white font-bold text-lg" data-lang-content="zh">耆那教</h3>
              <h3 class="text-white font-bold text-lg" data-lang-content="en" style="display: none;">Jainism</h3>
              <p class="text-white/60 text-sm mt-1" data-lang-content="zh">勒舍波解脱地</p>
              <p class="text-white/60 text-sm mt-1" data-lang-content="en" style="display: none;">Ashtapada</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-kailash-dark text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-3xl font-bold mb-4" data-lang-content="zh">分享你的冈仁波齐影像</h2>
      <h2 class="font-display text-3xl font-bold mb-4" data-lang-content="en" style="display: none;">Share Your Kailash Photographs</h2>
      <p class="text-gray-400 mb-8" data-lang-content="zh">如果你有冈仁波齐的真实照片——写实风格、无滤镜处理——欢迎投稿。每张照片署名。</p>
      <p class="text-gray-400 mb-8" data-lang-content="en" style="display: none;">If you have documentary-style photos of Kailash — unembellished, unfiltered — please submit. Every photo is credited.</p>
      <a href="mailto:kailash2026Lucas@outlook.com?subject=冈仁波齐照片投稿" class="inline-flex items-center gap-2 bg-kailash-gold text-kailash-dark px-8 py-3 rounded-lg font-semibold hover:bg-kailash-accent transition" data-lang-content="zh">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
        </svg>
        投稿照片
      </a>
      <a href="mailto:kailash2026Lucas@outlook.com?subject=Kailash Photo Submission" class="inline-flex items-center gap-2 bg-kailash-gold text-kailash-dark px-8 py-3 rounded-lg font-semibold hover:bg-kailash-accent transition" data-lang-content="en" style="display: none;">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
        </svg>
        Submit Photos
      </a>
    </div>
  </section>
</Layout>

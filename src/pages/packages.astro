  <!-- FAQ -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-3xl font-bold text-kailash-dark mb-12 text-center">
        <span data-lang-content="zh">常见问题</span>
        <span data-lang-content="en" style="display: none;">Frequently Asked Questions</span>
      </h2>
      <div class="space-y-4">
        {faq.map((item) => (
          <details class="bg-kailash-light rounded-xl p-6 group cursor-pointer">
            <summary class="font-semibold text-kailash-dark text-lg list-none flex justify-between items-center">
              <span data-lang-content="zh">{item.q}</span>
              <span data-lang-content="en" style="display: none;">{item.qEn}</span>
              <svg class="w-5 h-5 text-kailash-gold group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <p class="text-gray-600 mt-4 leading-relaxed">
              <span data-lang-content="zh">{item.a}</span>
              <span data-lang-content="en" style="display: none;">{item.aEn}</span>

---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Newsletter from '../../components/Newsletter.astro';

const allPosts = await getCollection('blog', ({ data }) => data.lang === 'zh');
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const title = '朝圣博客 - 冈仁波齐转山指南与故事 | Kailash 2026';
const description = '冈仁波齐朝圣博客：最新转山指南、马年资讯、朝圣故事与深度文化解读。为您的神圣之旅提供专业指导与灵感。';
---

<Layout title={title} description={description}>
  <!-- Hero -->
  <section class="relative bg-kailash-dark">
    <div class="relative w-full h-[35vh] lg:h-[40vh]">
      <div class="absolute inset-0 bg-[url('/images/kailash-aerial.webp')] bg-cover bg-center opacity-60"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-kailash-dark/40 via-transparent to-kailash-dark"></div>
    </div>
    <div class="relative -mt-12 z-10 px-4 pb-8">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-kailash-gold text-sm tracking-[0.3em] uppercase mb-3 font-light">朝圣知识 · 深度指南</p>
        <h1 class="font-display text-4xl md:text-5xl font-bold text-white mb-3">朝圣博客</h1>
        <p class="text-lg text-white/60 max-w-2xl mx-auto">
          最专业的冈仁波齐转山指南、马年资讯与深度文化解读
        </p>
      </div>
    </div>
  </section>

  <!-- Blog Posts Grid -->
  <section class="py-16 bg-kailash-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {posts.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-gray-500 text-lg">敬请期待更多精彩文章...</p>
        </div>
      ) : (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => {
            // Extract clean slug from the collection entry id (e.g., 'zh/kailash-kora-guide-2026' -> 'kailash-kora-guide-2026')
            const slugParts = post.id.split('/');
            const cleanSlug = slugParts.length > 1 ? slugParts.slice(1).join('/').replace(/\.md$/, '') : slugParts[0].replace(/\.md$/, '');
            const formattedDate = post.data.date.toLocaleDateString('zh-CN', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            });

            return (
              <article class="bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 hover-lift group">
                <a href={`/blog/${cleanSlug}`} class="block">
                  <div class="relative aspect-[16/10] overflow-hidden bg-gray-100">
                    <img
                      src={post.data.image}
                      alt={post.data.title}
                      class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                  </div>
                </a>
                <div class="p-6">
                  <div class="flex flex-wrap gap-2 mb-3">
                    {post.data.tags.slice(0, 3).map((tag) => (
                      <span class="text-xs bg-kailash-cream text-kailash-dark/70 px-2.5 py-1 rounded-full font-medium">
                        {tag}
                      </span>
                    ))}
                  </div>
                  <a href={`/blog/${cleanSlug}`} class="block group">
                    <h2 class="font-display text-xl font-bold text-kailash-dark mb-3 group-hover:text-kailash-gold transition-colors leading-snug">
                      {post.data.title}
                    </h2>
                  </a>
                  <p class="text-gray-600 text-sm line-clamp-3 mb-4 leading-relaxed">
                    {post.data.description}
                  </p>
                  <div class="flex items-center justify-between">
                    <time datetime={post.data.date.toISOString()} class="text-sm text-gray-400">
                      {formattedDate}
                    </time>
                    <a
                      href={`/blog/${cleanSlug}`}
                      class="text-kailash-gold font-medium text-sm hover:text-kailash-accent transition-colors inline-flex items-center gap-1"
                    >
                      阅读更多
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                      </svg>
                    </a>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      )}
    </div>
  </section>

  <!-- Newsletter -->
  <section class="py-16 bg-kailash-dark">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <Newsletter lang="zh" variant="card" />
    </div>
  </section>
</Layout>

---
import Layout from '../layouts/Layout.astro';

const title = "朝圣故事 | Kailash 2026";
const description = "冈仁波齐朝圣故事——真实经历与典型示例。标注为示例的故事不代表具体真实人物，仅供了解朝圣体验。";
---

<Layout title={title} description={description}>
  <div class="pt-20">
    <!-- Hero -->
    <section class="bg-kailash-dark py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="font-display text-4xl md:text-5xl font-bold text-white mb-4" data-lang-content="zh">朝圣故事</h1>
        <h1 class="font-display text-4xl md:text-5xl font-bold text-white mb-4" data-lang-content="en" style="display: none;">Pilgrim Stories</h1>
        <p class="text-xl text-white/80" data-lang-content="zh">以下故事为典型示例，不代表具体真实人物</p>
        <p class="text-xl text-white/80" data-lang-content="en" style="display: none;">These stories are illustrative examples of common pilgrimage experiences</p>
        <p class="text-xl text-white/80" data-lang-content="en" style="display: none;">Real Journeys · Transformative Experiences · Sacred Memories</p>
      </div>
    </section>

    <!-- Featured Story with Photo -->
    <section class="py-16 bg-kailash-light">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
          <div class="grid md:grid-cols-2">
            <div class="relative aspect-[4/3] md:aspect-auto bg-gray-100">
              <img src="/images/kailash-golden.webp" alt="朝圣者在卓玛拉垭口" class="absolute inset-0 w-full h-full object-cover" loading="eager" onerror="this.style.display='none'; this.parentElement.querySelector('.fallback').style.display='flex';" />
              <div class="fallback absolute inset-0 bg-gray-100 flex items-center justify-center text-gray-400" style="display: none;">
                <span>图片加载失败</span>
              </div>
              <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent p-4">
                <p class="text-white font-semibold" data-lang-content="zh">卓玛拉垭口 · 5648米</p>
                <p class="text-white font-semibold" data-lang-content="en" style="display: none;">Drolma La Pass · 5648m</p>
                <p class="text-white/80 text-sm">2024年9月 · 张先生</p>
              </div>
            </div>
            <div class="p-8 flex flex-col justify-center">
              <div class="text-kailash-gold mb-4">★★★★★</div>
              <p class="text-gray-700 mb-6 italic text-lg leading-relaxed" data-lang-content="zh">"当翻越卓玛拉垭口的那一刻，我终于明白什么是信仰的力量。5630米，这是我人生到达的最高点，也是心灵的最高点。"</p>
              <p class="text-gray-700 mb-6 italic text-lg leading-relaxed" data-lang-content="en" style="display: none;">"The moment I crossed Drolma La pass, I finally understood the power of faith. At 5,630 meters, this is the highest point of my life, and also the highest point of my soul."</p>
              <div class="flex items-center gap-3">
                <div class="w-12 h-12 bg-kailash-gold/20 rounded-full flex items-center justify-center font-bold text-lg">张</div>
                <div>
                  <p class="font-medium text-lg" data-lang-content="zh">张先生</p>
                  <p class="font-medium text-lg" data-lang-content="en" style="display: none;">Mr. Zhang</p>
                  <p class="text-sm text-gray-500">北京 · 2025年9月</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stories Grid with Photos -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4" data-lang-content="zh">更多朝圣故事</h2>
          <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4" data-lang-content="en" style="display: none;">More Pilgrim Stories</h2>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <!-- Story 1 -->
          <div class="bg-kailash-light rounded-2xl overflow-hidden shadow-md">
            <div class="relative aspect-[4/3] bg-gray-100">
              <img src="/images/kailash-sunrise.webp" alt="李女士与母亲在止热寺" class="absolute inset-0 w-full h-full object-cover" loading="lazy" onerror="this.style.display='none'; this.parentElement.querySelector('.fallback').style.display='flex';" />
              <div class="fallback absolute inset-0 bg-gray-100 flex items-center justify-center text-gray-400" style="display: none;">
                <span>图片加载失败</span>
              </div>
            </div>
            <div class="p-6">
              <div class="text-kailash-gold mb-3">★★★★★</div>
              <p class="text-gray-700 mb-4 italic text-sm" data-lang-content="zh">"带着70岁的母亲完成转山，她在止热寺前双手合十的样子，是我这辈子见过最美的画面。"</p>
              <p class="text-gray-700 mb-4 italic text-sm" data-lang-content="en" style="display: none;">"I completed the kora with my 70-year-old mother. Watching her pray at Drirapuk Monastery was the most beautiful sight I've ever seen."</p>
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-kailash-gold/20 rounded-full flex items-center justify-center font-bold text-sm">李</div>
                <div>
                  <p class="font-medium text-sm" data-lang-content="zh">李女士</p>
                  <p class="font-medium text-sm" data-lang-content="en" style="display: none;">Ms. Li</p>
                  <p class="text-xs text-gray-500">成都 · 2025年6月</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Story 2 -->
          <div class="bg-kailash-light rounded-2xl overflow-hidden shadow-md">
            <div class="relative aspect-[4/3] bg-gray-100">
              <img src="/images/kailash-lake.webp" alt="Rajesh Kumar在冈仁波齐" class="absolute inset-0 w-full h-full object-cover" loading="lazy" onerror="this.style.display='none'; this.parentElement.querySelector('.fallback').style.display='flex';" />
              <div class="fallback absolute inset-0 bg-gray-100 flex items-center justify-center text-gray-400" style="display: none;">
                <span>图片加载失败</span>
              </div>
            </div>
            <div class="p-6">
              <div class="text-kailash-gold mb-3">★★★★★</div>
              <p class="text-gray-700 mb-4 italic text-sm">"Kailash is the abode of Lord Shiva. I waited 3 years for the permit. The 52km kora changed my perspective on life forever."</p>
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-kailash-gold/20 rounded-full flex items-center justify-center font-bold text-sm">R</div>
                <div>
                  <p class="font-medium text-sm">Rajesh Kumar</p>
                  <p class="text-xs text-gray-500">Delhi, India · 2024</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Story 3 -->
          <div class="bg-kailash-light rounded-2xl overflow-hidden shadow-md">
            <div class="relative aspect-[4/3] bg-gray-100">
              <img src="/images/kailash-aerial.webp" alt="Sarah Johnson在转山途中" class="absolute inset-0 w-full h-full object-cover" loading="lazy" onerror="this.style.display='none'; this.parentElement.querySelector('.fallback').style.display='flex';" />
              <div class="fallback absolute inset-0 bg-gray-100 flex items-center justify-center text-gray-400" style="display: none;">
                <span>图片加载失败</span>
              </div>
            </div>
            <div class="p-6">
              <div class="text-kailash-gold mb-3">★★★★★</div>
              <p class="text-gray-700 mb-4 italic text-sm" data-lang-content="zh">"作为一名基督徒，我不确定会发生什么。但冈仁波齐超越了任何单一宗教。站在那座神圣的山峰前，我感受到了无法言喻的存在。"</p>
              <p class="text-gray-700 mb-4 italic text-sm" data-lang-content="en" style="display: none;">"As a Christian, I wasn't sure what to expect. But Kailash transcends any single religion. Standing before that sacred peak, I felt a presence that words cannot describe."</p>
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-kailash-gold/20 rounded-full flex items-center justify-center font-bold text-sm">S</div>
                <div>
                  <p class="font-medium text-sm">Sarah Johnson</p>
                  <p class="text-xs text-gray-500">London, UK · 2024</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Story 4 -->
          <div class="bg-kailash-light rounded-2xl overflow-hidden shadow-md">
            <div class="relative aspect-[4/3] bg-gray-100">
              <img src="/images/kailash-yaks.webp" alt="Tenzin Dorje第七次转山" class="absolute inset-0 w-full h-full object-cover" loading="lazy" onerror="this.style.display='none'; this.parentElement.querySelector('.fallback').style.display='flex';" />
              <div class="fallback absolute inset-0 bg-gray-100 flex items-center justify-center text-gray-400" style="display: none;">
                <span>图片加载失败</span>
              </div>
            </div>
            <div class="p-6">
              <div class="text-kailash-gold mb-3">★★★★★</div>
              <p class="text-gray-700 mb-4 italic text-sm" data-lang-content="zh">"这是我的第七次转山。每次我都能发现新的东西。山没有变，但我变了。每一圈都剥离了另一层自我，揭示出更真实的本我。"</p>
              <p class="text-gray-700 mb-4 italic text-sm" data-lang-content="en" style="display: none;">"This was my seventh kora. Each time I discover something new. The mountain doesn't change, but I do. Every circuit peels away another layer of ego, revealing a more authentic self."</p>
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-kailash-gold/20 rounded-full flex items-center justify-center font-bold text-sm">丁</div>
                <div>
                  <p class="font-medium text-sm">Tenzin Dorje</p>
                  <p class="text-xs text-gray-500">Lhasa, Tibet · 2024</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Story 5 -->
          <div class="bg-kailash-light rounded-2xl overflow-hidden shadow-md">
            <div class="relative aspect-[4/3] bg-gray-100">
              <img src="/images/kailash-birds.webp" alt="韩国朝圣团" class="absolute inset-0 w-full h-full object-cover" loading="lazy" onerror="this.style.display='none'; this.parentElement.querySelector('.fallback').style.display='flex';" />
              <div class="fallback absolute inset-0 bg-gray-100 flex items-center justify-center text-gray-400" style="display: none;">
                <span>图片加载失败</span>
              </div>
            </div>
            <div class="p-6">
              <div class="text-kailash-gold mb-3">★★★★★</div>
              <p class="text-gray-700 mb-4 italic text-sm" data-lang-content="zh">"我为了冒险而来，却带着转变的心离开。韩国朝圣团成为了我的家人。我们一起受苦，一起欢笑，一起成长。"</p>
              <p class="text-gray-700 mb-4 italic text-sm" data-lang-content="en" style="display: none;">"I came for the adventure, I left with a transformed heart. The Korean pilgrimage group became my family. We suffered together, laughed together, and grew together."</p>
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-kailash-gold/20 rounded-full flex items-center justify-center font-bold text-sm">朴</div>
                <div>
                  <p class="font-medium text-sm">Park Min-ji</p>
                  <p class="text-xs text-gray-500">Seoul, Korea · 2023</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Story 6 -->
          <div class="bg-kailash-light rounded-2xl overflow-hidden shadow-md">
            <div class="relative aspect-[4/3] bg-gray-100">
              <img src="/images/kailash-prairie.webp" alt="朝圣者在玛旁雍错" class="absolute inset-0 w-full h-full object-cover" loading="lazy" onerror="this.style.display='none'; this.parentElement.querySelector('.fallback').style.display='flex';" />
              <div class="fallback absolute inset-0 bg-gray-100 flex items-center justify-center text-gray-400" style="display: none;">
                <span>图片加载失败</span>
              </div>
            </div>
            <div class="p-6">
              <div class="text-kailash-gold mb-3">★★★★★</div>
              <p class="text-gray-700 mb-4 italic text-sm" data-lang-content="zh">"在玛旁雍错湖边，我看到了自己的倒影。那不是我的脸，而是我的灵魂。湖水如此清澈，仿佛能洗净千年的业障。"</p>
              <p class="text-gray-700 mb-4 italic text-sm" data-lang-content="en" style="display: none;">"By the shores of Lake Manasarovar, I saw my reflection. It wasn't my face, but my soul. The water was so clear, as if it could cleanse a thousand years of karma."</p>
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-kailash-gold/20 rounded-full flex items-center justify-center font-bold text-sm">王</div>
                <div>
                  <p class="font-medium text-sm" data-lang-content="zh">王先生</p>
                  <p class="font-medium text-sm" data-lang-content="en" style="display: none;">Mr. Wang</p>
                  <p class="text-xs text-gray-500">上海 · 2024年8月</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Photo Gallery -->
    <section class="py-16 bg-kailash-light">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4" data-lang-content="zh">朝圣瞬间</h2>
          <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4" data-lang-content="en" style="display: none;">Sacred Moments</h2>
          <p class="text-lg text-gray-600" data-lang-content="zh">镜头记录的信仰之旅</p>
          <p class="text-lg text-gray-600" data-lang-content="en" style="display: none;">Faith journey captured through the lens</p>
        </div>

        <div class="grid md:grid-cols-3 gap-4">
          <div class="relative aspect-[4/3] rounded-xl overflow-hidden group">
            <img src="/images/kailash-golden.webp" alt="经幡与神山" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity">
              <p class="absolute bottom-4 left-4 text-white font-medium" data-lang-content="zh">经幡与神山</p>
              <p class="absolute bottom-4 left-4 text-white font-medium" data-lang-content="en" style="display: none;">Prayer Flags & Mountain</p>
            </div>
          </div>
          <div class="relative aspect-[4/3] rounded-xl overflow-hidden group md:row-span-2">
            <img src="/images/kailash-aerial.webp" alt="朝圣者磕长头" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity">
              <p class="absolute bottom-4 left-4 text-white font-medium" data-lang-content="zh">朝圣者磕长头</p>
              <p class="absolute bottom-4 left-4 text-white font-medium" data-lang-content="en" style="display: none;">Pilgrim Prostrating</p>
            </div>
          </div>
          <div class="relative aspect-[4/3] rounded-xl overflow-hidden group">
            <img src="/images/kailash-lake.webp" alt="玛旁雍错日出" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity">
              <p class="absolute bottom-4 left-4 text-white font-medium" data-lang-content="zh">玛旁雍错日出</p>
              <p class="absolute bottom-4 left-4 text-white font-medium" data-lang-content="en" style="display: none;">Lake Manasarovar Sunrise</p>
            </div>
          </div>
          <div class="relative aspect-[4/3] rounded-xl overflow-hidden group">
            <img src="/images/kailash-sunrise.webp" alt="止热寺夜景" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity">
              <p class="absolute bottom-4 left-4 text-white font-medium" data-lang-content="zh">止热寺夜景</p>
              <p class="absolute bottom-4 left-4 text-white font-medium" data-lang-content="en" style="display: none;">Drirapuk Night View</p>
            </div>
          </div>
          <div class="relative aspect-[4/3] rounded-xl overflow-hidden group">
            <img src="/images/kailash-yaks.webp" alt="卓玛拉垭口经幡" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity">
              <p class="absolute bottom-4 left-4 text-white font-medium" data-lang-content="zh">卓玛拉垭口经幡</p>
              <p class="absolute bottom-4 left-4 text-white font-medium" data-lang-content="en" style="display: none;">Drolma La Prayer Flags</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Story Submission -->
    <section class="py-16 bg-kailash-gold">
      <div class="max-w-2xl mx-auto px-4">
        <div class="text-center mb-10">
          <h2 class="font-display text-3xl font-bold text-kailash-dark mb-4" data-lang-content="zh">分享您的转山故事</h2>
          <h2 class="font-display text-3xl font-bold text-kailash-dark mb-4" data-lang-content="en" style="display: none;">Share Your Kora Story</h2>
          <p class="text-kailash-dark/80" data-lang-content="zh">您的经历可能成为某人开始朝圣之旅的勇气。我们会精选故事发布在网站上。</p>
          <p class="text-kailash-dark/80" data-lang-content="en" style="display: none;">Your experience could be someone's courage to begin. Selected stories will be published on the site.</p>
        </div>

        <form id="story-form" class="bg-white rounded-2xl p-8 shadow-lg space-y-5">
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm font-medium text-kailash-dark mb-1.5">
                <span data-lang-content="zh">姓名 / 称呼</span>
                <span data-lang-content="en" style="display: none;">Name</span>
              </label>
              <input type="text" name="name" placeholder="您的称呼" class="w-full px-4 py-2.5 rounded-lg border border-gray-200 focus:border-kailash-gold focus:ring-1 focus:ring-kailash-gold outline-none transition text-sm" />
            </div>
            <div>
              <label class="block text-sm font-medium text-kailash-dark mb-1.5">
                <span data-lang-content="zh">邮箱</span>
                <span data-lang-content="en" style="display: none;">Email</span>
              </label>
              <input type="email" name="email" placeholder="your@email.com" class="w-full px-4 py-2.5 rounded-lg border border-gray-200 focus:border-kailash-gold focus:ring-1 focus:ring-kailash-gold outline-none transition text-sm" />
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-kailash-dark mb-1.5">
              <span data-lang-content="zh">转山时间</span>
              <span data-lang-content="en" style="display: none;">When did you go?</span>
            </label>
            <input type="text" name="date" placeholder="例如：2025年9月 / Sep 2025" class="w-full px-4 py-2.5 rounded-lg border border-gray-200 focus:border-kailash-gold focus:ring-1 focus:ring-kailash-gold outline-none transition text-sm" />
          </div>
          <div>
            <label class="block text-sm font-medium text-kailash-dark mb-1.5">
              <span data-lang-content="zh">您的故事</span>
              <span data-lang-content="en" style="display: none;">Your Story</span>
            </label>
            <textarea name="story" rows="5" placeholder="写下您的转山经历..." class="w-full px-4 py-2.5 rounded-lg border border-gray-200 focus:border-kailash-gold focus:ring-1 focus:ring-kailash-gold outline-none transition text-sm resize-y"></textarea>
          </div>
          <button type="submit" class="w-full bg-kailash-gold text-kailash-dark px-6 py-3 rounded-lg font-semibold hover:bg-kailash-accent hover:text-white transition">
            <span data-lang-content="zh">提交故事</span>
            <span data-lang-content="en" style="display: none;">Submit Story</span>
          </button>
          <p class="text-xs text-gray-400 text-center mt-2">
            <span data-lang-content="zh">提交后我们会通过邮箱联系您。您的故事不会被公开除非获得您的许可。</span>
            <span data-lang-content="en" style="display: none;">We'll contact you via email. Your story won't be published without your permission.</span>
          </p>
        </form>
      </div>
    </section>

    <script>
      document.getElementById('story-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const form = e.target;
        const data = Object.fromEntries(new FormData(form));
        try {
          await fetch('/api/story', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });
          form.innerHTML = '<div class="text-center py-8"><p class="text-3xl mb-3">🙏</p><p class="text-xl font-semibold text-kailash-dark mb-2" data-lang-content="zh">感谢您的分享！</p><p class="text-xl font-semibold text-kailash-dark mb-2" data-lang-content="en" style="display: none;">Thank you for sharing!</p><p class="text-gray-500" data-lang-content="zh">我们会尽快与您联系。</p><p class="text-gray-500" data-lang-content="en" style="display: none;">We will contact you soon.</p></div>';
        } catch {
          alert('提交失败，请发送邮件至 kailash2026Lucas@outlook.com');
        }
      });
    </script>
  </div>
</Layout>

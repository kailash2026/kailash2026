---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="यात्रा गाइड - कैलाश पर्वत तीर्थयात्रा की सम्पूर्ण तैयारी | कैलाश 2026" description="कैलाश पर्वत तीर्थयात्रा की सम्पूर्ण गाइड: सर्वोत्तम समय, परमिट और दस्तावेज़, शारीरिक तैयारी, पैकिंग सूची, ऊँचाई बीमारी से बचाव, आवास, परिवहन, और लागत विवरण। हिन्दी में सम्पूर्ण जानकारी।">

  <!-- Hero Section -->
  <section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-[url('/images/kailash-golden.jpg')] bg-cover bg-center"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-kailash-dark/70 via-kailash-dark/50 to-kailash-dark"></div>

    <div class="relative z-10 text-center px-4 max-w-5xl mx-auto">
      <p class="text-kailash-gold text-sm md:text-base tracking-[0.3em] uppercase mb-4 font-light">
        सम्पूर्ण तैयारी · सुरक्षित यात्रा · आध्यात्मिक अनुभव
      </p>
      <h1 class="font-display text-5xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">
        यात्रा
        <span class="block text-kailash-gold mt-2">गाइड</span>
      </h1>
      <p class="text-xl md:text-2xl text-white/80 mb-4 max-w-3xl mx-auto font-light leading-relaxed">
        कैलाश पर्वत की पवित्र तीर्थयात्रा के लिए सम्पूर्ण तैयारी मार्गदर्शिका — परमिट से लेकर पैकिंग तक, हर प्रश्न का उत्तर
      </p>
      <p class="text-lg text-white/60 mb-8 max-w-2xl mx-auto">
        सर्वोत्तम समय · आवश्यक दस्तावेज़ · शारीरिक तैयारी · लागत अनुमान
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#samay" class="bg-kailash-gold text-kailash-dark px-8 py-4 rounded-lg font-semibold hover:bg-kailash-accent transition">
          तैयारी शुरू करें
        </a>
        <a href="#kharch" class="border-2 border-white/30 text-white px-8 py-4 rounded-lg font-semibold hover:bg-white/10 transition">
          लागत देखें
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="bg-kailash-dark py-8 border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <p class="text-3xl md:text-4xl font-bold text-kailash-gold">मई-अक्टूबर</p>
          <p class="text-white/60 text-sm mt-1">सर्वोत्तम समय</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold text-kailash-gold">4</p>
          <p class="text-white/60 text-sm mt-1">आवश्यक परमिट</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold text-kailash-gold">4,600m</p>
          <p class="text-white/60 text-sm mt-1">आधार ऊँचाई</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold text-kailash-gold">2-3 दिन</p>
          <p class="text-white/60 text-sm mt-1">अनुकूलन अवधि</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 2: Best Time to Visit -->
  <section id="samay" class="py-20 bg-kailash-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-kailash-gold text-sm tracking-[0.2em] uppercase mb-3 font-medium">यात्रा का समय</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold text-kailash-dark mb-4">कैलाश यात्रा का सर्वोत्तम समय</h2>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto">कैलाश पर्वत की तीर्थयात्रा के लिए मई से अक्टूबर तक का समय सर्वोत्तम है। सर्दियों में दर्रे बर्फ़ से बंद हो जाते हैं और यात्रा असंभव हो जाती है। सही महीने का चयन आपकी यात्रा को सुरक्षित और आनंददायक बनाता है।</p>
      </div>

      <!-- Monthly Breakdown Cards -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- May -->
        <div class="bg-white rounded-2xl p-6 shadow-md hover:shadow-xl transition border-t-4 border-green-400">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center text-2xl">🌱</div>
            <div>
              <h3 class="font-display text-xl font-bold text-kailash-dark">मई</h3>
              <p class="text-green-600 text-sm font-medium">मौसम की शुरुआत</p>
            </div>
          </div>
          <div class="space-y-2 text-sm text-gray-600">
            <div class="flex justify-between"><span>दिन का तापमान</span><span class="font-semibold">5°C – 12°C</span></div>
            <div class="flex justify-between"><span>रात का तापमान</span><span class="font-semibold">-8°C – 0°C</span></div>
            <div class="flex justify-between"><span>वर्षा</span><span class="font-semibold">कम</span></div>
            <div class="flex justify-between"><span>भीड़</span><span class="font-semibold text-green-600">कम</span></div>
          </div>
          <p class="text-gray-600 text-sm mt-4 leading-relaxed">मौसम की शुरुआत। सागा दावा उत्सव (बुद्ध पूर्णिमा) का पवित्र समय। बर्फ़ पिघल रही होती है, दर्रा अभी-अभी खुलता है। कम भीड़, शांत वातावरण। ठंड के लिए तैयार रहें।</p>
          <div class="mt-4 flex gap-2">
            <span class="bg-green-50 text-green-700 px-3 py-1 rounded-full text-xs">सागा दावा</span>
            <span class="bg-green-50 text-green-700 px-3 py-1 rounded-full text-xs">कम भीड़</span>
          </div>
        </div>

        <!-- June -->
        <div class="bg-white rounded-2xl p-6 shadow-md hover:shadow-xl transition border-t-4 border-blue-400">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center text-2xl">☀️</div>
            <div>
              <h3 class="font-display text-xl font-bold text-kailash-dark">जून</h3>
              <p class="text-blue-600 text-sm font-medium">उत्तम समय</p>
            </div>
          </div>
          <div class="space-y-2 text-sm text-gray-600">
            <div class="flex justify-between"><span>दिन का तापमान</span><span class="font-semibold">8°C – 16°C</span></div>
            <div class="flex justify-between"><span>रात का तापमान</span><span class="font-semibold">-4°C – 4°C</span></div>
            <div class="flex justify-between"><span>वर्षा</span><span class="font-semibold">कम-मध्यम</span></div>
            <div class="flex justify-between"><span>भीड़</span><span class="font-semibold text-blue-600">मध्यम</span></div>
          </div>
          <p class="text-gray-600 text-sm mt-4 leading-relaxed">सबसे अच्छे महीनों में से एक। दिन लंबे और अपेक्षाकृत गर्म। आकाश साफ़, कैलाश के दर्शन के लिए उत्तम। सागा दावा का उत्सव जारी रह सकता है।</p>
          <div class="mt-4 flex gap-2">
            <span class="bg-blue-50 text-blue-700 px-3 py-1 rounded-full text-xs">साफ़ आकाश</span>
            <span class="bg-blue-50 text-blue-700 px-3 py-1 rounded-full text-xs">लंबे दिन</span>
          </div>
        </div>

        <!-- July -->
        <div class="bg-white rounded-2xl p-6 shadow-md hover:shadow-xl transition border-t-4 border-amber-400">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center text-2xl">🌤️</div>
            <div>
              <h3 class="font-display text-xl font-bold text-kailash-dark">जुलाई</h3>
              <p class="text-amber-600 text-sm font-medium">गर्म महीना</p>
            </div>
          </div>
          <div class="space-y-2 text-sm text-gray-600">
            <div class="flex justify-between"><span>दिन का तापमान</span><span class="font-semibold">10°C – 18°C</span></div>
            <div class="flex justify-between"><span>रात का तापमान</span><span class="font-semibold">-2°C – 6°C</span></div>
            <div class="flex justify-between"><span>वर्षा</span><span class="font-semibold">मध्यम-अधिक</span></div>
            <div class="flex justify-between"><span>भीड़</span><span class="font-semibold text-amber-600">अधिक</span></div>
          </div>
          <p class="text-gray-600 text-sm mt-4 leading-relaxed">सबसे गर्म महीना। लेकिन मानसून का प्रभाव — बारिश और कीचड़ संभव। जलरोधक उपकरण आवश्यक। भारतीय तीर्थयात्रियों की भीड़ अधिक होती है।</p>
          <div class="mt-4 flex gap-2">
            <span class="bg-amber-50 text-amber-700 px-3 py-1 rounded-full text-xs">सबसे गर्म</span>
            <span class="bg-amber-50 text-amber-700 px-3 py-1 rounded-full text-xs">वर्षा संभव</span>
          </div>
        </div>

        <!-- August -->
        <div class="bg-white rounded-2xl p-6 shadow-md hover:shadow-xl transition border-t-4 border-teal-400">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 bg-teal-100 rounded-full flex items-center justify-center text-2xl">🌦️</div>
            <div>
              <h3 class="font-display text-xl font-bold text-kailash-dark">अगस्त</h3>
              <p class="text-teal-600 text-sm font-medium">व्यस्त समय</p>
            </div>
          </div>
          <div class="space-y-2 text-sm text-gray-600">
            <div class="flex justify-between"><span>दिन का तापमान</span><span class="font-semibold">8°C – 16°C</span></div>
            <div class="flex justify-between"><span>रात का तापमान</span><span class="font-semibold">-3°C – 5°C</span></div>
            <div class="flex justify-between"><span>वर्षा</span><span class="font-semibold">मध्यम</span></div>
            <div class="flex justify-between"><span>भीड़</span><span class="font-semibold text-teal-600">बहुत अधिक</span></div>
          </div>
          <p class="text-gray-600 text-sm mt-4 leading-relaxed">पीक सीज़न। चीनी पर्यटकों की छुट्टियाँ। आवास और परिवहन पहले से बुक करना अनिवार्य। हरियाली और जंगली फूलों का सुंदर दृश्य।</p>
          <div class="mt-4 flex gap-2">
            <span class="bg-teal-50 text-teal-700 px-3 py-1 rounded-full text-xs">पीक सीज़न</span>
            <span class="bg-teal-50 text-teal-700 px-3 py-1 rounded-full text-xs">जंगली फूल</span>
          </div>
        </div>

        <!-- September -->
        <div class="bg-white rounded-2xl p-6 shadow-md hover:shadow-xl transition border-t-4 border-orange-400">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 bg-orange-100 rounded-full flex items-center justify-center text-2xl">🍂</div>
            <div>
              <h3 class="font-display text-xl font-bold text-kailash-dark">सितंबर</h3>
              <p class="text-orange-600 text-sm font-medium">स्वर्णिम समय</p>
            </div>
          </div>
          <div class="space-y-2 text-sm text-gray-600">
            <div class="flex justify-between"><span>दिन का तापमान</span><span class="font-semibold">6°C – 14°C</span></div>
            <div class="flex justify-between"><span>रात का तापमान</span><span class="font-semibold">-5°C – 2°C</span></div>
            <div class="flex justify-between"><span>वर्षा</span><span class="font-semibold">कम</span></div>
            <div class="flex justify-between"><span>भीड़</span><span class="font-semibold text-orange-600">मध्यम</span></div>
          </div>
          <p class="text-gray-600 text-sm mt-4 leading-relaxed">सबसे सुंदर महीना। शरद ऋतु के रंग, स्वर्णिम घास के मैदान, बिल्कुल साफ़ आकाश। फ़ोटोग्राफ़ी के लिए आदर्श। तापमान सुखद, वर्षा न्यूनतम। अत्यधिक अनुशंसित।</p>
          <div class="mt-4 flex gap-2">
            <span class="bg-orange-50 text-orange-700 px-3 py-1 rounded-full text-xs">स्वर्णिम दृश्य</span>
            <span class="bg-orange-50 text-orange-700 px-3 py-1 rounded-full text-xs">साफ़ आकाश</span>
            <span class="bg-orange-50 text-orange-700 px-3 py-1 rounded-full text-xs">अनुशंसित</span>
          </div>
        </div>

        <!-- October -->
        <div class="bg-white rounded-2xl p-6 shadow-md hover:shadow-xl transition border-t-4 border-purple-400">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 bg-purple-100 rounded-full flex items-center justify-center text-2xl">❄️</div>
            <div>
              <h3 class="font-display text-xl font-bold text-kailash-dark">अक्टूबर</h3>
              <p class="text-purple-600 text-sm font-medium">अंतिम अवसर</p>
            </div>
          </div>
          <div class="space-y-2 text-sm text-gray-600">
            <div class="flex justify-between"><span>दिन का तापमान</span><span class="font-semibold">0°C – 8°C</span></div>
            <div class="flex justify-between"><span>रात का तापमान</span><span class="font-semibold">-12°C – -4°C</span></div>
            <div class="flex justify-between"><span>वर्षा</span><span class="font-semibold">बहुत कम</span></div>
            <div class="flex justify-between"><span>भीड़</span><span class="font-semibold text-purple-600">कम</span></div>
          </div>
          <p class="text-gray-600 text-sm mt-4 leading-relaxed">मौसम का अंतिम महीना। अत्यधिक ठंड, रातें बर्फ़ीली। दर्रा जल्द ही बंद होगा। अनुभवी यात्रियों के लिए उपयुक्त। अक्टूबर के अंत तक दर्रा बंद हो सकता है।</p>
          <div class="mt-4 flex gap-2">
            <span class="bg-purple-50 text-purple-700 px-3 py-1 rounded-full text-xs">अत्यधिक ठंड</span>
            <span class="bg-purple-50 text-purple-700 px-3 py-1 rounded-full text-xs">अंतिम मौका</span>
          </div>
        </div>
      </div>

      <!-- Best Time Summary -->
      <div class="mt-12 bg-kailash-dark rounded-2xl p-8 md:p-10">
        <h3 class="font-display text-2xl font-bold text-kailash-gold mb-6 text-center">हमारी अनुशंसा</h3>
        <div class="grid md:grid-cols-3 gap-6 text-center">
          <div>
            <div class="text-4xl mb-3">🥇</div>
            <p class="text-white font-semibold mb-2">सितंबर</p>
            <p class="text-white/60 text-sm">स्वर्णिम शरद ऋतु, साफ़ आकाश, सुखद तापमान, कम वर्षा — सबसे अच्छा समग्र अनुभव</p>
          </div>
          <div>
            <div class="text-4xl mb-3">🥈</div>
            <p class="text-white font-semibold mb-2">जून</p>
            <p class="text-white/60 text-sm">सागा दावा का पवित्र समय, लंबे दिन, गर्म तापमान — आध्यात्मिक अनुभव के लिए सर्वोत्तम</p>
          </div>
          <div>
            <div class="text-4xl mb-3">🥉</div>
            <p class="text-white font-semibold mb-2">मई</p>
            <p class="text-white/60 text-sm">कम भीड़, शांत वातावरण, ताज़ी बर्फ़ के दृश्य — एकांतप्रिय यात्रियों के लिए आदर्श</p>
          </div>
        </div>
        <div class="mt-8 pt-6 border-t border-white/10 text-center">
          <p class="text-red-400 text-sm font-medium">⚠️ नवंबर से अप्रैल: दोलमा ला दर्रा बर्फ़ से बंद। परिक्रमा संभव नहीं। यात्रा की योजना न बनाएँ।</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3: Permit & Documents -->
  <section id="parmit" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-kailash-gold text-sm tracking-[0.2em] uppercase mb-3 font-medium">आवश्यक दस्तावेज़</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold text-kailash-dark mb-4">परमिट एवं दस्तावेज़</h2>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto">कैलाश यात्रा के लिए चार प्रमुख दस्तावेज़ आवश्यक हैं। ये सभी एक पंजीकृत तिब्बत ट्रैवल एजेंसी के माध्यम से ही प्राप्त किए जा सकते हैं। व्यक्तिगत रूप से आवेदन संभव नहीं है।</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Chinese Visa -->
        <div class="bg-kailash-light rounded-2xl p-8 shadow-md hover:shadow-xl transition border-l-4 border-red-500">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center text-3xl">🇨🇳</div>
            <div>
              <h3 class="font-display text-2xl font-bold text-kailash-dark">चीनी वीज़ा</h3>
              <p class="text-red-600 text-sm font-medium">Chinese Visa (L टूरिस्ट वीज़ा)</p>
            </div>
          </div>
          <div class="space-y-3 text-gray-700 text-sm">
            <p>सबसे पहला और अनिवार्य दस्तावेज़। आपके गृह देश के चीनी दूतावास या वीज़ा केंद्र से प्राप्त करें।</p>
            <ul class="space-y-2">
              <li class="flex items-start gap-2">
                <span class="text-kailash-gold mt-1">•</span>
                <span><span class="font-semibold">प्रकार:</span> L टूरिस्ट वीज़ा (पर्यटन वीज़ा)</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-kailash-gold mt-1">•</span>
                <span><span class="font-semibold">वैधता:</span> सामान्यतः 30 दिन, एकल प्रवेश</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-kailash-gold mt-1">•</span>
                <span><span class="font-semibold">आवेदन समय:</span> यात्रा से 1-2 महीने पूर्व</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-kailash-gold mt-1">•</span>

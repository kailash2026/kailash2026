  <!-- NEW Section: Detailed Permit Guide (विस्तृत परमिट गाइड) -->
  <section id="parmit-guide" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-kailash-gold text-sm tracking-[0.2em] uppercase mb-3 font-medium">चरण-दर-चरण मार्गदर्शन</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold text-kailash-dark mb-4">विस्तृत परमिट गाइड — भारतीय नागरिकों के लिए</h2>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto">कैलाश यात्रा के लिए आवश्यक सभी परमिट प्राप्त करने की चरण-दर-चरण प्रक्रिया। भारतीय नागरिकों और विदेशी नागरिकों के लिए अलग-अलग प्रक्रियाएँ।</p>
      </div>

      <!-- Step by Step for Indian Citizens -->
      <div class="bg-kailash-light rounded-2xl p-8 shadow-md mb-8">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-16 h-16 bg-orange-100 rounded-full flex items-center justify-center text-3xl">🇮🇳</div>
          <div>
            <h3 class="font-display text-2xl font-bold text-kailash-dark">भारतीय नागरिकों के लिए चरण-दर-चरण प्रक्रिया</h3>
            <p class="text-gray-600 text-sm">काठमांडू मार्ग से यात्रा करने वाले भारतीय नागरिकों के लिए</p>
          </div>
        </div>

        <div class="space-y-6">
          <!-- Step 1 -->
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <div class="flex items-start gap-4">
              <span class="bg-kailash-gold text-kailash-dark w-10 h-10 rounded-full flex items-center justify-center font-bold text-lg flex-shrink-0">1</span>
              <div>
                <h4 class="font-semibold text-lg text-kailash-dark">पासपोर्ट तैयार करें</h4>
                <ul class="mt-2 space-y-1 text-sm text-gray-600">
                  <li>• सुनिश्चित करें कि आपका पासपोर्ट यात्रा समाप्ति के बाद कम से कम 6 महीने तक वैध हो</li>
                  <li>• पासपोर्ट में कम से कम 2 खाली पृष्ठ होने चाहिए</li>
                  <li>• पुराना/क्षतिग्रस्त पासपोर्ट होने पर नया बनवाएँ (तत्काल: 7-14 दिन)</li>
                  <li>• पासपोर्ट की कम से कम 6 फ़ोटोकॉपी और डिजिटल स्कैन रखें</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <div class="flex items-start gap-4">
              <span class="bg-kailash-gold text-kailash-dark w-10 h-10 rounded-full flex items-center justify-center font-bold text-lg flex-shrink-0">2</span>
              <div>
                <h4 class="font-semibold text-lg text-kailash-dark">चीनी वीज़ा (L टूरिस्ट) प्राप्त करें</h4>
                <ul class="mt-2 space-y-1 text-sm text-gray-600">
                  <li>• <span class="font-semibold">कहाँ:</span> काठमांडू स्थित चीनी दूतावास या भारत में चीनी वीज़ा केंद्र (दिल्ली, मुंबई, कोलकाता)</li>
                  <li>• <span class="font-semibold">प्रकार:</span> L टूरिस्ट वीज़ा (एकल प्रवेश, 30 दिन)</li>
                  <li>• <span class="font-semibold">शुल्क:</span> ₹3,800 (भारत में) या $60-100 (काठमांडू में)</li>
                  <li>• <span class="font-semibold">समय:</span> 4-7 कार्य दिवस (भारत), 3-5 दिन (काठमांडू)</li>
                  <li>• <span class="font-semibold">दस्तावेज़:</span> पासपोर्ट, फ़ोटो, आवेदन पत्र, यात्रा कार्यक्रम, होटल बुकिंग</li>
                  <li>• <span class="font-semibold">महत्वपूर्ण:</span> आवेदन में "तिब्बत" का उल्लेख न करें — केवल "चीन" या "चेंगदू/कुनमिंग" लिखें</li>
                </ul>
                <div class="mt-3 bg-red-50 rounded-lg p-3 border border-red-200">
                  <p class="text-red-700 text-sm"><span class="font-bold">⚠️ सावधानी:</span> यदि आपने वीज़ा आवेदन में तिब्बत का उल्लेख किया, तो आवेदन अस्वीकार होने की संभावना बहुत अधिक है। चीनी अधिकारी विदेशियों को स्वतंत्र रूप से तिब्बत जाने की अनुमति नहीं देते।</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Step 3 -->

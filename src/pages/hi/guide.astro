        <!-- Prevention -->
        <div class="bg-white rounded-2xl p-8 shadow-md border-t-4 border-green-500">
          <div class="text-4xl mb-4">🛡️</div>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-4">बचाव (Prevention)</h3>
          <p class="text-gray-600 text-sm mb-4">ऊँचाई बीमारी से बचने का सबसे अच्छा तरीका — धीरे-धीरे ऊपर जाना:</p>
          <ul class="space-y-3 text-gray-700 text-sm">
            <li class="flex items-start gap-2"><span class="text-green-500 font-bold">•</span><span><span class="font-semibold">धीमी चढ़ाई:</span> 3,000मी से ऊपर प्रतिदिन 300-500मी से अधिक न चढ़ें</span></li>
            <li class="flex items-start gap-2"><span class="text-green-500 font-bold">•</span><span><span class="font-semibold">अनुकूलन दिवस:</span> तिब्बत पहुँचने के बाद 2-3 दिन आराम करें</span></li>
            <li class="flex items-start gap-2"><span class="text-green-500 font-bold">•</span><span><span class="font-semibold">खूब पानी पिएँ:</span> प्रतिदिन 3-4 लीटर — निर्जलीकरण AMS को बढ़ाता है</span></li>
            <li class="flex items-start gap-2"><span class="text-green-500 font-bold">•</span><span><span class="font-semibold">शराब और धूम्रपान से बचें:</span> ये लक्षणों को और बिगाड़ते हैं</span></li>
            <li class="flex items-start gap-2"><span class="text-green-500 font-bold">•</span><span><span class="font-semibold">हल्का भोजन:</span> कार्बोहाइड्रेट-युक्त, आसानी से पचने वाला</span></li>
            <li class="flex items-start gap-2"><span class="text-green-500 font-bold">•</span><span><span class="font-semibold">डायमॉक्स:</span> डॉक्टर के परामर्श से — चढ़ाई से 1-2 दिन पूर्व शुरू करें</span></li>
            <li class="flex items-start gap-2"><span class="text-green-500 font-bold">•</span><span><span class="font-semibold">"ऊँचा चढ़ो, नीचे सोओ":</span> दिन में चढ़ें, रात को निचली ऊँचाई पर सोएँ</span></li>
            <li class="flex items-start gap-2"><span class="text-green-500 font-bold">•</span><span><span class="font-semibold">अपने शरीर को सुनें:</span> लक्षण दिखने पर आगे न बढ़ें</span></li>
          </ul>

    services: "रेस्तरां, दुकानें, पेट्रोल पंप, डाकघर, इंटरनेट कैफ़े, चिकित्सालय, वाहन/घोड़ा/कुली किराया"
  }
];
---

<Layout title="परिक्रमा मार्ग - 52 किमी पवित्र यात्रा | कैलाश 2026" description="कैलाश पर्वत की 52 किमी बाहरी परिक्रमा का पूर्ण मार्गदर्शन: एक दिवसीय, दो दिवसीय और तीन दिवसीय यात्रा योजनाएँ। 13 आपूर्ति केंद्रों, ऊँचाई परिवर्तन और महत्वपूर्ण सुझावों के साथ। तारचेन से प्रारंभ, 5648मी दोलमा ला दर्रा पार।">

  <!-- Hero Section with full-width photo overlay -->
  <section class="relative bg-kailash-dark">
    <!-- Full-width photo -->
    <div class="relative w-full h-[45vh] lg:h-[55vh]">
      <div class="absolute inset-0 bg-[url('/images/kailash-yaks.webp')] bg-cover bg-center"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-kailash-dark"></div>
    </div>

    <!-- Content below photo -->
    <div class="relative -mt-20 z-10 px-4 sm:px-6 lg:px-8 pb-16">
      <div class="max-w-7xl mx-auto text-center">
        <h1 class="font-display text-5xl md:text-6xl font-bold text-white mb-4">
          परिक्रमा मार्ग
        </h1>
        <p class="text-xl text-white/60 max-w-3xl mx-auto">
          52 किमी, तीन दिन — आस्था से प्रारंभ, आत्मा की ओर वापसी
        </p>
        <div class="flex justify-center gap-8 mt-8">
          <div class="text-center">
            <p class="text-3xl font-bold text-kailash-gold">52 किमी</p>
            <p class="text-white/40 text-sm">कुल दूरी</p>
          </div>
          <div class="text-center">
            <p class="text-3xl font-bold text-kailash-gold">5648 मी</p>
            <p class="text-white/40 text-sm">सर्वोच्च बिंदु</p>
          </div>
          <div class="text-center">
            <p class="text-3xl font-bold text-kailash-gold">3 दिन</p>
            <p class="text-white/40 text-sm">मानक यात्रा</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="bg-kailash-dark py-8 border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <p class="text-3xl md:text-4xl font-bold text-kailash-gold">52 किमी</p>
          <p class="text-white/60 text-sm mt-1">कुल परिक्रमा दूरी</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold text-kailash-gold">5648 मी</p>
          <p class="text-white/60 text-sm mt-1">दोलमा ला दर्रा</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold text-kailash-gold">4600 मी</p>
          <p class="text-white/60 text-sm mt-1">आधार ऊँचाई</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold text-kailash-gold">13</p>
          <p class="text-white/60 text-sm mt-1">आपूर्ति केंद्र</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Route Overview -->
  <section class="py-20 bg-kailash-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4">मार्ग अवलोकन</h2>
        <p class="text-lg text-gray-600">ऊँचाई परिवर्तन और प्रमुख पड़ाव</p>
      </div>

      <!-- Route Map -->
      <div class="mb-12">
        <div class="text-center mb-8">
          <h3 class="font-display text-2xl font-bold text-kailash-dark mb-2">कैलाश परिक्रमा मार्ग मानचित्र</h3>
          <p class="text-gray-600 text-sm">52 किमी पवित्र पथ — पवित्र पर्वत की एक परिक्रमा</p>
        </div>
        <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
          <img src="/images/kailash-trek-map.webp" alt="कैलाश परिक्रमा मार्ग मानचित्र" class="w-full block" style="min-height: 400px;" loading="eager" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
          <div style="display: none;" class="p-8 text-center text-gray-500">
            <svg class="w-16 h-16 mx-auto mb-4 text-kailash-gold/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            <p>मानचित्र लोड हो रहा है...</p>
          </div>
        </div>
      </div>

      <!-- Route Scenery -->
      <div class="mt-16 mb-16">
        <div class="text-center mb-12">
          <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4">मार्ग दृश्य</h2>
          <p class="text-lg text-gray-600">कदमों से आस्था नापें, आँखों से पवित्र पर्वत देखें</p>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
            <div class="relative aspect-[4/3] bg-gray-100">
              <img src="/images/route-map-1.webp" alt="दोलमा ला दर्रा प्रार्थना ध्वज" class="absolute inset-0 w-full h-full object-cover" loading="eager" onerror="this.style.display='none'; this.parentElement.querySelector('.fallback').style.display='flex';" />
              <div class="fallback absolute inset-0 bg-gray-100 flex items-center justify-center text-gray-400" style="display: none;">
                <span>चित्र लोड विफल</span>
              </div>
              <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent p-4">
                <p class="text-white font-semibold">दोलमा ला दर्रा · प्रार्थना ध्वज</p>
                <p class="text-white/80 text-sm">Drolma La Pass · Prayer Flags</p>
              </div>
            </div>
            <div class="p-4">
              <p class="text-gray-600 text-sm">5648 मीटर की ऊँचाई पर सर्वोच्च बिंदु, तीर्थयात्री आशीर्वाद के लिए यहाँ प्रार्थना ध्वज लटकाते हैं। रंग-बिरंगे लुंगता हवा में मंत्रों का जाप करते हैं।</p>
            </div>
          </div>

          <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
            <div class="relative aspect-[4/3] bg-gray-100">
              <img src="/images/route-map-2.webp" alt="कैलाश पर्वत और घोड़ा कारवां" class="absolute inset-0 w-full h-full object-cover" loading="eager" onerror="this.style.display='none'; this.parentElement.querySelector('.fallback').style.display='flex';" />
              <div class="fallback absolute inset-0 bg-gray-100 flex items-center justify-center text-gray-400" style="display: none;">
                <span>चित्र लोड विफल</span>
              </div>
              <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent p-4">
                <p class="text-white font-semibold">पवित्र पर्वत दृश्य · घोड़ा कारवां विश्राम</p>
                <p class="text-white/80 text-sm">Mount Kailash View · Horse Caravan Rest</p>
              </div>
            </div>
            <div class="p-4">
              <p class="text-gray-600 text-sm">बादलों से घिरा कैलाश पर्वत, घाटी में विश्राम करता घोड़ा कारवां, दूर अस्थायी शिविरों का धुआँ उठता हुआ।</p>
            </div>
          </div>

          <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
            <div class="relative aspect-[4/3] bg-gray-100">
              <img src="/images/route-scenery-1.webp" alt="मार्ग संकेत पट्टिका" class="absolute inset-0 w-full h-full object-cover" loading="eager" onerror="this.style.display='none'; this.parentElement.querySelector('.fallback').style.display='flex';" />
              <div class="fallback absolute inset-0 bg-gray-100 flex items-center justify-center text-gray-400" style="display: none;">
                <span>चित्र लोड विफल</span>
              </div>
              <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent p-4">
                <p class="text-white font-semibold">चोकु गोम्पा पथ · त्रिभाषी संकेत</p>
                <p class="text-white/80 text-sm">Choku Gompa Path · Trilingual Sign</p>
              </div>
            </div>
            <div class="p-4">
              <p class="text-gray-600 text-sm">त्रिभाषी (तिब्बती/चीनी/अंग्रेज़ी) संकेत पट्टिका चोकु गोम्पा की ओर इशारा करती है। लाल चट्टानें गहरे नीले आकाश के विरुद्ध — विशिष्ट आली भूदृश्य।</p>
            </div>
          </div>

          <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
            <div class="relative aspect-[4/3] bg-gray-100">
              <img src="/images/route-scenery-2.webp" alt="कैलाश नज़दीकी दृश्य" class="absolute inset-0 w-full h-full object-cover" loading="eager" onerror="this.style.display='none'; this.parentElement.querySelector('.fallback').style.display='flex';" />
              <div class="fallback absolute inset-0 bg-gray-100 flex items-center justify-center text-gray-400" style="display: none;">
                <span>चित्र लोड विफल</span>
              </div>
              <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent p-4">
                <p class="text-white font-semibold">कैलाश पर्वत · प्रार्थना ध्वज अग्रभूमि</p>
                <p class="text-white/80 text-sm">Mount Kailash · Prayer Flags Foreground</p>
              </div>
            </div>
            <div class="p-4">
              <p class="text-gray-600 text-sm">पिरामिड आकार के शिखर का नज़दीकी दृश्य। अग्रभूमि में प्रार्थना ध्वज लहरा रहे हैं, चट्टान की परतें स्पष्ट दिखाई देती हैं — 6656 मीटर की शाश्वत गरिमा।</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Supply Stations -->
      <div class="mt-16">
        <div class="text-center mb-12">
          <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4">13 आपूर्ति केंद्र</h2>
          <p class="text-lg text-gray-600">प्रारंभ से समापन तक पूरे मार्ग पर विस्तृत आपूर्ति</p>
        </div>

        <div class="space-y-4">
          {supplyStations.map((station, index) => (
            <div class={`rounded-xl overflow-hidden ${
              station.type === 'start' || station.type === 'end' ? 'bg-green-50 border-2 border-green-200' :
              station.type === 'peak' ? 'bg-red-50 border-2 border-red-200' :
              station.type === 'camp' ? 'bg-blue-50 border-2 border-blue-200' :
              'bg-white shadow-md border border-gray-100'
            }`}>
              <div class={`p-5 ${
                station.type === 'start' || station.type === 'end' ? 'bg-green-100/50' :
                station.type === 'peak' ? 'bg-red-100/50' :
                station.type === 'camp' ? 'bg-blue-100/50' :
                'bg-gray-50/50'
              }`}>
                <div class="flex items-start gap-4">
                  <div class={`w-14 h-14 rounded-full flex items-center justify-center font-bold text-lg shrink-0 ${
                    station.type === 'start' || station.type === 'end' ? 'bg-green-500 text-white' :
                    station.type === 'peak' ? 'bg-red-500 text-white' :
                    station.type === 'camp' ? 'bg-blue-500 text-white' :
                    'bg-kailash-gold text-kailash-dark'
                  }`}>
                    {station.altitude}मी
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-3 mb-1 flex-wrap">
                      <h3 class="font-display text-xl font-bold text-kailash-dark">{station.name}</h3>
                      <span class="text-sm text-gray-500">{station.nameEn}</span>
                      {station.type === 'camp' && <span class="bg-blue-100 text-blue-700 px-2 py-0.5 rounded text-xs font-semibold">🏠 आवास</span>}
                      {station.type === 'peak' && <span class="bg-red-100 text-red-700 px-2 py-0.5 rounded text-xs font-semibold">⚠️ सर्वोच्च बिंदु</span>}
                      {station.type === 'start' && <span class="bg-green-100 text-green-700 px-2 py-0.5 rounded text-xs font-semibold">🚀 प्रारंभ</span>}
                      {station.type === 'end' && <span class="bg-green-100 text-green-700 px-2 py-0.5 rounded text-xs font-semibold">🏁 समापन</span>}
                      {station.type === 'teahouse' && <span class="bg-kailash-gold/20 text-kailash-dark px-2 py-0.5 rounded text-xs font-semibold">🍵 चायघर</span>}
                    </div>
                    <p class="text-sm text-gray-500 font-medium">{station.distance}</p>
                  </div>
                  <div class="text-2xl text-gray-300 font-bold shrink-0">
                    {String(index + 1).padStart(2, '0')}
                  </div>
                </div>
              </div>

              <div class="px-5 pb-5">
                {station.supplies.length > 0 && (
                  <div class="mb-3">
                    <h4 class="text-sm font-semibold text-gray-700 mb-2 flex items-center gap-1">
                      <span class="text-kailash-gold">●</span>
                      उपलब्ध वस्तुएँ
                    </h4>
                    <div class="flex flex-wrap gap-2">
                      {station.supplies.map(item => (
                        <span class="bg-white border border-gray-200 px-2 py-1 rounded text-sm text-gray-600">{item}</span>
                      ))}
                    </div>
                  </div>
                )}

                <div class="grid md:grid-cols-2 gap-3">
                  <div>
                    <h4 class="text-sm font-semibold text-gray-700 mb-1 flex items-center gap-1">
                      <span class="text-kailash-gold">●</span>
                      आवास
                    </h4>
                    <p class="text-sm text-gray-600">{station.lodging}</p>
                  </div>
                  <div>
                    <h4 class="text-sm font-semibold text-gray-700 mb-1 flex items-center gap-1">
                      <span class="text-kailash-gold">●</span>
                      सेवाएँ
                    </h4>
                    <p class="text-sm text-gray-600">{station.services}</p>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Route Plans Comparison -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4">अपनी परिक्रमा योजना चुनें</h2>
        <p class="text-lg text-gray-600">एक दिन की चरम चुनौती, दो दिन का कठिन अभियान, या तीन दिन की शास्त्रीय यात्रा</p>
      </div>

      <!-- Plan Cards -->
      <div class="grid md:grid-cols-3 gap-8 mb-16">
        <!-- 1-Day Plan (Purple / Extreme) -->
        <div class="bg-kailash-light rounded-2xl overflow-hidden border-2 border-purple-200">
          <div class="bg-purple-50 p-6">
            <div class="flex items-center justify-between mb-2">
              <h3 class="font-display text-2xl font-bold text-kailash-dark">{routePlans.oneDay.name}</h3>
              <span class="bg-purple-600 text-white px-3 py-1 rounded-full text-sm font-semibold">{routePlans.oneDay.difficulty}</span>
            </div>
            <p class="text-gray-600 text-sm">{routePlans.oneDay.subtitle}</p>
          </div>
          <div class="p-6">
            <div class="grid grid-cols-3 gap-4 mb-4 text-center">
              <div>
                <p class="text-2xl font-bold text-kailash-gold">{routePlans.oneDay.totalDistance}</p>
                <p class="text-xs text-gray-500">कुल दूरी</p>
              </div>
              <div>
                <p class="text-2xl font-bold text-kailash-gold">{routePlans.oneDay.totalDuration}</p>
                <p class="text-xs text-gray-500">कुल समय</p>
              </div>
              <div>
                <p class="text-2xl font-bold text-kailash-gold">0</p>
                <p class="text-xs text-gray-500">रात्रि विश्राम</p>
              </div>
            </div>
            <p class="text-gray-700 text-sm mb-4">{routePlans.oneDay.description}</p>
            <div class="bg-purple-50 border border-purple-200 rounded-lg p-3">
              <p class="text-purple-700 text-sm">{routePlans.oneDay.warning}</p>
            </div>
          </div>
        </div>

        <!-- 2-Day Plan (Red / Hard) -->
        <div class="bg-kailash-light rounded-2xl overflow-hidden border-2 border-red-200">
          <div class="bg-red-50 p-6">
            <div class="flex items-center justify-between mb-2">
              <h3 class="font-display text-2xl font-bold text-kailash-dark">{routePlans.twoDay.name}</h3>
              <span class="bg-red-500 text-white px-3 py-1 rounded-full text-sm font-semibold">{routePlans.twoDay.difficulty}</span>
            </div>
            <p class="text-gray-600 text-sm">{routePlans.twoDay.subtitle}</p>
          </div>
          <div class="p-6">
            <div class="grid grid-cols-3 gap-4 mb-4 text-center">
              <div>
                <p class="text-2xl font-bold text-kailash-gold">{routePlans.twoDay.totalDistance}</p>
                <p class="text-xs text-gray-500">कुल दूरी</p>
              </div>
              <div>
                <p class="text-2xl font-bold text-kailash-gold">{routePlans.twoDay.totalDuration}</p>
                <p class="text-xs text-gray-500">कुल समय</p>
              </div>
              <div>
                <p class="text-2xl font-bold text-kailash-gold">1</p>
                <p class="text-xs text-gray-500">रात्रि विश्राम</p>
              </div>
            </div>
            <p class="text-gray-700 text-sm mb-4">{routePlans.twoDay.description}</p>
            <div class="bg-red-50 border border-red-200 rounded-lg p-3">
              <p class="text-red-700 text-sm">{routePlans.twoDay.warning}</p>
            </div>
          </div>
        </div>

        <!-- 3-Day Plan (Blue / Moderate) -->
        <div class="bg-kailash-light rounded-2xl overflow-hidden border-2 border-blue-200">
          <div class="bg-blue-50 p-6">
            <div class="flex items-center justify-between mb-2">
              <h3 class="font-display text-2xl font-bold text-kailash-dark">{routePlans.threeDay.name}</h3>
              <span class="bg-blue-500 text-white px-3 py-1 rounded-full text-sm font-semibold">{routePlans.threeDay.difficulty}</span>
            </div>
            <p class="text-gray-600 text-sm">{routePlans.threeDay.subtitle}</p>
          </div>
          <div class="p-6">
            <div class="grid grid-cols-3 gap-4 mb-4 text-center">
              <div>
                <p class="text-2xl font-bold text-kailash-gold">{routePlans.threeDay.totalDistance}</p>
                <p class="text-xs text-gray-500">कुल दूरी</p>
              </div>
              <div>
                <p class="text-2xl font-bold text-kailash-gold">{routePlans.threeDay.totalDuration}</p>
                <p class="text-xs text-gray-500">कुल समय</p>
              </div>
              <div>
                <p class="text-2xl font-bold text-kailash-gold">2</p>
                <p class="text-xs text-gray-500">रात्रि विश्राम</p>
              </div>
            </div>

---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="संपर्क करें - कैलाश 2026" description="कैलाश 2026 से संपर्क करें। आपके प्रश्न, कहानियाँ, सुझाव और प्रतिक्रिया के लिए हमसे जुड़ें। kailash2026Lucas@outlook.com पर ईमेल करें।">

  <!-- Hero Section -->
  <section class="relative py-24 bg-kailash-dark overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-kailash-dark/80 to-kailash-dark"></div>
    <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
      <p class="text-kailash-gold text-sm md:text-base tracking-[0.3em] uppercase mb-4 font-light">
        हमसे जुड़ें
      </p>
      <h1 class="font-display text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight">
        संपर्क करें
      </h1>
      <p class="text-xl text-white/70 max-w-2xl mx-auto font-light leading-relaxed">
        आपके विचार, प्रश्न और कहानियाँ हमारे लिए महत्वपूर्ण हैं। कैलाश 2026 की टीम आपकी सहायता के लिए सदैव तत्पर है।
      </p>
    </div>
  </section>

  <!-- Contact Info Card -->
  <section class="py-16 bg-kailash-light">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-2xl shadow-lg p-8 md:p-12 text-center">
        <div class="text-5xl mb-6">📧</div>
        <h2 class="font-display text-3xl font-bold text-kailash-dark mb-4">ईमेल के माध्यम से संपर्क करें</h2>
        <p class="text-lg text-gray-600 mb-8 max-w-xl mx-auto">
          हमसे संपर्क करने का सबसे सीधा और सरल तरीका ईमेल है। हम आपके हर संदेश का उत्तर देने का प्रयास करते हैं।
        </p>
        <a
          href="mailto:kailash2026Lucas@outlook.com"
          class="inline-block bg-kailash-gold text-kailash-dark px-8 py-4 rounded-lg font-semibold text-lg hover:bg-kailash-accent transition"
        >
          kailash2026Lucas@outlook.com
        </a>
        <p class="text-sm text-gray-400 mt-4">
          ईमेल भेजने के लिए ऊपर दिए गए पते पर क्लिक करें
        </p>
      </div>
    </div>
  </section>

  <!-- Response Time -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="text-5xl mb-6">⏱️</div>
      <h2 class="font-display text-3xl font-bold text-kailash-dark mb-6">प्रतिक्रिया समय</h2>
      <p class="text-lg text-gray-600 mb-10 max-w-2xl mx-auto leading-relaxed">
        हम आपके हर संदेश को गंभीरता से लेते हैं और शीघ्रतापूर्वक उत्तर देने का प्रयास करते हैं।
      </p>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-kailash-light rounded-2xl p-8">
          <div class="text-kailash-gold text-4xl font-bold mb-3">24</div>
          <p class="font-semibold text-kailash-dark text-lg mb-2">घंटों के भीतर</p>
          <p class="text-gray-600 text-sm">
            सामान्य प्रश्नों का उत्तर हम 24 घंटों के भीतर देने का प्रयास करते हैं।
          </p>
        </div>

        <div class="bg-kailash-light rounded-2xl p-8">
          <div class="text-kailash-gold text-4xl font-bold mb-3">48</div>
          <p class="font-semibold text-kailash-dark text-lg mb-2">घंटों के भीतर</p>
          <p class="text-gray-600 text-sm">
            विस्तृत या जटिल प्रश्नों के लिए हमें 48 घंटों तक का समय लग सकता है।
          </p>
        </div>

        <div class="bg-kailash-light rounded-2xl p-8">
          <div class="text-kailash-gold text-4xl font-bold mb-3">7</div>
          <p class="font-semibold text-kailash-dark text-lg mb-2">दिन/सप्ताह</p>
          <p class="text-gray-600 text-sm">
            हम सप्ताह के सातों दिन उपलब्ध हैं। सप्ताहांत और छुट्टियों में थोड़ा विलंब हो सकता है।
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- What to Contact Us About -->
  <section class="py-16 bg-kailash-light">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="text-5xl mb-6">💬</div>
      <h2 class="font-display text-3xl font-bold text-kailash-dark mb-6">हमसे किन विषयों पर संपर्क करें</h2>
      <p class="text-lg text-gray-600 mb-10 max-w-2xl mx-auto leading-relaxed">
        चाहे आपके मन में कोई प्रश्न हो, कोई अनुभव साझा करना हो, या कोई सुझाव देना हो — हम आपकी बात सुनने के लिए उत्सुक हैं।
      </p>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-lg transition">
          <div class="text-4xl mb-4">❓</div>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3">प्रश्न</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            कैलाश पर्वत, परिक्रमा मार्ग, यात्रा की तैयारी, परमिट, मौसम, ऊँचाई, आवास, या किसी अन्य विषय पर आपके प्रश्नों का हम स्वागत करते हैं।
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-lg transition">
          <div class="text-4xl mb-4">📖</div>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3">कहानियाँ</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            क्या आपने कैलाश की यात्रा की है? अपनी तीर्थयात्रा की कहानी, अनुभव और तस्वीरें हमारे साथ साझा करें। आपकी कहानी दूसरों को प्रेरित कर सकती है।
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-lg transition">
          <div class="text-4xl mb-4">💡</div>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3">सुझाव</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            हमारी वेबसाइट, सेवाओं या सामग्री को बेहतर बनाने के लिए आपके सुझावों का हम स्वागत करते हैं। आपकी प्रतिक्रिया हमें बेहतर बनाती है।
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Additional Contact Topics -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-3xl font-bold text-kailash-dark mb-10">अन्य विषय</h2>

      <div class="grid md:grid-cols-2 gap-6 text-left">
        <div class="flex items-start gap-4 bg-kailash-light rounded-xl p-6">
          <div class="text-3xl flex-shrink-0">🤝</div>
          <div>
            <h3 class="font-semibold text-kailash-dark text-lg mb-1">सहयोग</h3>
            <p class="text-gray-600 text-sm">यात्रा एजेंसियों, टूर ऑपरेटरों और स्थानीय गाइडों के साथ साझेदारी में रुचि है? हमसे संपर्क करें।</p>
          </div>
        </div>

        <div class="flex items-start gap-4 bg-kailash-light rounded-xl p-6">
          <div class="text-3xl flex-shrink-0">📝</div>
          <div>
            <h3 class="font-semibold text-kailash-dark text-lg mb-1">सामग्री योगदान</h3>
            <p class="text-gray-600 text-sm">क्या आप कैलाश से संबंधित लेख, कविता, या कलाकृति साझा करना चाहते हैं? हमें भेजें।</p>
          </div>
        </div>

        <div class="flex items-start gap-4 bg-kailash-light rounded-xl p-6">
          <div class="text-3xl flex-shrink-0">📢</div>
          <div>
            <h3 class="font-semibold text-kailash-dark text-lg mb-1">मीडिया पूछताछ</h3>
            <p class="text-gray-600 text-sm">पत्रकार, शोधकर्ता या फिल्म निर्माता? हम जानकारी और सहायता प्रदान करने में प्रसन्न होंगे।</p>
          </div>
        </div>

        <div class="flex items-start gap-4 bg-kailash-light rounded-xl p-6">
          <div class="text-3xl flex-shrink-0">🛠️</div>
          <div>
            <h3 class="font-semibold text-kailash-dark text-lg mb-1">तकनीकी सहायता</h3>
            <p class="text-gray-600 text-sm">वेबसाइट से संबंधित किसी समस्या या तकनीकी सुझाव के लिए हमें लिखें।</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Media / Follow Us -->
  <section class="py-16 bg-kailash-light">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="text-5xl mb-6">🌐</div>
      <h2 class="font-display text-3xl font-bold text-kailash-dark mb-4">हमें फ़ॉलो करें</h2>
      <p class="text-lg text-gray-600 mb-10 max-w-2xl mx-auto leading-relaxed">
        कैलाश 2026 से जुड़े रहें। नवीनतम जानकारी, यात्रा अपडेट और प्रेरक कहानियों के लिए हमारे सोशल मीडिया चैनलों पर हमें फ़ॉलो करें।
      </p>

      <div class="flex flex-wrap justify-center gap-6">
        <a
          href="#"
          class="flex items-center gap-3 bg-white rounded-xl px-6 py-4 shadow-md hover:shadow-lg transition group"
          aria-label="Facebook पर फ़ॉलो करें"
        >
          <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center text-xl group-hover:scale-110 transition-transform">
            📘
          </div>
          <div class="text-left">
            <p class="font-semibold text-kailash-dark">Facebook</p>
            <p class="text-xs text-gray-500">जल्द आ रहा है</p>
          </div>
        </a>

        <a
          href="#"
          class="flex items-center gap-3 bg-white rounded-xl px-6 py-4 shadow-md hover:shadow-lg transition group"
          aria-label="Instagram पर फ़ॉलो करें"
        >
          <div class="w-10 h-10 bg-pink-100 rounded-full flex items-center justify-center text-xl group-hover:scale-110 transition-transform">
            📷
          </div>
          <div class="text-left">
            <p class="font-semibold text-kailash-dark">Instagram</p>
            <p class="text-xs text-gray-500">जल्द आ रहा है</p>
          </div>
        </a>

        <a
          href="#"
          class="flex items-center gap-3 bg-white rounded-xl px-6 py-4 shadow-md hover:shadow-lg transition group"
          aria-label="Twitter/X पर फ़ॉलो करें"
        >
          <div class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center text-xl group-hover:scale-110 transition-transform">
            🐦
          </div>
          <div class="text-left">
            <p class="font-semibold text-kailash-dark">Twitter / X</p>
            <p class="text-xs text-gray-500">जल्द आ रहा है</p>
          </div>
        </a>

        <a
          href="#"
          class="flex items-center gap-3 bg-white rounded-xl px-6 py-4 shadow-md hover:shadow-lg transition group"
          aria-label="YouTube चैनल देखें"
        >
          <div class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center text-xl group-hover:scale-110 transition-transform">
            ▶️
          </div>
          <div class="text-left">
            <p class="font-semibold text-kailash-dark">YouTube</p>
            <p class="text-xs text-gray-500">जल्द आ रहा है</p>
          </div>
        </a>
      </div>

      <p class="text-sm text-gray-500 mt-8">
        हमारे सोशल मीडिया चैनल शीघ्र ही लॉन्च होंगे। तब तक, ईमेल के माध्यम से जुड़े रहें।
      </p>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-16 bg-kailash-gold">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-3xl font-bold text-kailash-dark mb-4">
        आपका संदेश हमारे लिए महत्वपूर्ण है
      </h2>
      <p class="text-kailash-dark/80 text-lg mb-8">
        हर प्रश्न, हर कहानी, और हर सुझाव हमें कैलाश 2026 को और बेहतर बनाने में मदद करता है।
      </p>
      <a
        href="mailto:kailash2026Lucas@outlook.com"
        class="inline-flex items-center bg-kailash-dark text-kailash-gold px-8 py-4 rounded-lg font-semibold text-lg hover:bg-black transition"
      >
        अभी ईमेल लिखें
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
      </a>
    </div>
  </section>

</Layout>

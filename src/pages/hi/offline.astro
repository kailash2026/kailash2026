---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="ऑफ़लाइन - Kailash 2026" description="आप ऑफ़लाइन हैं। कैश की गई मूल जानकारी अभी भी उपलब्ध है।" lang="hi">
  <section class="min-h-screen flex items-center justify-center bg-kailash-light px-4">
    <div class="text-center max-w-lg mx-auto py-20">
      <div class="text-6xl mb-6">🏔️</div>
      <h1 class="font-display text-3xl md:text-4xl font-bold text-kailash-dark mb-4">ऑफ़लाइन</h1>
      <p class="text-gray-600 text-lg mb-2">आपका इंटरनेट कनेक्शन नहीं है</p>
      <p class="text-gray-500 mb-8">तीर्थयात्रा गाइड और मार्ग जानकारी अभी भी उपलब्ध है</p>
      <div class="grid gap-4">
        <a href="/hi" class="block bg-kailash-dark text-white px-6 py-4 rounded-xl font-medium hover:bg-kailash-stone transition">होम पेज पर वापस जाएँ</a>
        <a href="/hi/guide" class="block bg-white text-kailash-dark px-6 py-4 rounded-xl font-medium border border-gray-200 hover:border-kailash-gold transition">तीर्थयात्रा गाइड (कैश किया गया)</a>
        <a href="/hi/routes" class="block bg-white text-kailash-dark px-6 py-4 rounded-xl font-medium border border-gray-200 hover:border-kailash-gold transition">परिक्रमा मार्ग (कैश किया गया)</a>
      </div>
      <p class="text-sm text-gray-400 mt-8">पुनः कनेक्ट होने पर सामग्री स्वतः अपडेट हो जाएगी। कैलाश पर्वत सदैव यहाँ है।</p>
    </div>
  </section>
</Layout>

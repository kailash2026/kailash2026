---
import Layout from '../../layouts/Layout.astro';

const purposes = [
  {
    icon: '🙏',
    title: '巡礼について',
    desc: 'コーラ（巡礼）の日程、距離、難易度、宿泊情報など、巡礼全般に関するご質問。'
  },
  {
    icon: '📅',
    title: 'ご予約・お申込み',
    desc: '2026年巡礼シーズン（5月〜10月）のご予約、グループ参加、キャンセルポリシーについて。'
  },
  {
    icon: '🛂',
    title: '入域許可・ビザ',
    desc: 'チベット入域許可証、中国ビザ、インド・ネパール方面からの特別手続きに関するご案内。'
  },
  {
    icon: '🏥',
    title: '安全・医療',
    desc: '高山病対策、必要な装備、緊急時対応、医療サポート体制についてのご質問。'
  },
  {
    icon: '🤝',
    title: '協業・メディア',
    desc: '旅行代理店様、ツアーオペレーター様との提携、取材協力、その他お問い合わせ。'
  }
];
---

<Layout title="お問い合わせ | カイラス2026" description="カイラス2026へのお問い合わせ。巡礼に関するご質問・ご予約・ご相談は kailash2026Lucas@outlook.com まで。">

  <!-- Hero -->
  <section class="py-20 md:py-28 bg-kailash-dark text-center">
    <div class="max-w-2xl mx-auto px-4">
      <p class="text-kailash-gold text-xs tracking-[0.3em] uppercase mb-4 font-light">
        ご連絡をお待ちしております
      </p>
      <h1 class="font-display text-4xl md:text-5xl font-bold text-white mb-6">
        お問い合わせ
      </h1>
      <p class="text-lg text-white/60 leading-relaxed">
        カイラス巡礼に関するご質問、ご予約、ご相談を承ります。<br />
        皆様の聖なる旅を全力でサポートいたします。
      </p>
    </div>
  </section>

  <!-- Email Contact — centered -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-lg mx-auto px-4 text-center">
      <div class="text-5xl mb-5">📧</div>
      <h2 class="font-display text-2xl md:text-3xl font-bold text-kailash-dark mb-4">
        メールでお問い合わせ
      </h2>
      <p class="text-xl md:text-2xl font-semibold text-kailash-gold mb-4 break-all">
        kailash2026Lucas@outlook.com
      </p>
      <p class="text-gray-500 mb-8">
        お問い合わせは24時間受付中です。<br />
        確認次第、順次ご返信いたします。
      </p>
      <a
        href="mailto:kailash2026Lucas@outlook.com"
        class="inline-flex items-center gap-2 bg-kailash-gold text-kailash-dark px-8 py-4 rounded-lg font-semibold text-lg hover:bg-kailash-accent transition shadow-md"
      >
        メールを送信する
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- Response Time — centered cards -->
  <section class="py-16 md:py-20 bg-kailash-light">
    <div class="max-w-2xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display text-2xl md:text-3xl font-bold text-kailash-dark mb-3">
          返信時間のご案内
        </h2>
        <p class="text-gray-600">
          お問い合わせ内容に応じて、以下の時間内にご返信いたします。
        </p>
      </div>

      <div class="flex flex-col items-center gap-5">
        <!-- General -->
        <div class="bg-white rounded-xl p-7 shadow-sm text-center w-full max-w-md">
          <div class="w-14 h-14 bg-kailash-gold/20 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-kailash-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="font-display text-lg font-bold text-kailash-dark mb-1">一般のお問い合わせ</h3>
          <p class="text-2xl font-bold text-kailash-gold mb-1">24時間以内</p>
          <p class="text-gray-500 text-sm">平日・休日問わず対応</p>
        </div>

        <!-- Booking -->
        <div class="bg-white rounded-xl p-7 shadow-sm text-center w-full max-w-md">
          <div class="w-14 h-14 bg-kailash-gold/20 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-kailash-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="font-display text-lg font-bold text-kailash-dark mb-1">ご予約・お申込み</h3>
          <p class="text-2xl font-bold text-kailash-gold mb-1">12時間以内</p>
          <p class="text-gray-500 text-sm">優先対応</p>
        </div>

        <!-- Emergency -->
        <div class="bg-white rounded-xl p-7 shadow-sm text-center w-full max-w-md">
          <div class="w-14 h-14 bg-kailash-gold/20 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-kailash-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h3 class="font-display text-lg font-bold text-kailash-dark mb-1">緊急のご連絡</h3>
          <p class="text-2xl font-bold text-kailash-gold mb-1">3時間以内</p>
          <p class="text-gray-500 text-sm">巡礼シーズン中（5月〜10月）</p>
        </div>
      </div>

      <!-- Office Hours -->
      <div class="mt-10 bg-white rounded-xl p-7 shadow-sm max-w-md mx-auto text-center">
        <h3 class="font-display text-lg font-bold text-kailash-dark mb-4">営業時間</h3>
        <div class="space-y-3 text-sm">
          <div class="flex justify-between items-center py-2 border-b border-gray-100">
            <span class="font-medium text-kailash-dark">月曜日 〜 金曜日</span>
            <span class="text-gray-600">09:00 〜 18:00</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-gray-100">
            <span class="font-medium text-kailash-dark">土曜日</span>
            <span class="text-gray-600">10:00 〜 16:00</span>
          </div>
          <div class="flex justify-between items-center py-2">
            <span class="font-medium text-kailash-dark">日曜日・祝日</span>
            <span class="text-gray-500">定休日</span>
          </div>
        </div>
        <p class="mt-5 text-amber-700 text-xs bg-amber-50 rounded-lg py-2 px-4">
          巡礼シーズン（5月〜10月）期間中は年中無休で対応いたします。
        </p>
      </div>
    </div>
  </section>

  <!-- Purposes — centered grid -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-display text-2xl md:text-3xl font-bold text-kailash-dark mb-3">
          お問い合わせいただける内容
        </h2>
        <p class="text-gray-600">
          以下のようなお問い合わせを承っております。<br />
          どのようなご質問でも、お気軽にご連絡ください。
        </p>
      </div>

      <div class="flex flex-col items-center gap-5">
        {purposes.map(purpose => (
          <div class="bg-kailash-light rounded-xl p-6 shadow-sm text-center w-full max-w-md hover:shadow-md transition">
            <div class="text-3xl mb-3">{purpose.icon}</div>
            <h3 class="font-display text-lg font-bold text-kailash-dark mb-2">{purpose.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{purpose.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-kailash-gold">
    <div class="max-w-lg mx-auto px-4 text-center">
      <h2 class="font-display text-2xl md:text-3xl font-bold text-kailash-dark mb-4">
        聖なる旅はここから始まります
      </h2>
      <p class="text-kailash-dark/80 text-lg mb-8">
        カイラス山の巡礼は、一生に一度の変容の旅です。<br />
        まずはお気軽にメールでご相談ください。
      </p>
      <a
        href="mailto:kailash2026Lucas@outlook.com?subject=カイラス巡礼について"
        class="inline-flex items-center gap-2 bg-kailash-dark text-white px-8 py-4 rounded-lg font-semibold text-lg hover:bg-kailash-dark/90 transition shadow-lg"
      >
        今すぐ問い合わせる
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </section>

</Layout>

---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('codex', ({ data }) => data.lang === 'en');
  return entries.map((entry) => {
    const slug = entry.id.replace(/\.md$/, '').replace(/^en\//, '');
    return {
      params: { slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const categoryLabels: Record<string, string> = {
  geography: '🏔️ Geography',
  religion: '🙏 Religion',
  history: '📜 History',
  figures: '👤 Figures',
  myths: '🗣️ Myths & Legends',
  nature: '🌿 Nature & Ecology',
  pilgrimage: '🚶 Pilgrimage',
};

const categoryLabel = categoryLabels[entry.data.category] || entry.data.category;
const pageTitle = `${entry.data.title} - Mount Kailash Codex | Kailash 2026`;

const codexLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  'headline': entry.data.title,
  'description': entry.data.description,
  'image': new URL(entry.data.image, 'https://kailash2026.com').toString(),
  'author': { '@type': 'Organization', 'name': 'Kailash 2026', 'url': 'https://kailash2026.com' },
  'mainEntityOfPage': { '@type': 'WebPage', '@id': new URL(Astro.url.pathname, 'https://kailash2026.com').toString() },
  'about': { '@type': 'Thing', 'name': `Mount Kailash - ${entry.data.title}` },
};
---

<Layout title={pageTitle} description={entry.data.description} lang="en">
  <!-- Hero Header -->
  <section class="relative bg-kailash-dark">
    <div class="relative w-full h-[25vh] lg:h-[30vh]">
      <div class="absolute inset-0 bg-[url('/images/kailash-golden.webp')] bg-cover bg-center opacity-40"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-kailash-dark/60 to-kailash-dark"></div>
    </div>
    <div class="relative -mt-8 z-10 px-4 pb-8">
      <div class="max-w-4xl mx-auto">
        <div class="flex items-center gap-2 text-sm text-kailash-gold mb-4">
          <a href="/en/codex" class="hover:text-kailash-accent transition-colors inline-flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Codex
          </a>
          <span class="text-white/30">/</span>
          <span>{categoryLabel}</span>
        </div>
        <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight">
          {entry.data.title}
        </h1>
        <p class="text-lg text-white/60 mt-3 max-w-3xl">{entry.data.description}</p>
      </div>
    </div>
  </section>

  <!-- Article Content -->
  <article class="py-12 bg-kailash-light">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-2xl shadow-md p-8 md:p-12">
        <div class="flex flex-wrap gap-2 mb-6 pb-6 border-b border-kailash-cream">
          <span class="text-sm bg-kailash-cream text-kailash-dark/70 px-3 py-1.5 rounded-full font-medium">
            {categoryLabel}
          </span>
        </div>
        <div class="prose prose-lg max-w-none
          prose-headings:font-display prose-headings:text-kailash-dark prose-headings:font-bold
          prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:pb-2 prose-h2:border-b prose-h2:border-kailash-cream
          prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
          prose-p:text-gray-700 prose-p:leading-relaxed prose-p:mb-4
          prose-a:text-kailash-gold prose-a:no-underline hover:prose-a:text-kailash-accent
          prose-strong:text-kailash-dark prose-strong:font-semibold
          prose-ul:text-gray-700 prose-ol:text-gray-700
          prose-blockquote:border-kailash-gold prose-blockquote:bg-kailash-light/50 prose-blockquote:rounded-r-lg prose-blockquote:py-3 prose-blockquote:px-6 prose-blockquote:italic
          prose-li:mb-2 prose-li:leading-relaxed
          prose-img:rounded-xl prose-img:shadow-md
          prose-th:bg-kailash-dark prose-th:text-white prose-th:px-4 prose-th:py-3 prose-th:text-sm
          prose-td:px-4 prose-td:py-3 prose-td:text-sm prose-td:text-gray-700 prose-td:border-b prose-td:border-gray-100
          prose-table:rounded-xl prose-table:overflow-hidden
          prose-code:bg-kailash-cream prose-code:text-kailash-accent prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm
        ">
          <Content />
        </div>

        <!-- Navigation -->
        <div class="mt-12 pt-8 border-t border-gray-200 flex justify-between items-center">
          <a href="/en/codex" class="inline-flex items-center text-kailash-gold font-medium hover:text-kailash-accent transition-colors">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
            </svg>
            Back to Codex
          </a>
        </div>
      </div>
    </div>
  </article>

  <!-- Related CTA -->
  <section class="py-12 bg-kailash-gold">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-2xl font-bold text-kailash-dark mb-3">Explore More Sacred Knowledge</h2>
      <p class="text-kailash-dark/70 mb-6">From geography to faith, discover everything about Mount Kailash.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/en/codex" class="bg-kailash-dark text-white px-6 py-3 rounded-lg font-medium hover:bg-kailash-stone transition">
          Browse All Entries
        </a>
        <a href="/en/guide" class="bg-white text-kailash-dark px-6 py-3 rounded-lg font-medium hover:bg-kailash-cream transition">
          Pilgrimage Guide
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json">
    {JSON.stringify(codexLd)}
  </script>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import SearchBox from '../../components/SearchBox.astro';
---

<Layout title="Kailash 2026 - Global Pilgrimage Platform | Sacred Mount Kailash, Tibet" description="Kailash 2026: The global pilgrimage platform connecting pilgrims worldwide. Sacred to Hinduism, Tibetan Buddhism, Bön, and Jainism. Join pilgrims from India, Nepal, China, and around the world on this transformative journey.">
  
  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-[url('/images/kailash-golden.jpg')] bg-cover bg-center"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-kailash-dark/60 via-kailash-dark/40 to-kailash-dark"></div>
    
    <div class="relative z-10 text-center px-4 max-w-5xl mx-auto">
      <p class="text-kailash-gold text-sm md:text-base tracking-[0.3em] uppercase mb-4 font-light">
        Center of the World · Sacred Pilgrimage Journey
      </p>
      <h1 class="font-display text-5xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">
        Mount Kailash
        <span class="block text-kailash-gold mt-2">2026</span>
      </h1>
      <p class="text-xl md:text-2xl text-white/80 mb-4 max-w-3xl mx-auto font-light leading-relaxed">
        Sacred to Four Religions, Connecting India, Tibet & the World
      </p>
      <p class="text-lg text-white/60 mb-8 max-w-2xl mx-auto">
        Tibetan Buddhism · Hinduism · Bön · Jainism
      </p>
      <div class="flex flex-wrap justify-center gap-4 mb-12 text-sm text-white/50">
        <span class="flex items-center gap-1">🏔️ 6,656m Sacred Peak</span>
        <span class="flex items-center gap-1">🚶 52km Kora Circuit</span>
        <span class="flex items-center gap-1">🙏 Four Sacred Traditions</span>
      </div>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/guide" class="bg-kailash-gold text-kailash-dark px-8 py-4 rounded-lg font-semibold hover:bg-kailash-accent transition">
          Start Exploring
        </a>
        <a href="/culture" class="border-2 border-white/30 text-white px-8 py-4 rounded-lg font-semibold hover:bg-white/10 transition">
          Explore Culture
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="bg-kailash-dark py-8 border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <p class="text-3xl md:text-4xl font-bold text-kailash-gold">6,656m</p>
          <p class="text-white/60 text-sm mt-1">Peak Elevation</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold text-kailash-gold">52km</p>
          <p class="text-white/60 text-sm mt-1">Kora Distance</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold text-kailash-gold">5,630m</p>
          <p class="text-white/60 text-sm mt-1">Highest Pass</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold text-kailash-gold">4</p>
          <p class="text-white/60 text-sm mt-1">Sacred Traditions</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-20 bg-kailash-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4">Why Kailash?</h2>
        <p class="text-lg text-gray-600">Center of the World, Pinnacle of Faith</p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-xl transition">
          <div class="text-4xl mb-4">🕉️</div>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3">Four Sacred Traditions</h3>
          <p class="text-gray-600">Tibetan Buddhism, Hinduism, Bön, and Jainism all revere this as the center of the world. The only mountain sacred to all four religions simultaneously.</p>
        </div>
        
        <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-xl transition">
          <div class="text-4xl mb-4">🏔️</div>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3">6,656m Sacred Peak</h3>
          <p class="text-gray-600">An unclimbed sacred summit with a unique pyramid shape. The mysterious swastika mark on its southern face radiates solemn divinity.</p>
        </div>
        
        <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-xl transition">
          <div class="text-4xl mb-4">🚶</div>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3">52km Kora Circuit</h3>
          <p class="text-gray-600">A three-day high-altitude trek crossing the 5,630m Drolma La pass. One circuit equals 600 million recitations of the six-syllable mantra.</p>
        </div>
        
        <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-xl transition">
          <div class="text-4xl mb-4">💧</div>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3">Lake Manasarovar</h3>
          <p class="text-gray-600">One of the world's highest freshwater lakes, source of four great rivers. Known as the "Western Heaven Jade Pool."</p>
        </div>
        
        <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-xl transition">
          <div class="text-4xl mb-4">🌏</div>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3">Global Pilgrims</h3>
          <p class="text-gray-600">Hundreds of thousands of pilgrims gather annually from India, Nepal, China, and across the globe. Different faiths worship here as equals.</p>
        </div>
        
        <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-xl transition">
          <div class="text-4xl mb-4">📅</div>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3">2026 Pilgrimage</h3>
          <p class="text-gray-600">Carefully planned itineraries with professional teams ensuring your safety. Early bird bookings enjoy exclusive discounts.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Route Preview -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4">52km Kora Route</h2>
        <p class="text-lg text-gray-600">A three-day high-altitude trek starting from Darchen, crossing the 5,630m Drolma La pass, and returning to the starting point. A journey of body and soul.</p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-kailash-light rounded-2xl p-8">
          <div class="text-kailash-gold text-4xl font-bold mb-4">1</div>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3">Day 1: Darchen → Dirapuk (20km)</h3>
          <p class="text-gray-600">A gentle start, acclimatizing to altitude while viewing the north face of the sacred mountain.</p>
        </div>
        
        <div class="bg-kailash-light rounded-2xl p-8">
          <div class="text-kailash-gold text-4xl font-bold mb-4">2</div>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3">Day 2: Dirapuk → Zongchu (18km)</h3>
          <p class="text-gray-600">Crossing Drolma La pass — the most challenging day.</p>
        </div>
        
        <div class="bg-kailash-light rounded-2xl p-8">
          <div class="text-kailash-gold text-4xl font-bold mb-4">3</div>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3">Day 3: Zongchu → Darchen (14km)</h3>
          <p class="text-gray-600">An easy return, completing the sacred kora circuit.</p>
        </div>
      </div>
      
      <div class="text-center mt-12">
        <a href="/routes" class="inline-flex items-center bg-kailash-gold text-kailash-dark px-8 py-3 rounded-lg font-semibold hover:bg-kailash-accent transition">
          View Detailed Route
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-20 bg-kailash-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4">Pilgrim Voices</h2>
        <p class="text-lg text-gray-600">Real experiences from pilgrims around the world</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white rounded-2xl p-8 shadow-md">
          <div class="text-kailash-gold mb-4">★★★★★</div>
          <p class="text-gray-700 mb-6 italic">"The moment I crossed Drolma La pass, I finally understood the power of faith. At 5,630 meters, this is the highest point of my life, and also the highest point of my soul."</p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-kailash-gold/20 rounded-full flex items-center justify-center font-bold">Z</div>
            <div>
              <p class="font-medium">Mr. Zhang</p>
              <p class="text-sm text-gray-500">Beijing · September 2025</p>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-md">
          <div class="text-kailash-gold mb-4">★★★★★</div>
          <p class="text-gray-700 mb-6 italic">"I completed the kora with my 70-year-old mother. Watching her pray at Dirapuk Monastery was the most beautiful sight I've ever seen."</p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-kailash-gold/20 rounded-full flex items-center justify-center font-bold">L</div>
            <div>
              <p class="font-medium">Ms. Li</p>
              <p class="text-sm text-gray-500">Chengdu · June 2025</p>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-md">
          <div class="text-kailash-gold mb-4">★★★★★</div>
          <p class="text-gray-700 mb-6 italic">"Kailash is the abode of Lord Shiva. I waited 3 years for the permit. The 52km kora changed my perspective on life forever."</p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-kailash-gold/20 rounded-full flex items-center justify-center font-bold">R</div>
            <div>
              <p class="font-medium">Rajesh Kumar</p>
              <p class="text-sm text-gray-500">Delhi, India · 2024</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery Preview -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4">Sacred Mountain Gallery</h2>
        <p class="text-lg text-gray-600">Capturing the sacred land through images</p>
      </div>

      <div class="grid md:grid-cols-3 gap-4">
        <div class="relative aspect-[4/3] rounded-xl overflow-hidden">
          <img src="/images/kailash-golden.jpg" alt="Golden Mountain" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="relative aspect-[4/3] rounded-xl overflow-hidden md:row-span-2">
          <img src="/images/kailash-aerial.jpg" alt="Aerial View of Kailash" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="relative aspect-[4/3] rounded-xl overflow-hidden">
          <img src="/images/kailash-lake.jpg" alt="Lake Manasarovar" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="relative aspect-[4/3] rounded-xl overflow-hidden">
          <img src="/images/kailash-sunrise.jpg" alt="Sunrise Peak" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="relative aspect-[4/3] rounded-xl overflow-hidden">
          <img src="/images/kailash-yaks.jpg" alt="Grassland Yaks" class="w-full h-full object-cover" loading="lazy" />
        </div>
      </div>

      <div class="text-center mt-12">
        <a href="/gallery" class="inline-flex items-center bg-kailash-gold text-kailash-dark px-8 py-3 rounded-lg font-semibold hover:bg-kailash-accent transition">
          View Full Gallery
        </a>
      </div>
    </div>
  </section>

  <!-- Trust Badges -->
  <section class="py-16 bg-kailash-light border-t border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-3xl mb-3">🛡️</div>
          <p class="font-medium">Professional Guides</p>
          <p class="text-sm text-gray-500">10+ years high-altitude experience</p>
        </div>
        <div>
          <div class="text-3xl mb-3">❤️</div>
          <p class="font-medium">Medical Support</p>
          <p class="text-sm text-gray-500">Oxygen + Medicine + Rescue</p>
        </div>
        <div>
          <div class="text-3xl mb-3">🤝</div>
          <p class="font-medium">Interfaith Neutral</p>
          <p class="text-sm text-gray-500">Respecting all traditions</p>
        </div>
        <div>
          <div class="text-3xl mb-3">⏰</div>
          <p class="font-medium">24/7 Support</p>
          <p class="text-sm text-gray-500">Always here to help</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Search Section -->
  <section class="py-20 bg-kailash-gold">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-3xl font-bold text-kailash-dark mb-4">Search Kailash</h2>
      <p class="text-kailash-dark/80 mb-8">Type keywords to quickly find what you need</p>
      <SearchBox />
    </div>
  </section>
</Layout>

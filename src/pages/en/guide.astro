  <!-- Cost Breakdown Section -->
  <section class="py-20 px-4 bg-kailash-dark">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">
          Cost Breakdown — Summary
        </h2>
        <p class="text-lg text-white/60 max-w-3xl mx-auto">
          Estimated costs for a Mount Kailash pilgrimage in 2026. Prices are in USD and reflect typical ranges. Actual costs vary by tour operator, group size, season, and level of comfort.
        </p>
        <div class="w-24 h-0.5 bg-kailash-gold mx-auto mt-6"></div>
      </div>

      <div class="bg-white/5 rounded-2xl overflow-hidden border border-white/10">

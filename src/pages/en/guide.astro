          <div class={`bg-white rounded-2xl p-6 md:p-8 shadow-md border-l-8 ${level.color === 'yellow' ? 'border-l-yellow-500' : level.color === 'orange' ? 'border-l-orange-500' : level.color === 'red' ? 'border-l-red-600' : 'border-l-gray-900'}`}>
            <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
              <div>
                <h3 class="font-display text-xl font-bold text-kailash-dark">{level.level}</h3>
                <p class="text-gray-500 text-sm">{level.score}</p>
              </div>
              <span class={`text-xs font-bold px-4 py-1.5 rounded-full ${level.color === 'yellow' ? 'bg-yellow-100 text-yellow-700' : level.color === 'orange' ? 'bg-orange-100 text-orange-700' : level.color === 'red' ? 'bg-red-100 text-red-700' : 'bg-gray-900 text-white'}`}>
                {level.color === 'black' ? 'CRITICAL' : level.color === 'red' ? 'SEVERE' : level.color === 'orange' ? 'MODERATE' : 'MILD'}
              </span>
            </div>
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <div class="mb-3">
                  <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Symptoms</p>
                  <p class="text-gray-700 text-sm leading-relaxed">{level.symptoms}</p>
                </div>
                <div>
                  <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Oxygen Saturation</p>
                  <p class="text-kailash-dark font-bold text-sm">{level.oxygenSaturation}</p>
                </div>
              </div>
              <div>
                <div class="mb-3">
                  <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Required Action</p>
                  <p class={`text-sm leading-relaxed ${level.color === 'red' || level.color === 'black' ? 'text-red-700 font-bold' : 'text-gray-700'}`}>{level.action}</p>
                </div>
                <div>
                  <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Can Continue Kora?</p>
                  <p class={`text-sm font-bold ${level.color === 'red' || level.color === 'black' ? 'text-red-600' : level.color === 'orange' ? 'text-orange-600' : 'text-green-600'}`}>{level.canContinue}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Accommodation Section -->
  <section class="py-20 px-4 bg-kailash-dark">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">
          Accommodation Overview
        </h2>
        <p class="text-lg text-white/60 max-w-3xl mx-auto">
          Accommodation around Mount Kailash ranges from basic guesthouses on the kora route to comfortable hotels in Darchen. Set your expectations appropriately — this is a remote, high-altitude region.
        </p>
        <div class="w-24 h-0.5 bg-kailash-gold mx-auto mt-6"></div>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {accommodationTypes.map(acc => (
          <div class="bg-white/5 rounded-2xl p-8 border border-white/10 hover:border-kailash-gold/30 transition-all duration-300">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-3xl">{acc.icon}</span>
              <div>
                <h3 class="font-display text-xl font-bold text-white">{acc.type}</h3>
                <span class="text-kailash-gold text-sm">{acc.rating} comfort level</span>
              </div>
            </div>
            <p class="text-white/70 text-sm leading-relaxed mb-3">{acc.desc}</p>
            <p class="text-white/40 text-xs"><span class="text-kailash-gold">Locations:</span> {acc.locations}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Accommodation Pricing Details -->
  <section class="py-20 px-4 bg-kailash-light">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-kailash-dark mb-4">
          Accommodation Pricing — Darchen, Dira-puk & Zunzhepu
        </h2>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto">
          Detailed accommodation options and pricing at each stop along the Kailash kora route. Prices are in both USD and Chinese Yuan (RMB) for the 2026 season. Horse Year pricing may be 30-50% higher.
        </p>
        <div class="w-24 h-0.5 bg-kailash-gold mx-auto mt-6"></div>
      </div>

      <div class="space-y-8">
        {accommodationPricingDetailed.map(loc => (
          <div class="bg-white rounded-2xl p-6 md:p-8 shadow-md hover:shadow-lg transition-all duration-300">
            <div class="flex items-center gap-3 mb-4">
              <span class="text-3xl">{loc.icon}</span>
              <h3 class="font-display text-xl font-bold text-kailash-dark">{loc.location}</h3>
            </div>
            <div class="space-y-3 mb-4">
              {loc.options.map(opt => (
                <div class="flex flex-wrap items-start justify-between gap-3 p-4 bg-kailash-light rounded-xl">
                  <div class="flex-1">
                    <p class="font-bold text-kailash-dark text-sm">{opt.type}</p>
                    <p class="text-gray-500 text-xs leading-relaxed mt-1">{opt.desc}</p>
                  </div>
                  <div class="text-right shrink-0">
                    <p class="text-kailash-gold font-bold text-sm">{opt.priceUSD}</p>
                    <p class="text-gray-400 text-xs">{opt.priceRMB}</p>
                  </div>
                </div>
              ))}
            </div>
            <div class="p-3 bg-kailash-gold/10 rounded-lg border border-kailash-gold/20">
              <p class="text-gray-500 text-xs leading-relaxed"><span class="text-kailash-dark font-bold">Note:</span> {loc.note}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Transport Section -->
  <section class="py-20 px-4 bg-kailash-dark">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">
          Getting There — Transport Overview
        </h2>
        <p class="text-lg text-white/60 max-w-3xl mx-auto">
          Reaching Mount Kailash is an expedition in itself. The journey across the Tibetan Plateau is one of the world's great overland adventures.
        </p>
        <div class="w-24 h-0.5 bg-kailash-gold mx-auto mt-6"></div>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {transportOptions.map(transport => (
          <div class="bg-white/5 rounded-2xl p-8 border border-white/10 hover:border-kailash-gold/30 transition-all duration-300">
            <h3 class="font-display text-xl font-bold text-kailash-gold mb-3">{transport.mode}</h3>
            <p class="text-white/70 text-sm leading-relaxed mb-3">{transport.details}</p>
            <p class="text-kailash-gold text-sm font-medium">Duration: {transport.duration}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Transportation Guide from Major Hubs -->
  <section class="py-20 px-4 bg-kailash-light">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-kailash-dark mb-4">
          Detailed Transportation Guide — Routes from International Hubs
        </h2>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto">
          Comprehensive route options from Delhi (India), Kathmandu (Nepal), and major Chinese cities. Includes costs in USD and RMB, durations, and practical tips for each route.
        </p>
        <div class="w-24 h-0.5 bg-kailash-gold mx-auto mt-6"></div>
      </div>

      <div class="space-y-8">
        {transportRoutesDetailed.map(hub => (
          <div class="bg-white rounded-2xl p-6 md:p-8 shadow-md">
            <div class="flex items-center gap-3 mb-6">
              <span class="text-4xl">{hub.icon}</span>
              <h3 class="font-display text-xl font-bold text-kailash-dark">{hub.origin}</h3>
            </div>
            <div class="space-y-4">
              {hub.routeOptions.map(opt => (
                <div class="p-5 bg-kailash-light rounded-xl hover:bg-kailash-gold/10 transition">
                  <div class="flex flex-wrap items-start justify-between gap-3 mb-2">
                    <h4 class="font-bold text-kailash-dark text-sm">{opt.route}</h4>
                    <div class="text-right shrink-0">
                      <p class="text-kailash-gold font-bold text-sm">{opt.costUSD}</p>
                      <p class="text-gray-400 text-xs">{opt.costRMB}</p>
                    </div>
                  </div>
                  <p class="text-gray-600 text-xs leading-relaxed mb-2">{opt.steps}</p>
                  <div class="flex flex-wrap items-center gap-4 text-xs">
                    <span class="text-kailash-gold font-medium">Duration: {opt.duration}</span>
                    <span class="text-gray-400">Tip: {opt.tips}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

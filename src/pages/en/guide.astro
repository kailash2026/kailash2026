        </a>
        <a href="/en/culture" class="inline-block bg-kailash-dark text-white px-8 py-4 rounded-2xl font-bold text-lg hover:bg-kailash-dark/90 transition shadow-lg">
          Discover Sacred Culture
        </a>
        <a href="/en/stories" class="inline-block border border-kailash-dark/20 text-kailash-dark px-8 py-4 rounded-2xl font-bold text-lg hover:bg-kailash-dark/5 transition">

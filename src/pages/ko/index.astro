---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Features from '../../components/Features.astro';
import RoutePreview from '../../components/RoutePreview.astro';
import SearchBox from '../../components/SearchBox.astro';
---

<Layout title="카일라스 2026 - 글로벌 순례 플랫폼 | 티베트의 성산 카일라스 순례" description="카일라스 2026: 전 세계 순례자를 연결하는 글로벌 플랫폼. 힌두교, 티베트 불교, 본교, 자이나교의 성지 카일라스 산. 인도, 네팔, 중국, 전 세계 순례자와 함께 변화의 여정을 시작하세요.">
  <Hero />
  <!-- Stats Bar -->
  <section class="bg-kailash-dark py-8 border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center" data-lang-content="ko">
        <div>
          <p class="text-3xl md:text-4xl font-bold text-kailash-gold">6656m</p>
          <p class="text-white/60 text-sm mt-1">카일라스 산 해발</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold text-kailash-gold">52km</p>
          <p class="text-white/60 text-sm mt-1">코라(순례길) 전체</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold text-kailash-gold">5630m</p>
          <p class="text-white/60 text-sm mt-1">최고 지점 도마라 고개</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold text-kailash-gold">4</p>
          <p class="text-white/60 text-sm mt-1">종교의 성지</p>
        </div>
      </div>
    </div>
  </section>
  
  <Features />
  <RoutePreview />
  
  <!-- Testimonials Section -->
  <section class="py-20 bg-kailash-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-2" data-lang-content="ko">순례자의 목소리</h2>
        <p class="text-lg text-gray-600" data-lang-content="ko">전 세계에서 온 순례자들이 전하는 진실한 체험</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Testimonial 1 -->
        <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-xl transition-shadow">
          <div class="flex items-center gap-1 mb-4">
            <span class="text-kailash-gold">★★★★★</span>
          </div>
          <p class="text-gray-700 mb-6 leading-relaxed italic">
            "도마라 고개를 넘는 순간, 신앙의 힘이 무엇인지 처음으로 이해했습니다. 해발 5630미터, 이것은 제 인생에서 가장 높은 곳이자 동시에 마음의 가장 높은 곳입니다."
          </p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-kailash-gold/20 rounded-full flex items-center justify-center text-kailash-dark font-bold">김</div>
            <div>
              <p class="font-medium text-kailash-dark">김 씨</p>
              <p class="text-sm text-gray-500">서울 · 2025년 9월</p>
            </div>
          </div>
        </div>

        <!-- Testimonial 2 -->
        <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-xl transition-shadow">
          <div class="flex items-center gap-1 mb-4">
            <span class="text-kailash-gold">★★★★★</span>
          </div>
          <p class="text-gray-700 mb-6 leading-relaxed italic">
            "70세 어머니와 함께 코라를 완주했습니다. 디라푹 사원에서 어머니가 손을 모으는 모습은 제가 지금까지 본 것 중 가장 아름다운 광경이었습니다. 순례는 나이와 상관없이 마음의 소원과 관련된 것입니다."
          </p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-kailash-gold/20 rounded-full flex items-center justify-center text-kailash-dark font-bold">박</div>
            <div>
              <p class="font-medium text-kailash-dark">박 씨</p>
              <p class="text-sm text-gray-500">부산 · 2025년 6월</p>
            </div>
          </div>
        </div>

        <!-- Testimonial 3 -->
        <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-xl transition-shadow">
          <div class="flex items-center gap-1 mb-4">
            <span class="text-kailash-gold">★★★★★</span>
          </div>
          <p class="text-gray-700 mb-6 leading-relaxed italic">
            "카일라스는 시바신의 거처입니다. 허가증을 받는 데 3년을 기다렸습니다. 52km 코라가 제 인생관을 영원히 바꾸었습니다."
          </p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-kailash-gold/20 rounded-full flex items-center justify-center text-kailash-dark font-bold">R</div>
            <div>
              <p class="font-medium text-kailash-dark">Rajesh Kumar</p>
              <p class="text-sm text-gray-500">델리, 인도 · 2024</p>
            </div>
          </div>
        </div>
      </div>

      <div class="text-center mt-12">
        <a href="/stories" class="inline-flex items-center text-kailash-gold font-semibold hover:text-kailash-dark transition">
          <span data-lang-content="ko">순례자 이야기 더 보기</span>
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Gallery Preview -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-2" data-lang-content="ko">카일라스 영상</h2>
        <p class="text-lg text-gray-600" data-lang-content="ko">영상으로 기록하는 신성한 땅</p>
      </div>

      <div class="grid md:grid-cols-3 gap-4">
        <div class="relative aspect-[4/3] rounded-xl overflow-hidden group">
          <img src="/images/kailash-golden.jpg" alt="황금빛 산" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity">
            <p class="absolute bottom-4 left-4 text-white font-medium">황금빛 산</p>
          </div>
        </div>
        <div class="relative aspect-[4/3] rounded-xl overflow-hidden group md:row-span-2">
          <img src="/images/kailash-aerial.jpg" alt="항공 촬영 카일라스" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity">
            <p class="absolute bottom-4 left-4 text-white font-medium">항공 촬영 카일라스</p>
          </div>
        </div>
        <div class="relative aspect-[4/3] rounded-xl overflow-hidden group">
          <img src="/images/kailash-lake.jpg" alt="마나사로와르 호수" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity">
            <p class="absolute bottom-4 left-4 text-white font-medium">성호 마나사로와르</p>
          </div>
        </div>
        <div class="relative aspect-[4/3] rounded-xl overflow-hidden group">
          <img src="/images/kailash-sunrise.jpg" alt="일출 정상" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity">
            <p class="absolute bottom-4 left-4 text-white font-medium">일출 정상</p>
          </div>
        </div>
        <div class="relative aspect-[4/3] rounded-xl overflow-hidden group">
          <img src="/images/kailash-yaks.jpg" alt="초원 야크" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity">
            <p class="absolute bottom-4 left-4 text-white font-medium">초원 야크</p>
          </div>
        </div>
      </div>

      <div class="text-center mt-12">
        <a href="/gallery" class="inline-flex items-center bg-kailash-gold text-kailash-dark px-8 py-3 rounded-lg font-semibold hover:bg-kailash-accent transition">
          <span data-lang-content="ko">갤러리 보기</span>
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Quick Links / Trust Badges -->
  <section class="py-16 bg-kailash-light border-t border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div class="flex flex-col items-center">
          <div class="w-12 h-12 bg-kailash-gold/20 rounded-full flex items-center justify-center mb-3">
            <svg class="w-6 h-6 text-kailash-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <p class="font-medium text-kailash-dark" data-lang-content="ko">전문 가이드 팀</p>
          <p class="text-sm text-gray-500" data-lang-content="ko">10년 이상 고원 경험</p>
        </div>
        <div class="flex flex-col items-center">
          <div class="w-12 h-12 bg-kailash-gold/20 rounded-full flex items-center justify-center mb-3">
            <svg class="w-6 h-6 text-kailash-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
          </div>
          <p class="font-medium text-kailash-dark" data-lang-content="ko">의료 지원 완비</p>
          <p class="text-sm text-gray-500" data-lang-content="ko">산소+의약품+구조</p>
        </div>
        <div class="flex flex-col items-center">
          <div class="w-12 h-12 bg-kailash-gold/20 rounded-full flex items-center justify-center mb-3">
            <svg class="w-6 h-6 text-kailash-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <p class="font-medium text-kailash-dark" data-lang-content="ko">종교 간 중립</p>
          <p class="text-sm text-gray-500" data-lang-content="ko">모든 신앙 전통 존중</p>
        </div>
        <div class="flex flex-col items-center">
          <div class="w-12 h-12 bg-kailash-gold/20 rounded-full flex items-center justify-center mb-3">
            <svg class="w-6 h-6 text-kailash-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <p class="font-medium text-kailash-dark" data-lang-content="ko">24시간 대응</p>
          <p class="text-sm text-gray-500" data-lang-content="ko">상시 지원</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Search Section -->
  <section class="py-20 bg-kailash-gold">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-3xl font-bold text-kailash-dark mb-4">
        <span data-lang-content="ko">카일라스 검색</span>
      </h2>
      <p class="text-kailash-dark/80 mb-8">
        <span data-lang-content="ko">키워드를 입력하여 필요한 정보를 빠르게 찾기</span>
      </p>
      <SearchBox />
    </div>
  </section>
</Layout>

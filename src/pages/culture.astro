                  <h4 class="font-semibold text-gray-600">English Translation</h4>
                </div>
                <div class="bg-gray-50 border-l-4 border-gray-300 p-6 rounded-r-xl">
                  <div class="prose prose-lg max-w-none">
                    {quote.fullQuoteEn.split('\n\n').map((paragraph, pIdx) => (
                      <p class="text-gray-600 leading-relaxed mb-4 last:mb-0 italic">{paragraph}</p>
                    ))}
                  </div>
                </div>
              </div>

              <!-- Interpretation -->
              <div class="bg-kailash-light rounded-xl p-6">
                <div class="flex items-center gap-2 mb-4">
                  <span class="w-8 h-8 bg-kailash-dark rounded-full flex items-center justify-center text-white font-bold">解</span>
                  <h4 class="font-semibold text-kailash-dark">深度解读</h4>
                </div>
                <div class="prose max-w-none">
                  {quote.interpretation.split('\n\n').map((paragraph, pIdx) => (
                    <p class="text-gray-700 leading-relaxed mb-3 last:mb-0">{paragraph}</p>
                  ))}
                </div>
                <div class="mt-4 pt-4 border-t border-kailash-gold/20">
                  <p class="text-sm text-gray-500 italic">{quote.interpretationEn}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Seasons -->
  <section class="py-20 bg-kailash-light">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display text-4xl font-bold text-kailash-dark mb-2">四季冈仁波齐</h2>
        <p class="text-lg text-gray-500 italic">Sacred Mountain Through the Seasons</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {seasons.map((season, index) => (
          <div class="bg-white rounded-2xl p-6 shadow-md hover:shadow-lg transition-shadow">
            <div class="flex items-center justify-between mb-4">
              <h3 class="font-display text-xl font-bold text-kailash-dark">{season.name}</h3>
              <span class="text-sm text-gray-500 italic">{season.nameEn}</span>
            </div>
            <p class="text-kailash-gold font-medium text-sm mb-3">{season.months}</p>
            <p class="text-gray-600 text-sm mb-4">{season.description}</p>
            <p class="text-gray-500 text-xs italic mb-4">{season.descriptionEn}</p>
            <span class="inline-block bg-kailash-gold/10 text-kailash-dark text-xs px-3 py-1 rounded-full">{season.highlight}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-kailash-gold">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-3xl font-bold text-kailash-dark mb-4" data-lang-content="zh">
        准备好亲身感受冈仁波齐的力量了吗？
      </h2>
      <h2 class="font-display text-3xl font-bold text-kailash-dark mb-4" data-lang-content="en" style="display: none;">
        Ready to Experience the Power of Kailash?
      </h2>
      <p class="text-kailash-dark/80 text-lg mb-8 leading-relaxed" data-lang-content="zh">
        了解历史是为了更好地理解当下。当您踏上转山之路时，您不仅是在行走，更是在延续三千年的信仰传承。
      </p>
      <p class="text-kailash-dark/80 text-lg mb-8 leading-relaxed" data-lang-content="en" style="display: none;">
        Understanding history helps us better understand the present. When you embark on the Kora, you are not just walking—you are continuing a 3000-year legacy of faith.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/guide" class="bg-kailash-dark text-white px-8 py-3 rounded-lg font-semibold hover:bg-kailash-dark/90 transition" data-lang-content="zh">
          查看朝圣攻略
        </a>
        <a href="/guide" class="bg-kailash-dark text-white px-8 py-3 rounded-lg font-semibold hover:bg-kailash-dark/90 transition" data-lang-content="en" style="display: none;">
          View Pilgrimage Guide
        </a>
        <a href="/routes" class="bg-white text-kailash-dark px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition" data-lang-content="zh">
          了解转山路线
        </a>
        <a href="/routes" class="bg-white text-kailash-dark px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition" data-lang-content="en" style="display: none;">
          Explore Kora Route
        </a>
      </div>
    </div>
  </section>
</Layout>

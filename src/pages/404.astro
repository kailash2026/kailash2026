---
import Layout from '../layouts/Layout.astro';
---

<Layout title="页面未找到">
  <div class="min-h-[60vh] flex items-center justify-center bg-kailash-light">
    <div class="text-center px-4">
      <div class="text-9xl font-display font-bold text-kailash-gold/30 mb-4">404</div>
      <h1 class="text-4xl font-bold text-kailash-dark mb-4">页面未找到</h1>
      <p class="text-gray-600 mb-8">您访问的页面似乎不存在，或者已被移除</p>
      <a href="/" class="inline-flex items-center bg-kailash-gold text-kailash-dark px-8 py-3 rounded-lg font-semibold hover:bg-kailash-accent transition">
        返回首页
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
      </a>
    </div>
  </div>
</Layout>

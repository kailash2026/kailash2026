---
import Layout from '../layouts/Layout.astro';

const contactInfo = [
  {
    icon: "📧",
    title: "电子邮件",
    titleEn: "Email",
    content: "kailash2026Lucas@outlook.com",
    desc: "对网站意见建议都可以发邮箱，24小时内回复",
    descEn: "Send feedback or suggestions, reply within 24 hours",
    action: "发送邮件",
    actionEn: "Send Email",
    link: "mailto:kailash2026Lucas@outlook.com"
  }
];

const officeHours = [
  { day: "周一至周五", dayEn: "Mon - Fri", time: "09:00 - 18:00" },
  { day: "周六", dayEn: "Saturday", time: "10:00 - 16:00" },
  { day: "周日", dayEn: "Sunday", time: "休息", timeEn: "Closed" }
];
---

<Layout title="联系我们 - Kailash 2026" description="联系冈仁波齐2026朝圣平台：邮件咨询、微信联系。朝圣季节提供24小时紧急服务热线，快速响应您的所有疑问。">
  <!-- Hero: Photo on top, content below -->
  <section class="relative bg-kailash-dark">
    <!-- Full-width photo -->
    <div class="relative w-full h-[45vh] lg:h-[55vh]">
      <div class="absolute inset-0 bg-[url('/images/kailash-prairie.webp')] bg-cover bg-center"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-kailash-dark"></div>
    </div>
    
    <!-- Content below photo -->
    <div class="relative -mt-20 z-10 px-4 sm:px-6 lg:px-8 pb-16">
      <div class="max-w-7xl mx-auto text-center">
        <h1 class="font-display text-5xl md:text-6xl font-bold text-white mb-4">
          <span data-lang-content="zh">联系我们</span>
          <span data-lang-content="en" style="display: none;">Contact Us</span>
        </h1>
        <p class="text-xl text-white/60 max-w-3xl mx-auto">
          <span data-lang-content="zh">有任何问题或特殊需求，我们随时为您服务</span>
          <span data-lang-content="en" style="display: none;">Have questions or special needs? We are here for you anytime</span>
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Methods -->
  <section class="py-20 bg-kailash-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-8">
        {contactInfo.map(method => (
          <div class="bg-white rounded-2xl p-8 shadow-lg text-center hover:shadow-xl transition-shadow">
            <div class="text-5xl mb-4">{method.icon}</div>
            <h3 class="font-display text-xl font-bold text-kailash-dark mb-2">
              <span data-lang-content="zh">{method.title}</span>
              <span data-lang-content="en" style="display: none;">{method.titleEn}</span>
            </h3>
            <p class="text-kailash-gold font-semibold text-lg mb-1">{method.content}</p>
            <p class="text-gray-500 text-sm mb-6">
              <span data-lang-content="zh">{method.desc}</span>
              <span data-lang-content="en" style="display: none;">{method.descEn}</span>
            </p>
            <a href={method.link} class="inline-block bg-kailash-gold text-kailash-dark px-6 py-2 rounded-lg font-medium hover:bg-kailash-accent transition">
              <span data-lang-content="zh">{method.action}</span>
              <span data-lang-content="en" style="display: none;">{method.actionEn}</span>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Office Hours -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-display text-3xl font-bold text-kailash-dark mb-6">
            <span data-lang-content="zh">工作时间</span>
            <span data-lang-content="en" style="display: none;">Office Hours</span>
          </h2>
          <div class="space-y-4">
            {officeHours.map(schedule => (
              <div class="flex justify-between items-center py-3 border-b border-gray-100">
                <span class="font-medium text-kailash-dark">
                  <span data-lang-content="zh">{schedule.day}</span>
                  <span data-lang-content="en" style="display: none;">{schedule.dayEn}</span>
                </span>
                <span class="text-gray-600">
                  <span data-lang-content="zh">{schedule.time}</span>
                  <span data-lang-content="en" style="display: none;">{schedule.timeEn}</span>
                </span>
              </div>
            ))}
          </div>
          <div class="mt-8 p-4 bg-amber-50 rounded-xl">
            <p class="text-amber-800 text-sm">
              <span class="font-semibold" data-lang-content="zh">💡 提示：</span>
              <span class="font-semibold" data-lang-content="en" style="display: none;">💡 Tip:</span>
              <span data-lang-content="zh">朝圣季节（5-10月）期间，我们提供7×24小时紧急服务热线。</span>
              <span data-lang-content="en" style="display: none;">During the pilgrimage season (May-Oct), we provide a 7×24 emergency hotline.</span>
            </p>
          </div>
        </div>
        <div class="bg-kailash-light rounded-2xl p-8">
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-4">
            <span data-lang-content="zh">快速回复承诺</span>
            <span data-lang-content="en" style="display: none;">Fast Response Promise</span>
          </h3>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <div>
                <p class="font-medium">
                  <span data-lang-content="zh">邮件咨询</span>
                  <span data-lang-content="en" style="display: none;">Email Inquiry</span>
                </p>
                <p class="text-gray-600 text-sm">
                  <span data-lang-content="zh">24小时内回复</span>
                  <span data-lang-content="en" style="display: none;">Reply within 24 hours</span>
                </p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <div>
                <p class="font-medium">
                  <span data-lang-content="zh">微信咨询</span>
                  <span data-lang-content="en" style="display: none;">WeChat Inquiry</span>
                </p>
                <p class="text-gray-600 text-sm">
                  <span data-lang-content="zh">工作时间内2小时内回复</span>
                  <span data-lang-content="en" style="display: none;">Reply within 2 hours during work time</span>
                </p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <div>
                <p class="font-medium">
                  <span data-lang-content="zh">电话咨询</span>
                  <span data-lang-content="en" style="display: none;">Phone Inquiry</span>
                </p>
                <p class="text-gray-600 text-sm">
                  <span data-lang-content="zh">工作时间内即时接听</span>
                  <span data-lang-content="en" style="display: none;">Answered instantly during work time</span>
                </p>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-kailash-gold">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-3xl font-bold text-kailash-dark mb-4">
        <span data-lang-content="zh">准备好开启您的朝圣之旅了吗？</span>
        <span data-lang-content="en" style="display: none;">Ready to start your pilgrimage journey?</span>
      </h2>
      <p class="text-kailash-dark/80 mb-8">
        <span data-lang-content="zh">有任何疑问，欢迎随时联系我们</span>
        <span data-lang-content="en" style="display: none;">Have any questions? Feel free to contact us anytime</span>
      </p>
      <a href="mailto:kailash2026Lucas@outlook.com" class="inline-flex items-center bg-kailash-dark text-white px-8 py-4 rounded-lg font-semibold text-lg hover:bg-kailash-dark/90 transition gap-2">
        <span data-lang-content="zh">发送邮件</span>
        <span data-lang-content="en" style="display: none;">Send Email</span>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
      </a>
    </div>
  </section>
</Layout>

---
const features = [
  {
    title: "Sacred to Four Religions / 四大宗教圣地",
    description: "Mount Kailash is revered by Hinduism, Tibetan Buddhism, Bön, and Jainism. Pilgrims from across the world meet here to complete the sacred Kora together. / 冈仁波齐是印度教、藏传佛教、苯教、耆那教共同尊奉的神山。来自世界各地的朝圣者在此相遇，共同完成神圣的转山之旅。",
    link: "/culture",
    icon: "🕉️"
  },
  {
    title: "Global Pilgrim Community / 全球朝圣者社区",
    description: "Connect with pilgrims from India, Nepal, China, Europe, and America. Share routes, experiences, and build spiritual connections across borders. / 连接印度、尼泊尔、中国、欧美等地的朝圣者。分享路线经验、信仰故事，建立跨越国界的 spiritual 连接。",
    link: "/stories",
    icon: "🤝"
  },
  {
    title: "International Services / 国际专业服务",
    description: "Multilingual guides familiar with pilgrims from all nations. Medical support, logistics, and oxygen assistance for a safe journey. / 多语言向导团队，熟悉各国朝圣者需求。提供医疗、后勤、氧气支持，让每位朝圣者安全完成心愿。",
    link: "/guide",
    icon: "🌐"
  },
  {
    title: "Premium Kora Experience / 精品转山体验",
    description: "52km outer route from Darchen to 5,630m Dolma La Pass. Flexible group sizes, professional support, walk the path of faith. / 52公里外转路线，从塔尔钦到5630米卓玛拉垭口。灵活成团，专业保障，用脚丈量信仰的高度。",
    link: "/routes",
    icon: "🏔️"
  }
];
---

  <!-- Aerial Background Section -->
  <section class="relative py-24 overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-[url('/images/kailash-aerial.jpg')] bg-cover bg-top opacity-20"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-kailash-light via-kailash-light/95 to-kailash-light"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 max-w-3xl mx-auto">
      <span class="text-kailash-gold text-sm font-semibold tracking-widest uppercase mb-4 block">Why Kailash 2026 / 为什么选择 Kailash 2026</span>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-kailash-dark mb-6">A Spiritual Home for Global Pilgrims / 全球朝圣者的精神家园</h2>
      <p class="text-lg text-gray-600 leading-relaxed">
        Whether you are Hindu, Buddhist, Bön practitioner, or Jain, this is your pilgrimage destination. We connect global faith communities with professional services. / 无论你是印度教徒、佛教徒、苯教徒还是耆那教徒，这里都是你的朝圣目的地。我们连接全球信仰者，提供专业服务。
      </p>
    </div>
    
    <!-- Features Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {features.map((feature, index) => (
        <a href={feature.link} class="group bg-white rounded-2xl p-8 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1 border border-gray-100 hover:border-kailash-gold/20">
          <!-- Icon -->
          <div class="w-14 h-14 rounded-xl bg-kailash-gold/10 flex items-center justify-center text-3xl mb-6 group-hover:bg-kailash-gold/20 transition-colors">
            {feature.icon}
          </div>
          
          <!-- Content -->
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3 group-hover:text-kailash-gold transition-colors">
            {feature.title}
          </h3>
          <p class="text-gray-600 text-sm leading-relaxed mb-6">
            {feature.description}
          </p>
          
          <!-- Link -->
          <div class="flex items-center text-kailash-gold font-medium text-sm group/link">
            <span>Learn More / 了解更多</span>
            <svg class="w-4 h-4 ml-1 group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

---
const features = [
  {
    title: "四大宗教圣地",
    description: "冈仁波齐是印度教、藏传佛教、苯教、耆那教共同尊奉的神山。来自世界各地的朝圣者在此相遇，共同完成神圣的转山之旅。",
    link: "/culture",
    icon: "🕉️"
  },
  {
    title: "全球朝圣者社区",
    description: "连接印度、尼泊尔、中国、欧美等地的朝圣者。分享路线经验、信仰故事，建立跨越国界的 spiritual 连接。",
    link: "/stories",
    icon: "🤝"
  },
  {
    title: "国际专业服务",
    description: "多语言向导团队，熟悉各国朝圣者需求。提供医疗、后勤、氧气支持，让每位朝圣者安全完成心愿。",
    link: "/guide",
    icon: "🌐"
  },
  {
    title: "精品转山体验",
    description: "52公里外转路线，从塔尔钦到5630米卓玛拉垭口。灵活成团，专业保障，用脚丈量信仰的高度。",
    link: "/booking",
    icon: "🏔️"
  }
];
---

<section class="py-20 bg-kailash-light">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="font-display text-4xl font-bold text-kailash-dark mb-4">Kailash 2026：全球朝圣者的精神家园</h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        无论你是印度教徒、佛教徒、苯教徒还是耆那教徒，这里都是你的朝圣目的地。我们连接全球信仰者，提供专业服务，让每位朝圣者安全完成心愿
      </p>
    </div>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {features.map((feature) => (
        <a href={feature.link} class="group bg-white rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-1">
          <div class="text-4xl mb-4">{feature.icon}</div>
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3 group-hover:text-kailash-gold transition">
            {feature.title}
          </h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            {feature.description}
          </p>
          <div class="mt-4 flex items-center text-kailash-gold font-medium text-sm">
            了解更多
            <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
          </div>
        </a>
      ))}

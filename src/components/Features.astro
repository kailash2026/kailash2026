---
const features = [
  {
    title: "Sacred to Four Religions",
    description: "Mount Kailash is revered by Hinduism, Tibetan Buddhism, Bön, and Jainism. Pilgrims from across the world meet here to complete the sacred Kora together.",
    link: "/culture",
    icon: "🕉️"
  },
  {
    title: "Global Pilgrim Community",
    description: "Connect with pilgrims from India, Nepal, China, Europe, and America. Share routes, experiences, and build spiritual connections across borders.",
    link: "/stories",
    icon: "🤝"
  },
  {
    title: "International Services",
    description: "Multilingual guides familiar with pilgrims from all nations. Medical support, logistics, and oxygen assistance for a safe journey.",
    link: "/guide",
    icon: "🌐"
  },
  {
    title: "Premium Kora Experience",
    description: "52km outer route from Darchen to 5,630m Dolma La Pass. Flexible group sizes, professional support, walk the path of faith.",
    link: "/booking",
    icon: "🏔️"
  }
];
---

<section class="py-24 bg-kailash-light">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 max-w-3xl mx-auto">
      <span class="text-kailash-gold text-sm font-semibold tracking-widest uppercase mb-4 block">Why Kailash 2026</span>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-kailash-dark mb-6">A Spiritual Home for Global Pilgrims</h2>
      <p class="text-lg text-gray-600 leading-relaxed">
        Whether you are Hindu, Buddhist, Bön practitioner, or Jain, this is your pilgrimage destination. We connect global faith communities with professional services.
      </p>
    </div>
    
    <!-- Features Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {features.map((feature, index) => (
        <a href={feature.link} class="group bg-white rounded-2xl p-8 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1 border border-gray-100 hover:border-kailash-gold/20">
          <!-- Icon -->
          <div class="w-14 h-14 rounded-xl bg-kailash-gold/10 flex items-center justify-center text-3xl mb-6 group-hover:bg-kailash-gold/20 transition-colors">
            {feature.icon}
          </div>
          
          <!-- Content -->
          <h3 class="font-display text-xl font-bold text-kailash-dark mb-3 group-hover:text-kailash-gold transition-colors">
            {feature.title}
          </h3>
          <p class="text-gray-600 text-sm leading-relaxed mb-6">
            {feature.description}
          </p>
          
          <!-- Link -->
          <div class="flex items-center text-kailash-gold font-medium text-sm group/link">
            <span>Learn More</span>
            <svg class="w-4 h-4 ml-1 group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

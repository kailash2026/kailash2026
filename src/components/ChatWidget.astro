<!-- Chat Widget for Kailash 2026 -->
<div id="kailash-chat-widget" class="kailash-chat-widget">
  <!-- Chat Bubble Button -->
  <button id="chat-bubble" class="kailash-chat-bubble" aria-label="打开AI助手">
    <svg id="chat-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
    </svg>
    <span id="chat-bubble-label" class="text-xs font-medium">问小冈</span>
  </button>

  <!-- Chat Window -->
  <div id="chat-window" class="kailash-chat-window hidden">
    <!-- Header -->
    <div class="kailash-chat-header">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 bg-kailash-gold/20 rounded-full flex items-center justify-center text-lg">🏔️</div>
        <div>
          <h3 class="font-bold text-sm text-white">小冈 · AI朝圣助手</h3>
          <p class="text-xs text-white/50">Kailash 2026</p>
        </div>
      </div>
      <button id="chat-close" class="text-white/50 hover:text-white transition p-1" aria-label="关闭">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Quick Questions -->
    <div id="quick-questions" class="kailash-chat-quick">
      <p class="text-xs text-gray-400 mb-3">💡 试试问我：</p>
      <div class="flex flex-wrap gap-2">
        <button class="quick-q-btn" data-q="转山需要准备什么装备？">🎒 转山装备</button>
        <button class="quick-q-btn" data-q="2026年马年转山有什么特别？">🐎 马年转山</button>
        <button class="quick-q-btn" data-q="高原反应怎么预防和应对？">⚠️ 高反应对</button>
        <button class="quick-q-btn" data-q="外圈52公里3天怎么走？">🗺️ 路线规划</button>
        <button class="quick-q-btn" data-q="签证和入藏函怎么办？">📋 签证办理</button>
        <button class="quick-q-btn" data-q="从拉萨到冈仁波齐怎么去？">🚙 交通方式</button>
      </div>
    </div>

    <!-- Messages -->
    <div id="chat-messages" class="kailash-chat-messages">
      <div class="chat-msg assistant">
        <div class="chat-bubble">
          你好！我是小冈 🏔️<br/>冈仁波齐转山有什么想了解的？路线、装备、高反、签证……都可以问我。
        </div>
      </div>
    </div>

    <!-- Input -->
    <div class="kailash-chat-input">
      <input
        type="text"
        id="chat-input"
        placeholder="输入你的问题……"
        maxlength="500"
        class="chat-input-field"
        autocomplete="off"
      />
      <button id="chat-send" class="chat-send-btn" aria-label="发送">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
        </svg>
      </button>
    </div>
  </div>
</div>

<style>
  .kailash-chat-widget {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 9999;
    font-family: system-ui, -apple-system, sans-serif;
  }
  .kailash-chat-bubble {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    background: linear-gradient(135deg, #B8956A, #8B6914);
    border: none;
    cursor: pointer;
    box-shadow: 0 4px 20px rgba(184, 149, 106, 0.4);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1px;
    transition: transform 0.2s, box-shadow 0.2s;
    color: white;
  }
  .kailash-chat-bubble:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 28px rgba(184, 149, 106, 0.55);
  }
  .kailash-chat-bubble:active {
    transform: scale(0.95);
  }

  .kailash-chat-window {
    position: fixed;
    bottom: 5.5rem;
    right: 1.5rem;
    width: 380px;
    max-width: calc(100vw - 2rem);
    height: 560px;
    max-height: calc(100vh - 7rem);
    background: #1a1a1a;
    border-radius: 20px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .kailash-chat-header {
    background: linear-gradient(135deg, #0F0E0D, #1a1a1a);
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .kailash-chat-quick {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    background: #121212;
  }
  .quick-q-btn {
    font-size: 0.75rem;
    padding: 0.4rem 0.75rem;
    border-radius: 100px;
    border: 1px solid rgba(255,255,255,0.15);
    background: transparent;
    color: rgba(255,255,255,0.7);
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .quick-q-btn:hover {
    border-color: #B8956A;
    color: #B8956A;
    background: rgba(184,149,106,0.08);
  }

  .kailash-chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .kailash-chat-messages::-webkit-scrollbar { width: 4px; }
  .kailash-chat-messages::-webkit-scrollbar-thumb { background: #333; border-radius: 2px; }

  .chat-msg { display: flex; }
  .chat-msg.user { justify-content: flex-end; }
  .chat-msg.assistant { justify-content: flex-start; }

  .chat-bubble {
    max-width: 85%;
    padding: 0.7rem 1rem;
    border-radius: 16px;
    font-size: 0.9rem;
    line-height: 1.6;
    word-break: break-word;
  }
  .chat-msg.user .chat-bubble {
    background: #B8956A;
    color: #0F0E0D;
    border-bottom-right-radius: 4px;
  }
  .chat-msg.assistant .chat-bubble {
    background: #242424;
    color: #e0e0e0;
    border-bottom-left-radius: 4px;
  }

  .chat-typing {
    display: flex;
    gap: 4px;
    padding: 0.7rem 1rem;
  }
  .chat-typing span {
    width: 6px;
    height: 6px;
    background: #666;
    border-radius: 50%;
    animation: typingBounce 1.4s infinite ease-in-out both;
  }
  .chat-typing span:nth-child(1) { animation-delay: -0.32s; }
  .chat-typing span:nth-child(2) { animation-delay: -0.16s; }
  @keyframes typingBounce {
    0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
    40% { transform: scale(1); opacity: 1; }
  }

  .kailash-chat-input {
    padding: 0.75rem 1rem;
    border-top: 1px solid rgba(255,255,255,0.08);
    display: flex;
    gap: 0.5rem;
    background: #0F0E0D;
  }
  .chat-input-field {
    flex: 1;
    padding: 0.65rem 1rem;
    border-radius: 100px;
    border: 1px solid rgba(255,255,255,0.12);
    background: #1a1a1a;
    color: white;
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.2s;
  }
  .chat-input-field:focus {
    border-color: #B8956A;
  }
  .chat-input-field::placeholder {
    color: #555;
  }
  .chat-send-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: none;
    background: #B8956A;
    color: #0F0E0D;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    flex-shrink: 0;
  }
  .chat-send-btn:hover { background: #C9A56C; }
  .chat-send-btn:disabled { opacity: 0.4; cursor: not-allowed; }

  @media (max-width: 480px) {
    .kailash-chat-window {
      width: 100%;
      height: 100%;
      max-width: 100vw;
      max-height: 100vh;
      bottom: 0;
      right: 0;
      border-radius: 0;
    }
    .kailash-chat-bubble {
      width: 3rem;
      height: 3rem;
      bottom: 1rem;
      right: 1rem;
    }
  }
</style>

<script>
  (function() {
    const bubble = document.getElementById('chat-bubble');
    const windowEl = document.getElementById('chat-window');
    const closeBtn = document.getElementById('chat-close');
    const messages = document.getElementById('chat-messages');
    const input = document.getElementById('chat-input');
    const sendBtn = document.getElementById('chat-send');
    const quickBtns = document.querySelectorAll('.quick-q-btn');
    const quickSection = document.getElementById('quick-questions');

    let isOpen = false;
    let isSending = false;
    let conversationHistory = [];

    function open() {
      isOpen = true;
      windowEl.classList.remove('hidden');
      bubble.classList.add('hidden');
      input.focus();
    }

    function close() {
      isOpen = false;
      windowEl.classList.add('hidden');
      bubble.classList.remove('hidden');
    }

    bubble.addEventListener('click', open);
    closeBtn.addEventListener('click', close);

    // ESC to close
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) close();
    });

    function addMessage(text, role) {
      const div = document.createElement('div');
      div.className = 'chat-msg ' + role;
      div.innerHTML = '<div class="chat-bubble">' + text.replace(/\n/g, '<br/>') + '</div>';
      messages.appendChild(div);
      messages.scrollTop = messages.scrollHeight;
    }

    function showTyping() {
      const div = document.createElement('div');
      div.className = 'chat-msg assistant';
      div.id = 'typing-indicator';
      div.innerHTML = '<div class="chat-typing chat-bubble"><span></span><span></span><span></span></div>';
      messages.appendChild(div);
      messages.scrollTop = messages.scrollHeight;
    }

    function removeTyping() {
      const el = document.getElementById('typing-indicator');
      if (el) el.remove();
    }

    async function sendMessage(text) {
      if (isSending || !text.trim()) return;
      isSending = true;

      // Hide quick questions after first message
      if (quickSection) quickSection.style.display = 'none';

      const userText = text.trim();
      addMessage(userText, 'user');
      conversationHistory.push({ role: 'user', content: userText });
      input.value = '';
      sendBtn.disabled = true;
      showTyping();

      try {
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages: conversationHistory }),
        });

        removeTyping();

        if (!res.ok) {
          const err = await res.json().catch(() => ({}));
          addMessage(err.error || '抱歉，服务暂时不可用。请稍后再试。', 'assistant');
        } else {
          const data = await res.json();
          addMessage(data.reply, 'assistant');
          conversationHistory.push({ role: 'assistant', content: data.reply });
          // Keep history manageable
          if (conversationHistory.length > 20) {
            conversationHistory = conversationHistory.slice(-20);
          }
        }
      } catch {
        removeTyping();
        addMessage('网络好像有问题，请检查连接后重试。', 'assistant');
      }

      isSending = false;
      sendBtn.disabled = false;
      input.focus();
    }

    sendBtn.addEventListener('click', () => sendMessage(input.value));
    input.addEventListener('keypress', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        sendMessage(input.value);
      }
    });

    // Quick question buttons
    quickBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const q = btn.getAttribute('data-q');
        if (q) {
          if (!isOpen) open();
          sendMessage(q);
        }
      });
    });
  })();
</script>

---
const checkpoints = [
  { name: "塔尔钦", altitude: "4560m", day: "起点", distance: "0km" },
  { name: "曲古寺", altitude: "4860m", day: "第1天", distance: "12km" },
  { name: "止热寺", altitude: "5080m", day: "第1天", distance: "22km" },
  { name: "卓玛拉垭口", altitude: "5630m", day: "第2天", distance: "30km", highlight: true },
  { name: "尊最普寺", altitude: "4820m", day: "第2天", distance: "38km" },
  { name: "塔尔钦", altitude: "4560m", day: "终点", distance: "52km" }
];
---

<section class="py-20 bg-kailash-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="font-display text-4xl font-bold text-white mb-4">
          52公里转山道
        </h2>
        <p class="text-gray-400 text-lg mb-8">
          从塔尔钦出发，翻越5630米的卓玛拉垭口，完成三天两夜的心灵洗礼。这不仅是一次身体的挑战，更是一场精神的朝圣。
        </p>
        
        <div class="space-y-4">
          {checkpoints.map((cp, index) => (
            <div class={`flex items-center gap-4 p-4 rounded-lg ${cp.highlight ? 'bg-kailash-gold/20 border border-kailash-gold' : 'bg-white/5'}`}>
              <div class="w-12 h-12 rounded-full bg-kailash-gold/20 flex items-center justify-center text-kailash-gold font-bold">
                {index + 1}
              </div>
              <div class="flex-1">
                <div class="flex justify-between items-center">
                  <h4 class="font-medium text-white">{cp.name}</h4>
                  {cp.highlight && <span class="text-xs bg-kailash-gold text-kailash-dark px-2 py-1 rounded">最高点</span>}
                </div>
                <div class="text-sm text-gray-400 flex gap-4 mt-1">
                  <span>海拔: {cp.altitude}</span>
                  <span>累计: {cp.distance}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
        
        <a href="/routes" class="inline-flex items-center mt-8 text-kailash-gold hover:text-kailash-accent transition">
          查看完整路线详情
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </a>
      </div>
      
      <div class="relative">
        <div class="aspect-[3/4] rounded-2xl overflow-hidden bg-gradient-to-b from-kailash-gold/20 to-kailash-dark">
          <!-- Placeholder for route map/image -->
          <div class="absolute inset-0 flex items-center justify-center text-gray-500">
            <div class="text-center">
              <svg class="w-20 h-20 mx-auto mb-4 text-kailash-gold/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0121 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path></svg>
              <p>路线地图</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

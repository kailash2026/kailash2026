---
export interface Props {
  title: string;
  description?: string;
  descriptionEn?: string;
  image?: string;
  type?: string;
  publishDate?: string;
  modifiedDate?: string;
  author?: string;
  keywords?: string[];
  breadcrumbs?: { name: string; item: string }[];
  faqs?: { question: string; answer: string }[];
}

const {
  title,
  description = "冈仁波齐朝圣之旅 - 世界的中心，信仰的高地。提供专业的神山文化介绍、朝圣攻略和转山路线。",
  descriptionEn = "Mount Kailash Pilgrimage - The center of the world, the height of faith. Sacred mountain culture, pilgrimage guides, and kora routes.",
  image = "/images/og-image.webp",
  type = "website",
  publishDate,
  modifiedDate,
  author = "Kailash 2026",
  keywords = ["冈仁波齐", "Mount Kailash", "Kailash", "朝圣", "pilgrimage", "神山", "sacred mountain", "西藏", "Tibet", "转山", "Kora", "玛旁雍错", "Manasarovar"],
  breadcrumbs,
  faqs,
} = Astro.props;

const siteUrl = "https://kailash2026.com";
const canonicalURL = new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = new URL(image, siteUrl).toString();

// Build bilingual description (Chinese first, with English)
const fullDescription = `${description} | ${descriptionEn}`;

// Schema.org structured data objects (built in frontmatter for proper variable interpolation)
const touristAttractionLd = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  "name": [
    {"@language": "zh", "@value": "冈仁波齐"},
    {"@language": "en", "@value": "Mount Kailash"}
  ],
  "alternateName": ["Kailash", "Kailasa", "Gang Rinpoche", "岗仁波切", "凯拉萨"],
  "description": fullDescription,
  "url": canonicalURL,
  "image": ogImage,
  "additionalType": ["PlaceOfWorship", "LandmarksOrHistoricalBuildings"],
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "31.0675",
    "longitude": "81.3119"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "塔尔钦",
    "addressRegion": "阿里地区",
    "addressCountry": "CN"
  },
  "isAccessibleForFree": true,
  "publicAccess": true,
  "sameAs": [
    "https://en.wikipedia.org/wiki/Mount_Kailash",
    "https://wikidata.org/wiki/Q201071"
  ]
};

const organizationLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Kailash 2026",
  "alternateName": "冈仁波齐2026",
  "url": "https://kailash2026.com",
  "logo": "https://kailash2026.com/favicon.svg",
  "sameAs": [],
  "description": "全球冈仁波齐神山文化平台 | Global Mount Kailash Sacred Mountain Culture Platform",
  "areaServed": {
    "@type": "Place",
    "name": "Mount Kailash",
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": "31.0675",
      "longitude": "81.3119"
    }
  },
  "knowsAbout": [
    "藏传佛教",
    "Tibetan Buddhism",
    "印度教",
    "Hinduism",
    "苯教",
    "Bön",
    "耆那教",
    "Jainism",
    "冈仁波齐",
    "Mount Kailash",
    "Kailash Kora",
    "转山",
    "Pilgrimage"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer service",
    "email": "kailash2026Lucas@outlook.com",
    "availableLanguage": ["Chinese", "English", "Japanese", "Hindi"]
  }
};

// Auto-generate BreadcrumbList from URL path (or use provided breadcrumbs prop)
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const segmentNameMap = {
  'en': 'English', 'ja': '日本語', 'hi': 'हिन्दी',
  'blog': 'Blog', 'guide': 'Guide', 'faq': 'FAQ', 'routes': 'Routes',
  'about': 'About', 'contact': 'Contact', 'gallery': 'Gallery',
  'culture': 'Culture', 'stories': 'Stories', 'ali': 'Ngari',
  'codex': 'Codex', 'horse-year-2026': 'Horse Year 2026',
  'messages': 'Messages', 'offline': 'Offline', 'assistant': 'Assistant',
};
const breadcrumbItems = breadcrumbs || pathSegments.map((seg, i) => {
  const url = siteUrl + '/' + pathSegments.slice(0, i + 1).join('/');
  const name = segmentNameMap[seg] || seg.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
  return { name, item: url };
});

const breadcrumbListLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': [
    { '@type': 'ListItem', 'position': 1, 'name': 'Kailash 2026', 'item': siteUrl + '/' },
    ...breadcrumbItems.map((item, index) => ({
      '@type': 'ListItem',
      'position': index + 2,
      'name': item.name,
      'item': item.item,
    })),
  ],
};

// FAQPage structured data if faqs are provided
const faqPageLd = faqs && faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  'mainEntity': faqs.map((item) => ({
    '@type': 'Question',
    'name': item.question,
    'acceptedAnswer': {
      '@type': 'Answer',
      'text': item.answer,
    },
  })),
} : null;
---

<!-- Basic Meta -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="description" content={description} />
<meta name="description" lang="en" content={descriptionEn} />
<meta name="author" content={author} />
<meta name="generator" content={Astro.generator} />
<meta name="keywords" content={keywords.join(", ")} />

<!-- Canonical -->
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={fullDescription} />
<meta property="og:image" content={ogImage} />
<meta property="og:site_name" content="Kailash 2026 | 冈仁波齐" />
<meta property="og:locale" content="zh_CN" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={fullDescription} />
<meta name="twitter:image" content={ogImage} />

<!-- Article meta -->
{publishDate && <meta property="article:published_time" content={publishDate} />}
{modifiedDate && <meta property="article:modified_time" content={modifiedDate} />}

<!-- Icons -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />

<!-- Theme color -->
<meta name="theme-color" content="#1a1a2e" />

<!-- Schema.org: TouristAttraction for Mount Kailash -->
<script type="application/ld+json">
{JSON.stringify(touristAttractionLd)}
</script>

<!-- Schema.org: Organization -->
<script type="application/ld+json">
{JSON.stringify(organizationLd)}
</script>

<!-- Schema.org: BreadcrumbList -->
<script type="application/ld+json">
{JSON.stringify(breadcrumbListLd)}
</script>

{faqPageLd && (
  <script type="application/ld+json">
    {JSON.stringify(faqPageLd)}
  </script>
)}

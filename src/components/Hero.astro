---
const features = [
  {
    title: "The Center of the World / 世界的中心",
    description: "Mount Kailash is revered as the sacred mountain by four major religions: Hinduism, Tibetan Buddhism, Bön, and Jainism. Every year, tens of thousands of pilgrims from around the world come to complete the holy Kora. / 冈仁波齐被藏传佛教、印度教、苯教、耆那教四大宗教共同尊为神山，每年吸引全球数万名朝圣者前来转山。",
    icon: "🌍"
  },
  {
    title: "Global Pilgrim Community / 全球朝圣者社区",
    description: "Connect with pilgrims from India, Nepal, China, Europe, America, and beyond. Share routes, experiences, and spiritual stories across borders and faiths. / 连接来自印度、尼泊尔、中国、欧美等地的朝圣者，分享路线、经验与信仰故事。",
    icon: "🤝"
  },
  {
    title: "Professional Services / 专业服务",
    description: "Multilingual guides, international team support, medical and logistics assistance. Ensuring every pilgrim completes their journey safely and meaningfully. / 多语言向导、国际团队接待、医疗与后勤支持，让每位朝圣者安全完成心愿。",
    icon: "✨"
  }
];
---

<!-- Fullscreen Background Hero -->
<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  
  <!-- Background with overlay -->
  <div class="absolute inset-0 bg-kailash-dark">
    <div class="absolute inset-0 bg-[url('/images/kailash-golden.jpg')] bg-cover bg-center opacity-60"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-kailash-dark/60 via-kailash-dark/40 to-kailash-dark"></div>
  </div>
  
  <!-- Content -->
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-20">
    
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-2 mb-8">
      <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
      <span class="text-white/90 text-sm">2026 Pilgrimage Season Now Open / 2026年朝圣季开放预订</span>
    </div>
    
    <!-- Main Title -->
    <h1 class="font-display text-6xl md:text-7xl lg:text-8xl text-white font-bold mb-4 leading-tight">
      Kailash <span class="text-kailash-gold">2026</span>
    </h1>
    
    <!-- Subtitle -->
    <p class="font-display text-2xl md:text-3xl text-kailash-gold font-semibold mb-4">
      Global Pilgrimage Platform / 全球朝圣者平台
    </p>
    
    <!-- Tagline -->
    <p class="text-xl text-white/70 mb-8">
      Where Pilgrims Unite / 朝圣者在此相聚
    </p>
    
    <!-- Description -->
    <p class="text-white/50 max-w-2xl mx-auto mb-10 leading-relaxed">
      Connecting Global Faiths · Four Sacred Traditions · Professional Support<br>
      <span class="text-white/40">连接全球信仰者 · 四大宗教圣地 · 专业服务支持</span>
    </p>
    
    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
      <a href="/guide" class="group bg-kailash-gold text-kailash-dark px-8 py-4 rounded-lg font-semibold hover:bg-kailash-accent transition-all inline-flex items-center justify-center gap-2">
        Explore Now / 开始探索
        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
      </a>
      <a href="/contact" class="border border-white/30 text-white px-8 py-4 rounded-lg font-semibold hover:bg-white/10 transition-all text-center backdrop-blur-sm">
        Contact Us / 联系我们
      </a>
    </div>
    
    <!-- Stats -->
    <div class="grid grid-cols-3 gap-8 max-w-lg mx-auto pt-8 border-t border-white/20">
      <div>
        <div class="text-3xl font-bold text-kailash-gold">52<span class="text-lg">km</span></div>
        <div class="text-sm text-white/50 mt-1">Kora Route<br>转山路线</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-kailash-gold">5630<span class="text-lg">m</span></div>
        <div class="text-sm text-white/50 mt-1">Highest Point<br>最高海拔</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-kailash-gold">4</div>
        <div class="text-sm text-white/50 mt-1">Sacred Faiths<br>宗教信仰</div>
      </div>
    </div>
  </div>
</section>

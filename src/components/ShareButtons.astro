  en: { shareText: 'Share on', copyText: 'Copy Link', copiedText: 'Copied!', wechat: 'WeChat', weibo: 'Weibo', twitter: 'Twitter/X', facebook: 'Facebook', whatsapp: 'WhatsApp', line: 'LINE', telegram: 'Telegram', copy: 'Copy Link' },
  ja: { shareText: '共有する', copyText: 'リンクをコピー', copiedText: 'コピーしました！', wechat: 'WeChat', weibo: 'Weibo', twitter: 'Twitter/X', facebook: 'Facebook', whatsapp: 'WhatsApp', line: 'LINE', telegram: 'Telegram', copy: 'リンクをコピー' },
  hi: { shareText: 'शेयर करें', copyText: 'लिंक कॉपी करें', copiedText: 'कॉपी हो गया!', wechat: 'WeChat', weibo: 'Weibo', twitter: 'Twitter/X', facebook: 'Facebook', whatsapp: 'WhatsApp', line: 'LINE', telegram: 'Telegram', copy: 'लिंक कॉपी करें' },
};

const t = labels[lang] || labels.zh;


  { key: 'wechat', name: t.wechat, color: 'hover:bg-[#07C160]', icon: 'M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 01.213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 00.167-.054l1.903-1.114a.864.864 0 01.717-.098 10.16 10.16 0 002.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178A1.17 1.17 0 014.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178 1.17 1.17 0 01-1.162-1.178c0-.651.52-1.18 1.162-1.18zm5.34 2.867c-3.95 0-7.15 2.886-7.15 6.448 0 3.56 3.2 6.447 7.15 6.447a7.56 7.56 0 002.264-.332.714.714 0 01.565.074l1.433.838a.237.237 0 00.125.04.22.22 0 00.218-.222c0-.054-.022-.107-.036-.16l-.294-1.114a.444.444 0 01.16-.5C22.907 14.338 24 12.793 24 11.075c0-3.338-3.116-6.045-6.952-6.217zm-2.066 3.39c.48 0 .87.396.87.884a.877.877 0 01-.87.884.877.877 0 01-.87-.884c0-.488.39-.884.87-.884zm4.298 0c.48 0 .87.396.87.884a.877.877 0 01-.87.884.877.877 0 01-.87-.884c0-.488.39-.884.87-.884z' },

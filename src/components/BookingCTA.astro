---
---

<section class="relative py-24 overflow-hidden">
  <!-- Background Image -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-[url('/images/kailash-golden.jpg')] bg-cover bg-top opacity-25"></div>
    <div class="absolute inset-0 bg-gradient-to-br from-kailash-gold/90 via-kailash-accent/90 to-kailash-gold/90"></div>
  </div>
  
  <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm rounded-full px-4 py-2 mb-8">
      <span class="w-2 h-2 bg-white rounded-full animate-pulse"></span>
      <span class="text-white/90 text-sm font-medium">2026 Pilgrimage Season - Now Open / 2026年朝圣季开放</span>
    </div>
    
    <h2 class="font-display text-4xl md:text-6xl font-bold text-kailash-dark mb-6">
      Join the Global<br class="hidden md:block"> Kailash Community<br class="hidden md:block">
      <span class="text-3xl md:text-4xl">加入全球Kailash社区</span>
    </h2>
    
    <p class="text-kailash-dark/70 text-lg md:text-xl mb-10 max-w-2xl mx-auto leading-relaxed">
      Join pilgrims from India, Nepal, China, and around the world on this sacred journey to Mount Kailash<br class="hidden md:block">
      与来自印度、尼泊尔、中国及世界各地的朝圣者一起，完成神圣的冈仁波齐之旅
    </p>
    
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a href="/guide" class="group bg-kailash-dark text-white px-10 py-4 rounded-xl font-semibold text-lg hover:bg-kailash-dark/90 transition-all duration-300 inline-flex items-center gap-2 shadow-xl shadow-kailash-dark/20 hover:shadow-2xl hover:shadow-kailash-dark/30 hover:-translate-y-0.5">
        <span>Explore Routes / 探索路线</span>
        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
      </a>
      <a href="/contact" class="border-2 border-kailash-dark/30 text-kailash-dark px-10 py-4 rounded-xl font-semibold text-lg hover:bg-white/20 hover:border-kailash-dark/50 transition-all duration-300">
        Contact Us / 联系我们
      </a>
    </div>
    
    <div class="mt-12 pt-8 border-t border-kailash-dark/10">
      <p class="text-kailash-dark/50 text-sm tracking-widest uppercase">
        Hinduism · Buddhism · Bön · Jainism · One Sacred Mountain / 印度教 · 佛教 · 苯教 · 耆那教 · 一座神山
      </p>
    </div>
  </div>
</section>
